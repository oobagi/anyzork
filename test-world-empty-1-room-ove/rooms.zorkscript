room testing_chamber {
  name        "The Testing Chamber"
  description "A sterile white cube with no visible seams. Fluorescent light hums from nowhere. A heavy steel door leads north, though it seems to be just for show."
  short       "A white testing cube."
  first_visit "Welcome to the simulation. Please begin your interaction protocols."
  start       true

  exit north -> victory_gallery (locked) "A heavy steel door stands to the north."
}

room victory_gallery {
  name        "The Victory Gallery"
  description "A room filled with trophies and bright streamers. You've reached the end of the test."
  short       "The winner_circle."
  first_visit "Confetti falls from the ceiling!"

  exit south -> testing_chamber "The white void lies back to the south."
}

lock exit_lock {
  exit     testing_chamber -> victory_gallery north
  type     "flag"
  flags    [tested_all_systems]
  locked   "The steel door remains sealed until all test parameters are met."
  unlocked "The steel door slides open with a pneumatic hiss."
}

item stone_pedestal {
  name        "Stone Pedestal"
  description "A waist-high column of gray granite."
  examine     "It's perfectly smooth and firmly rooted to the floor."
  in          testing_chamber
  takeable    false
  container   true
  tags        ["furniture"]
  category    "furniture"
  room_desc   "A Stone Pedestal stands in the center of the room."
  open_msg    "The top of the pedestal slides aside like a lid."
}

item brass_lamp {
  name        "Brass Lamp"
  description "A standard desk lamp with a pull-chain."
  examine     "It looks like it's seen better days, but the bulb is intact."
  in          stone_pedestal
  takeable    true
  home        testing_chamber
  toggle      true
  toggle_state "off"
  on_msg      "The lamp clicks on, bathing the white walls in a warm glow."
  off_msg     "The lamp clicks off."
  tags        ["light_source"]
  category    "tool"
  take_msg    "You pick up the Brass Lamp."
  room_desc   "A Brass Lamp sits atop the pedestal."
  drop_desc   "The Brass Lamp lies on the floor."
}

item heavy_chest {
  name        "Heavy Chest"
  description "A wooden chest reinforced with iron bands."
  examine     "It has a simple keyhole. It looks like it could hold a lot of test data."
  in          testing_chamber
  takeable    false
  container   true
  locked      true
  key         iron_key
  tags        ["container"]
  category    "container"
  room_desc   "A Heavy Chest sits in the corner."
  lock_msg    "The chest is locked tight."
  open_msg    "The lid creaks open."
}

item iron_key {
  name        "Iron Key"
  description "A heavy, cold piece of iron."
  examine     "It's a very standard-looking key. Probably for the chest."
  in          testing_chamber
  takeable    true
  home        testing_chamber
  tags        ["key"]
  category    "key"
  take_msg    "You pocket the Iron Key."
  room_desc   "An Iron Key is lying on the floor."
  drop_desc   "The Iron Key is here."
}

item red_button {
  name        "Red Button"
  description "A large, tempting red button mounted on the wall."
  examine     "It practically begs to be pushed. A label underneath says 'TEST'."
  in          testing_chamber
  takeable    false
  tags        ["mechanism"]
  category    "fixture"
  room_desc   "A large Red Button is mounted to the west wall."
}

item lead_pipe {
  name        "Lead Pipe"
  description "A short, heavy length of industrial piping."
  examine     "It's dull, gray, and very solid."
  in          heavy_chest
  takeable    true
  home        testing_chamber
  tags        ["weapon"]
  category    "weapon"
  take_msg    "You lift the Lead Pipe. It's got some weight to it."
  room_desc   "A Lead Pipe is leaning against the chest."
}

item nutrient_bar {
  name        "Nutrient Bar"
  description "A foil-wrapped slab of compressed calories."
  examine     "The label says 'Flavor: Neutral'. It looks edible, barely."
  in          heavy_chest
  takeable    true
  quantity    1
  max_quantity 1
  quantity_unit "bar"
  depleted_msg "You've eaten the whole thing."
  tags        ["food"]
  category    "food"
  take_msg    "You take the Nutrient Bar."
  room_desc   "A foil-wrapped Nutrient Bar is here."
}

flag tested_all_systems "Test cycle complete"
flag light_functional "Lamp has been lit"
flag chest_opened "Chest has been opened"
flag button_pressed "Button has been pressed"
flag npc_satisfied "Dummy test complete"
flag chest_accessible "Key has been found"
flag sequence_initiated "Sequence started"
flag gallery_unlocked "Gallery is accessible"
flag fed_the_bot "The maintenance bot has been given energy"
flag bot_hit "The maintenance bot was struck"
flag instructor_annoyed "The instructor was hit"
flag dummy_hit "Dummy struck"
flag dummy_fed "Dummy fed"
flag lamp_lit_once "Lamp activated once"

on "push {target}" in [testing_chamber] {
  require not_flag(button_pressed)

  effect set_flag(button_pressed)
  effect set_flag(chest_accessible)
  effect make_visible(heavy_key)
  effect add_score(10)
  success "You press the Red Button. A satisfying 'DING' echoes through the room. A hidden floor tile clicks open."
  fail    "You've already pressed the button."
  once
}

on "push {target}" {
  success "There is nothing here worth pushing."
}

on "climb {target}" {
  success "There is no reason to climb the {target} in this controlled environment."
}

on "hit {target}" {
  success "You swing wildly, but you don't have a reason to hit the {target} yet."
}

when flag_set(light_functional) {
  require has_flag(chest_opened)
  require has_flag(button_pressed)
  require has_flag(npc_satisfied)

  effect set_flag(tested_all_systems)
  effect unlock(exit_lock)
  message "A chime sounds! The north door is now unlocked."
}

when flag_set(dummy_hit) {
  effect set_flag(npc_satisfied)
  effect add_score(10)
  message "The dummy wobbles but remains upright. Test complete."
  once
}

when flag_set(dummy_fed) {
  effect set_flag(npc_satisfied)
  effect add_score(10)
  message "The dummy 'eats' the bar through some unseen mechanism. Test complete."
  once
}

when item_taken(lead_pipe) {
  effect set_flag(chest_opened)
  effect add_score(10)
  once
}

when item_taken(heavy_key) {
  message "The key is cold and heavy. This should fit the iron chest."
}

when dialogue_node(instructor_tasks) {
  effect add_score(2)
  message "The Instructor marks something down on his clipboard."
}

interaction weapon_on_character {
  tag      "weapon"
  target   "character"
  response "You swing the {item} at the {target}!"
  effect   set_flag(dummy_hit)
  effect   set_flag(instructor_annoyed)
}

interaction food_on_character {
  tag      "food"
  target   "character"
  response "You offer the {item} to the {target}."
  consumes 1
  effect   set_flag(dummy_fed)
  effect   set_flag(fed_the_bot)
}

interaction weapon_on_furniture {
  tag      "weapon"
  target   "furniture"
  response "You whack the {target} with the {item}. It makes a dull thud."
}

interaction key_on_furniture {
  tag      "key"
  target   "furniture"
  response "You try the {item} on the {target}. It fits perfectly."
  effect   unlock(heavy_chest)
}

interaction weapon_on_default {
  tag      "weapon"
  target   "*"
  response "You poke the {target} with the {item}. Nothing happens."
}

interaction food_on_default {
  tag      "food"
  target   "*"
  response "The {target} doesn't seem interested in eating the {item}."
}

interaction tool_on_default {
  tag      "tool"
  target   "*"
  response "You poke the {target} with your {item}. Nothing happens."

quest main:test_run {
  name        "The Gauntlet"
  description "Satisfy the requirements of the testing chamber to reach the gallery."
  completion  tested_all_systems
  score       50

  objective "Light the lamp" -> light_functional
  objective "Search the chest" -> chest_opened
  objective "Push the button" -> button_pressed
  objective "Interact with the dummy" -> npc_satisfied
}

quest main:simulation_test {
  name        "Master of the Void"
  description "Complete all interaction protocols to prove the simulation is stable."
  completion  gallery_unlocked
  score       50

  objective "Reveal and take the heavy key" -> chest_accessible
  objective "Unlock and search the iron chest" -> sequence_initiated
  objective "Acquire the gold trophy from the gallery" -> gallery_unlocked
}

quest side:bot_friend {
  name        "The Machine's Hunger"
  description "The small robot in the gallery seems to be looking for something."
  completion  fed_the_bot
  score       10

  objective "Give the energy bar to the maintenance bot" -> fed_the_bot
}

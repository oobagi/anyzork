npc dummy {
  name        "Test Dummy"
  description "A wooden mannequin with a painted-on face."
  examine     "It stands perfectly still, waiting for interaction."
  in          testing_chamber
  home        testing_chamber
  room_desc   "A Test Dummy stands near the north door, watching you expectantly."
  dialogue    "The dummy doesn't move, but you feel like it's listening."
  category    "character"

  talk root {
    "The dummy's painted eyes stare back at you."
    option "Are you the gatekeeper?" -> gate_info
    option "I'm done talking to wood."
  }

  talk gate_info {
    "A small sign around its neck flips over. It reads: 'Perform the four tests to pass.'"
    option "What tests?" -> test_list
    option "Right, thanks." -> root
  }

  talk test_list {
    "'Light the lamp. Open the chest. Push the button. Interact with me.'"
    option "Got it." -> root
  }
}

npc instructor {
  name        "The Instructor"
  description "A tall, translucent figure wearing a lab coat."
  examine     "His features are blurry, as if he is made of low-resolution light. He holds a digital clipboard."
  in          testing_chamber
  home        testing_chamber
  room_desc   "The Instructor stands by the north wall, observing you."
  category    "character"

  talk root {
    "The Instructor looks up from his clipboard. 'Standard testing protocols are in effect. Please proceed with interaction.'"
    option "What am I supposed to do?" -> tasks
    option "Are you real?" -> reality_check
    option "I'm working on it."
  }

  talk tasks {
    "'You must demonstrate mastery over this environment. Light the lamp, access the chest, and trigger the primary sequence. Only then can the gallery be opened.'"
    option "How do I open the chest?" -> chest_hint
    option "Understood." -> root
  }

  talk chest_hint {
    "'Observation is key. Perhaps the button provides more than just a sound. Look closely at the floor when you press it.'"
    option "Thanks for the tip." -> root
  }

  talk reality_check {
    "'Reality is a relative term in this sector. I am a manifestation of the system's guidance subroutines.'"
    option "That's helpful, I guess." -> root
  }
}

npc maintenance_bot {
  name        "Maintenance Bot"
  description "A small, boxy robot with three wheels and a single optical sensor."
  examine     "It chirps quietly. A small hatch on its front is labeled 'FUEL'."
  in          victory_gallery
  home        victory_gallery
  room_desc   "A small Maintenance Bot trundles aimlessly around the gallery."
  category    "character"

  talk root {
    "The robot emits a series of binary beeps."
    option "Can you help me get out of here?" -> escape_talk
    option "Nice robot."
  }

  talk escape_talk {
    "It displays a message on its screen: 'ERROR: DESTINATION NOT FOUND. CURRENT STATUS: VICTORIOUS.'"
    option "I'll take that as a compliment." -> root
    option "Goodbye, little bot."
  }
}

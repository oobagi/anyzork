# --- Puzzle 21: Ward Stabilization ---

on "read mural" in [malachar_gallery] {
  effect set_flag(knows_ward_order)
  effect add_score(5)
  success "The mural stretches the full length of the gallery. Four figures stand around a pulsing stone, each touching it in turn. The sequence is clear: first Helga Hufflepuff in yellow, then Rowena Ravenclaw in blue, then Godric Gryffindor in red, and finally Salazar Slytherin in green. The order they laid the wards. The order that must be repeated to stabilize them."
  done "You already know the ward activation order."
  once
}

on "examine mural" in [malachar_gallery] {
  effect set_flag(knows_ward_order)
  effect add_score(5)
  success "The mural stretches the full length of the gallery. Four figures stand around a pulsing stone, each touching it in turn. The sequence is clear: first Helga Hufflepuff in yellow, then Rowena Ravenclaw in blue, then Godric Gryffindor in red, and finally Salazar Slytherin in green. The order they laid the wards. The order that must be repeated to stabilize them."
  done "You already know the ward activation order."
  once
}


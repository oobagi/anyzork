game {
  title          "Harry Potter and the Founders' Convergence"
  author         "Generated for AnyZork"
  intro_text     "You open your eyes to candlelight and the distant rumble of magic gone wrong. The Great Hall surrounds you — but something is deeply off. The enchanted ceiling doesn't show the sky anymore. It shows a storm that belongs to no season, no geography, no world you recognize. Professor McGonagall stands at the head table, her expression carved from flint. Ron Weasley sits nearby, pale, picking at the edge of his sleeve. Neither of them looks surprised to see you. They look like they've been waiting."
  win_text       "Your quest is complete. The Convergence Stone is sealed. Hogwarts endures."
  lose_text      "The wards have fallen. Hogwarts' magic is no more."
  max_score      500
  realism        "medium"
  win_conditions [stone_sealed]
  lose_conditions [player_died, stone_corrupted]
}

player {
  start_room great_hall
  hp         100
  max_hp     100
}
# ═══════════════════════════════════════════════════
#   ROOMS — HOGWARTS COMMONS
# ═══════════════════════════════════════════════════

room great_hall {
  name              "Great Hall"
  description       "The Great Hall stretches before you, impossibly long, its four house tables scarred with hex-burns and littered with abandoned goblets. Hundreds of candles float overhead in uneven clusters, their flames guttering in a wind that has no source. The enchanted ceiling churns with bruise-colored storms that never break — lightning crawls between clouds but no thunder follows. The air smells of cold stone and something faintly metallic, like the aftertaste of a spell gone wrong."
  short_description "The Great Hall is dim and unsettled. Candles gutter overhead and the enchanted ceiling writhes with silent, unnatural storms."
  first_visit_text  "The enchanted ceiling churns with storm clouds that have no business being indoors. The candles flicker in unison, as if the castle itself is breathing."
  region            "hogwarts_commons"
  is_start          true
  exit north -> entrance_hall "A wide archway leads north to the Entrance Hall."
  exit east -> kitchen_corridor "A short passage leads east toward the kitchens."
}

room entrance_hall {
  name              "Entrance Hall"
  description       "The Entrance Hall rises around you in cold marble, its vaulted ceiling lost in shadow. The grand staircase dominates the north wall, its flights shifting with grinding, arrhythmic lurches — stairs swinging to landings they were never meant to reach. Portraits line every surface, their occupants huddled in clusters, whispering behind painted hands. The floor tiles are cracked in a radial pattern, as though something struck the center with tremendous force."
  short_description "The marble Entrance Hall echoes with the grinding of shifting staircases and the nervous whispers of a hundred portraits."
  first_visit_text  "You step into the Entrance Hall and the grand staircase lurches — an entire flight of stone swings sideways with a groan that vibrates in your teeth, connecting to a landing three stories above where it has no business going. The portraits gasp in unison. One of them — a medieval witch in a starched ruff — catches your eye and shakes her head slowly. 'Don't trust the stairs, dear,' she whispers. 'They've forgotten where they belong.'"
  region            "hogwarts_commons"
  exit south -> great_hall "The Great Hall lies south."
  exit north -> grand_staircase "The grand staircase climbs northward."
  exit east -> corridor_east "A corridor stretches east."
  exit west -> corridor_west "A corridor leads west."
}

room grand_staircase {
  name              "Grand Staircase"
  description       "The grand staircase is a vertical labyrinth of stone flights that grind and pivot without warning, connecting and disconnecting landings in a slow, senseless dance. Banisters end in mid-air. A flight above you rotates a full quarter-turn and locks into place with a shudder. To the north, a stone gargoyle blocks a spiral staircase leading upward, its carved eyes following you with patient malice. The seventh-floor corridor is accessible above."
  short_description "Staircases grind and shift around you in chaotic loops. A stone gargoyle guards the north passage. The seventh floor is accessible above."
  first_visit_text  "A flight of stairs directly above you detaches from its landing with a grinding shriek, pivots forty-five degrees, and locks into a new position with a shudder that rains dust from above. The staircase isn't broken — it's forgotten what order means."
  region            "hogwarts_commons"
  exit south -> entrance_hall "Back down to the Entrance Hall."
  exit up -> seventh_floor_corridor "Stairs climb to the seventh floor."
}

room corridor_east {
  name              "East Corridor"
  description       "A long corridor stretches eastward, its flagstones uneven and cold beneath your feet. Suits of armor that once stood in orderly ranks along the walls have been shoved aside — some toppled, some propped against each other like wounded soldiers. One has been driven halfway through a wall, its gauntlet reaching out from the stone as if drowning. Torchlight catches the dull gleam of scattered metal. The air smells of rust and old magic."
  short_description "The east corridor is cluttered with displaced suits of armor, their metal bodies scattered and half-embedded in stone."
  first_visit_text  "Suits of armor that once stood in orderly ranks have been displaced — some toppled, one driven halfway through a wall. The castle's magic is no longer gentle."
  region            "hogwarts_commons"
  exit west -> entrance_hall "The Entrance Hall lies west."
  exit north -> library "The corridor leads north toward the library."
  exit east -> hospital_wing "A passage leads east to the hospital wing."
}

room corridor_west {
  name              "West Corridor"
  description       "A draft curls through the western corridor like something alive, tugging at your robes and pushing torch flames into long, flickering tongues that lean uniformly northward. The walls here are rougher, the stonework older, the mortar dark with age. Water stains streak downward from the ceiling in patterns that almost look deliberate — like claw marks, or writing in a language you can't read. The passage narrows as it continues."
  short_description "The west corridor is drafty and narrow, its torches leaning in a wind that shouldn't exist. Water stains streak the old stone walls."
  first_visit_text  "A draft curls through the corridor like something alive. The torches lean uniformly northward, pushed by a wind that has no source."
  region            "hogwarts_commons"
  exit east -> entrance_hall "Back to the Entrance Hall."
  exit north -> trophy_room "The corridor leads to the trophy room."
  exit west -> dungeon_stairs "Stone steps descend west into the dungeons."
}

room library {
  name              "Library"
  description       "Towering shelves of dark wood reach from floor to vaulted ceiling, packed with books that refuse to stay still. Pages turn themselves with dry, papery whispers. A thick volume on a reading stand snaps its covers shut as you pass, then opens again to a different page. The smell is old parchment, dust, and the faint ozone tang of preservation charms working overtime. A velvet rope blocks the northern alcove, and to the east, a section of shelving sits at an angle that doesn't quite match the wall behind it."
  short_description "The library hums with restless books turning their own pages. Shelves stretch to the ceiling and a velvet rope blocks the northern alcove."
  first_visit_text  "The books are restless. You can hear pages turning by themselves, deep in the stacks. Hermione doesn't seem to find this unusual."
  region            "hogwarts_commons"
  exit south -> corridor_east "Back to the east corridor."
}

room restricted_section {
  name              "Restricted Section"
  description       "The air here is heavier, colder, and tastes faintly of iron. The books are chained to their shelves, and the chains are taut — not hanging slack but pulled tight, as if the volumes are straining to reach you. One book vibrates against its restraints with a low, constant hum. Another has frost creeping across its leather cover despite the room being dry. A reading table in the center holds a single empty book stand and the residue of spilled ink that has dried in a shape disturbingly close to a screaming face."
  short_description "Chained books strain against their restraints in the cold, heavy air. The restricted section feels like it is watching you."
  first_visit_text  "The air here is heavier, colder. The chained books strain against their restraints. One of them whispers your name. You are quite sure you did not imagine it."
  region            "hogwarts_commons"
  is_dark           true
  exit south -> library "Back to the library."
}

room trophy_room {
  name              "Trophy Room"
  description       "Glass display cases line the walls of this hexagonal chamber, their contents gleaming under enchanted spotlights that track your movement. Quidditch cups, academic shields, and Special Awards for Services to the School stand in polished rows. One large case at the room's center is locked with a heavy brass mechanism — inside, you can see a velvet cushion bearing something that glints. The north wall bears a tapestry of a rearing lion, its mane woven in actual gold thread that catches the light strangely."
  short_description "The trophy room gleams under tracking spotlights. A locked case at the center holds something on a velvet cushion. A golden lion tapestry covers the north wall."
  first_visit_text  "Enchanted spotlights track your movement across polished glass cases. The trophies gleam with self-importance. The locked case at the center catches your attention — something glints inside."
  region            "hogwarts_commons"
  exit south -> corridor_west "Back to the west corridor."
}

room hospital_wing {
  name              "Hospital Wing"
  description       "Two rows of pristine white beds stretch toward tall windows that let in pale, watery light. The sheets are pulled tight with military precision, the pillows plumped, every surface scrubbed to a shine — but no patients lie here, and the emptiness feels wrong, like a held breath. A medicine cabinet stands against the east wall, its glass doors reflecting the room in duplicate. The smell of dittany and essence of murtlap hangs thick enough to taste."
  short_description "The hospital wing is spotless and empty, its white beds untouched. The smell of healing potions saturates the sterile air."
  first_visit_text  "The sterile whiteness of the hospital wing is almost aggressive after the castle's gloom. Empty beds stand in precise rows. The smell of dittany saturates the air."
  region            "hogwarts_commons"
  exit west -> corridor_east "Back to the east corridor."
}

room dungeon_stairs {
  name              "Dungeon Stairs"
  description       "Cold radiates from the stone steps like a living thing, climbing your ankles and settling into your bones. The staircase descends in a tight spiral, its walls slick with condensation that glitters in the sparse torchlight. Each step is worn smooth in the center by centuries of footsteps. The passage east leads back to the western corridor. In the deepest shadows below, where the spiral tightens, the wall has a hairline crack that runs floor to ceiling — perfectly straight, perfectly vertical, as if placed there with intention."
  short_description "Cold stone steps spiral downward, slick with condensation. A hairline crack runs perfectly vertical in the deepest shadow of the stairwell."
  first_visit_text  "The temperature drops sharply as you descend. Your breath mists. Something in the stones hums at a frequency you can feel in your teeth."
  region            "hogwarts_commons"
  exit east -> corridor_west "Back to the west corridor."
  exit down -> potions_classroom "The stairs descend to the potions classroom."
}

room potions_classroom {
  name              "Potions Classroom"
  description       "The dungeon classroom is exactly as oppressive as its reputation demands. Stone walls sweat in the heat of a dozen simmering cauldrons left unattended on their burners, their contents bubbling in colors that shift when you're not looking directly at them. Shelves of jars line the back wall — pickled ingredients floating in murky fluids, their labels written in Snape's cramped, precise hand. An ingredient cabinet stands beside the teacher's desk. The air is a war between sulfur, peppermint, and something sweet and rotting."
  short_description "Snape's potions classroom simmers with unattended cauldrons and the competing smells of a dozen volatile ingredients."
  first_visit_text  "The dungeon classroom smells of sulfur and old failure. Cauldrons simmer unattended. Snape's presence lingers even when he is here — the room feels like it is judging you."
  region            "hogwarts_commons"
  exit up -> dungeon_stairs "Steps climb back to the dungeon stairs."
}

room kitchen_corridor {
  name              "Kitchen Corridor"
  description       "A short, low-ceilinged passage connects the Great Hall to the lower kitchens. The walls are hung with still-life paintings of elaborate feasts — roast turkeys, towering cakes, pyramids of crystallized fruit — and the painted food seems almost to steam. One painting stands out: a large canvas depicting a silver bowl overflowing with ripe pears. The largest pear is rendered with peculiar detail, its brushstrokes catching the light. The air is warm, carrying the yeasty smell of baking bread from somewhere below."
  short_description "The warm kitchen corridor smells of baking bread. A painting of a silver bowl of pears hangs prominently on the wall."
  first_visit_text  "Warm air rolls over you, carrying the smell of fresh bread and roasting meat. The paintings of elaborate feasts seem almost to steam. One canvas catches your eye — a bowl of pears, rendered with unsettling precision. The largest pear glistens as if wet, and you could swear it moved."
  region            "hogwarts_commons"
  exit west -> great_hall "Back to the Great Hall."
  exit east -> kitchens "The passage leads down to the kitchens."
}

room kitchens {
  name              "Kitchens"
  description       "The Hogwarts kitchens are a cathedral of copper pots, roaring hearths, and organized chaos. Four long tables mirror the house tables in the Great Hall above, currently buried under mountains of half-prepared food. House-elves swarm between workstations in a blur of tea-towels and enormous eyes, chopping, stirring, and levitating dishes with effortless magic. A set of cold stores in the far corner is padlocked with enchanted chains. Despite the bustle, there's an undercurrent of anxiety — the elves work too fast, glance at the ceiling too often."
  short_description "The kitchens bustle with anxious house-elves preparing food beneath mountains of copper pots. Enchanted chains seal the cold stores."
  first_visit_text  "A blast of warm air and the smell of baking bread. House-elves bustle between enormous copper pots, but they move nervously, flinching at every tremor in the walls."
  region            "hogwarts_commons"
  exit west -> kitchen_corridor "Back to the kitchen corridor."
}

room dumbledore_office {
  name              "Dumbledore's Office"
  description       "The circular office hums with the quiet ticking and whirring of a hundred silver instruments, each one performing some inscrutable measurement of forces you cannot name. Portraits of former headmasters line the curved walls, most feigning sleep, a few watching you with undisguised interest. Fawkes perches on his golden stand, his plumage dimmer than legend suggests. The Sorting Hat sits on a high shelf, its brim twitching. Dumbledore's desk is cluttered with parchment, lemon drop wrappers, and a single open journal."
  short_description "Dumbledore's circular office whirs with silver instruments. Fawkes perches quietly. The former headmasters watch from their portraits."
  first_visit_text  "The office is exactly as cluttered as you remember — silver instruments whirring, portraits of former headmasters pretending to sleep, and Fawkes's empty perch. Dumbledore sits behind his desk, looking older than you have ever seen him."
  region            "hogwarts_commons"
  exit south -> grand_staircase "The spiral staircase descends to the grand staircase."
}

room seventh_floor_corridor {
  name              "Seventh Floor Corridor"
  description       "The seventh-floor corridor is quieter than the rest of the castle — an almost reverent hush, broken only by the distant grinding of staircases below. The left wall is conspicuously blank: smooth, unbroken stone where every other corridor in Hogwarts is cluttered with portraits and tapestries. The blankness has a quality to it, a sense of potential, as if the wall is listening. Opposite, a tapestry of Barnabas the Barmy being clubbed by trolls hangs slightly askew. Scorch marks on the floor tiles suggest recent experimentation."
  short_description "The seventh-floor corridor is hushed. One wall is conspicuously blank and seems to listen. Scorch marks dot the floor."
  first_visit_text  "The seventh floor is quieter than the rest of the castle. The air here feels thick with secrets. A stretch of blank wall catches your attention — smooth, featureless, waiting."
  region            "hogwarts_commons"
  exit down -> grand_staircase "Steps descend to the grand staircase."
}

# ═══════════════════════════════════════════════════
#   ROOMS — HOGWARTS GROUNDS
# ═══════════════════════════════════════════════════

room courtyard {
  name              "Courtyard"
  description       "The open courtyard offers the first breath of outside air, and it tastes wrong — thin and metallic, like licking a copper Knut. The sky overhead is a deep, burnt amber that belongs to no hour of the day, casting everything in sepia tones. A stone sundial stands at the center, its gnomon snapped clean off. Cloistered walkways frame the space on three sides, their arches casting geometric shadows across flagstones scattered with dead leaves that crunch like parchment."
  short_description "The courtyard sits under an amber sky that belongs to no natural hour. A broken sundial stands at its center, gnomon snapped clean."
  first_visit_text  "The sky above the courtyard is the wrong color — a faint amber, like parchment held up to a lamp. The sundial's shadow points in a direction that doesn't correspond to any compass point."
  region            "hogwarts_grounds"
  exit east -> entrance_hall "Through the archway back to the Entrance Hall."
  exit south -> greenhouse "A path leads south to the greenhouse."
  exit west -> clock_tower_base "The clock tower entrance is to the west."
}

room greenhouse {
  name              "Greenhouse"
  description       "Glass walls and ceiling panels let in the sickly amber light, refracting it into prismatic bands across rows of potting benches and hanging baskets. The greenhouse is a riot of magical botany — Venomous Tentaculas strain against their pots, puffapods quiver at your approach, and a Whomping Willow sapling thrashes in a reinforced planter. The air is thick, humid, and sweet with the smell of dragon dung fertilizer and fresh-turned earth."
  short_description "The greenhouse is humid and overgrown with magical plants straining against their pots. Amber light refracts through glass panels."
  first_visit_text  "The glass walls magnify the strange amber sky. Plants reach toward light that isn't quite right. Neville is here, tending to a Venomous Tentacula with the calm focus of someone who understands things that don't talk back."
  region            "hogwarts_grounds"
  exit north -> courtyard "Back to the courtyard."
}

room clock_tower_base {
  name              "Clock Tower Base"
  description       "The base of the clock tower is a stone chamber dominated by the massive clock mechanism overhead — a cathedral of brass gears, iron pendulums, and crystal escapements, all frozen mid-motion. The great clock has stopped. Its hands are visible through a gap in the ceiling, fixed at an hour that doesn't correspond to any number on the face. A thick layer of brass dust coats every surface, disturbed only by a single set of footprints leading to the mechanism and back."
  short_description "The clock tower's massive mechanism is frozen mid-motion, its gears locked. Brass dust coats everything."
  first_visit_text  "The clock tower's mechanism fills the space above you — a cathedral of gears and pendulums, all still. The silence where ticking should be feels profoundly wrong."
  region            "hogwarts_grounds"
  exit east -> courtyard "Back to the courtyard."
  exit north -> hagrid_hut "A path leads north to Hagrid's hut."
}

room hagrid_hut {
  name              "Hagrid's Hut"
  description       "The hut is exactly as oversized and warm as you'd expect — a single round room with a crackling fire, a bed the size of a small boat, and a table set with mugs large enough to bathe a cat in. Crossbow bolts, gardening gloves, and unidentifiable animal teeth litter every surface. The walls are hung with copper pans and what appears to be a dragon-hide coat. A distinct smell of treacle, dog, and woodsmoke saturates everything. Through the fogged windows, the edge of the Forbidden Forest is a dark, uneven line."
  short_description "Hagrid's hut is warm and cluttered, smelling of treacle and woodsmoke. The Forbidden Forest looms darkly through the windows."
  first_visit_text  "The hut smells of rock cakes and dog. Fang raises his enormous head from beside the fireplace, whimpers, and puts it back down. Even the boarhound knows something is wrong."
  region            "hogwarts_grounds"
  exit south -> clock_tower_base "Back toward the clock tower."
  exit east -> forest_edge "A path leads east to the forest edge."
}

room forest_edge {
  name              "Forest Edge"
  description       "The treeline of the Forbidden Forest rises before you like a wall of black teeth. The amber sky does not penetrate the canopy — beyond the first row of trunks, the darkness is absolute and impenetrable. The undergrowth rustles with movements that don't match the wind. Sounds emerge and retreat: a twig snap, a low whistle, something heavy shifting its weight deeper in. The grass at the forest's edge is brown and dead in a perfect line, as if the trees are draining the life from everything around them."
  short_description "The Forbidden Forest looms ahead, its darkness absolute beyond the first trees. The grass at the treeline is dead in a sharp, unnatural border."
  first_visit_text  "The Forbidden Forest is louder than usual. Not with animal sounds — with whispers, as if the trees are discussing something amongst themselves."
  region            "hogwarts_grounds"
  exit west -> hagrid_hut "Back to Hagrid's hut."
  exit north -> lake_shore "A muddy path leads north along the treeline to the lake."
}

room lake_shore {
  name              "Lake Shore"
  description       "The Black Lake stretches before you, utterly still, its surface like polished obsidian reflecting the amber sky in muted tones. No ripples disturb it. A small rowboat is pulled halfway onto the muddy shore, its oars shipped and its hull crusted with dried algae. Something in the shallows catches the light — the corner of an object protruding from the mud, half-buried and encrusted with silt. The water laps with a sound that is almost, but not quite, rhythmic — as if the lake is breathing slowly in its sleep."
  short_description "The Black Lake is impossibly still, its surface like black glass. A small rowboat rests on the muddy shore. Something glints in the shallows."
  first_visit_text  "The Black Lake is flat and still as a mirror. In its surface, Hogwarts is reflected perfectly — except the reflection's windows are dark, every one, as though the castle in the lake has already been abandoned."
  region            "hogwarts_grounds"
  exit south -> forest_edge "Back along the treeline."
}

# ═══════════════════════════════════════════════════
#   ROOMS — GRYFFINDOR TRIAL
# ═══════════════════════════════════════════════════

room gryffindor_antechamber {
  name              "Gryffindor Antechamber"
  description       "The passage behind the tapestry opens into a stone chamber lit by torches that burn deep crimson, casting everything in shades of blood and shadow. A carved lion's head dominates the far wall, its mane flowing into the stonework as if the beast is emerging from the rock itself. Below the lion, words are chiseled in an ancient hand: 'Courage is not the absence of fear, but the will to walk through it.' The air is warmer here than anywhere in the castle, and carries the faint smell of woodsmoke and iron."
  short_description "Crimson torches light a stone chamber. A carved lion emerges from the far wall above an inscription about courage."
  region            "gryffindor_trial"
  exit south -> trophy_room "Back through the passage to the trophy room."
  exit north -> lion_corridor "A corridor stretches north, lined with living tapestries."
}

room lion_corridor {
  name              "Lion Corridor"
  description       "A long corridor stretches north, its walls hung with tapestries that move with more than magical animation — they live. A woven Gryffindor charges a basilisk and the threads actually strain, the fabric bulging outward. Another panel shows a young witch standing alone against a tide of darkness, her expression set with quiet determination. The floor tiles are alternating red and gold, worn smooth by centuries. A breeze from the north carries the smell of smoke and the distant crackle of fire."
  short_description "Animated tapestries of courage line this red-and-gold corridor. A hot breeze and the crackle of fire drift from the north."
  first_visit_text  "Animated tapestries line the walls, depicting acts of bravery in stitched gold thread. A knight charges a dragon. A witch shields a child from a curse. The figures move, but slowly, as if watching you."
  region            "gryffindor_trial"
  exit south -> gryffindor_antechamber "Back to the antechamber."
  exit north -> bridge_of_flames "The corridor opens onto a bridge wreathed in fire."
  exit east -> fear_chamber "A dark doorway leads east into shadow."
}

room fear_chamber {
  name              "Fear Chamber"
  description       "The room is dark — profoundly, aggressively dark, the kind of darkness that presses against your skin. Your wand light reaches only a few feet before being swallowed. Something in the far corner shifts, scrapes, and reshapes itself with a wet, wooden sound. A wardrobe stands against the back wall, its door hanging open, and the darkness inside it is somehow darker than the rest of the room. The temperature fluctuates — warm, then cold, then warm again — as if the room itself is breathing."
  short_description "Oppressive darkness fills this room. A wardrobe stands open against the back wall, and something inside it shifts and reshapes itself."
  first_visit_text  "Darkness. Absolute, pressing darkness. Something shifts in the void — you can hear it breathing, or maybe that's you. The room is pitch black without a light source."
  region            "gryffindor_trial"
  is_dark           true
  exit west -> lion_corridor "Back to the lion corridor."
}

room bridge_of_flames {
  name              "Bridge of Flames"
  description       "A narrow stone bridge arcs over a chasm that drops into absolute blackness. Magical fire erupts from the bridge's surface in irregular bursts — not the orange of natural flame, but a deep, arterial red that throws no heat until it touches you. The bridge is wide enough for one person and has no railings. The far side is visible through curtains of rising flame: a stone doorway framed by two carved torches. The fire moves in rhythmic patterns, with gaps that open and close like a breathing creature."
  short_description "A narrow stone bridge spans a black chasm, erupting with rhythmic bursts of red magical fire."
  first_visit_text  "Heat hits you like a wall. The stone bridge spans a chasm of indeterminate depth, and magical fire erupts in arterial-red bursts across its surface. The flames roar with a sound like a living thing."
  region            "gryffindor_trial"
  exit south -> lion_corridor "Back to the corridor."
  exit north -> guardian_hall "Across the bridge to the guardian hall."
}

room guardian_hall {
  name              "Guardian Hall"
  description       "The hall is wide and round, its ceiling lost in shadow, its walls carved with scenes of sacrifice and protection — wizards shielding others, falling so that someone behind them might stand. At the room's center, a magical barrier shimmers like a wall of amber light, and behind it, a figure is trapped — arms at their sides, expression frozen between fear and resignation. The barrier hums with a low, constant tone. A plaque between two stone levers reads: 'What would you give?'"
  short_description "A magical barrier traps a figure at the center of this round hall. Stone levers stand on either side, and wall carvings depict acts of sacrifice."
  first_visit_text  "Rubble. Dust. And Ron, pinned under a collapsed section of ceiling, one leg trapped beneath a stone slab. He looks up at you with pain-glazed eyes. 'Harry — took a wrong turn. Classic me, right?'"
  region            "gryffindor_trial"
  exit south -> bridge_of_flames "Back across the bridge."
  exit north -> gryffindor_vault "A passage leads north to the vault."
}

room gryffindor_vault {
  name              "Gryffindor Vault"
  description       "The vault is smaller than you expected — intimate, almost reverent, like the interior of a reliquary. Red and gold light pulses gently from the walls themselves, as if the stone has a heartbeat. A stone pedestal at the center holds a gleaming token bearing the Gryffindor crest: a rampant lion in ruby and gold. Above the pedestal, a spectral sword hangs in mid-air — a replica of Gryffindor's blade, translucent and shimmering, present but untouchable."
  short_description "The intimate Gryffindor vault pulses with red-gold light. A token bearing the lion crest rests on a stone pedestal beneath a spectral sword."
  first_visit_text  "Golden light floods the chamber. A replica of Godric Gryffindor's sword hangs above a stone plinth, and on that plinth rests a small golden token stamped with a lion rampant. The air here feels safe — fierce, but safe."
  region            "gryffindor_trial"
  exit south -> guardian_hall "Back to the guardian hall."
}

# ═══════════════════════════════════════════════════
#   ROOMS — RAVENCLAW TRIAL
# ═══════════════════════════════════════════════════

room ravenclaw_antechamber {
  name              "Ravenclaw Antechamber"
  description       "The passage behind the shifted bookshelf leads to a chamber of blue-tinged stone, its geometry subtly wrong — the corners don't quite meet at right angles, the ceiling is higher on one side than the other, and the shadows fall in directions that disagree with the torchlight. An eagle-shaped bronze knocker is mounted on the north door, its beak slightly parted, its eyes gleaming with genuine intelligence. Below it, no handle, no keyhole — only smooth, featureless wood."
  short_description "Blue-tinged stone and subtly wrong geometry define this chamber. A bronze eagle knocker guards the north door with ancient, patient intelligence."
  first_visit_text  "The passage narrows into blue-tinged stone. An eagle door-knocker watches you with bronze eyes that follow your movement. The air smells of parchment and distant rain."
  region            "ravenclaw_trial"
  exit south -> library "Back to the library."
}

room riddle_hall {
  name              "Riddle Hall"
  description       "The hall is impossibly tall, its walls lined with bookshelves that extend upward beyond the reach of any light, vanishing into a darkness that suggests infinity rather than ceiling. Three stone pedestals stand in a row at the room's center, each bearing a different symbol carved into the surface. The floor is a mosaic of blue and bronze tiles arranged in a pattern that almost resolves into meaning, like a word on the tip of your tongue."
  short_description "Infinite bookshelves rise into darkness. Three pedestals stand at the center. The mosaic floor almost resolves into meaning."
  first_visit_text  "Three pedestals stand in a row, each lit by a beam of light from no visible source. The floor is a mosaic of interlocking geometric patterns that seem to rearrange when you look away."
  region            "ravenclaw_trial"
  exit south -> ravenclaw_antechamber "Back south to the antechamber."
  exit east -> mirror_maze "A passage leads east into reflected light."
  exit north -> logic_chamber "A doorway leads north, flanked by purple flames."
}

room mirror_maze {
  name              "Mirror Maze"
  description       "Mirrors line every surface — walls, floor, ceiling — but they do not show your reflection. They show Hogwarts. Different eras, different seasons, different centuries. In one mirror, the Great Hall is being built, its stones rising by wand-light. In another, students in archaic robes duel in a corridor you recognize. A third shows a figure surrounded by centaurs, gesturing at stars. The mirrors hum at slightly different frequencies, creating a dissonant chord that vibrates in your chest."
  short_description "Every surface is mirrored, but the mirrors show Hogwarts across centuries rather than your reflection."
  first_visit_text  "Mirrors surround you on every side, but your reflection is wrong — or rather, it's not your reflection. Each mirror shows a scene from Hogwarts history: the Sorting, a duel, a Quidditch match. In one, you see Professor Snape writing something on a parchment."
  region            "ravenclaw_trial"
  exit west -> riddle_hall "Back to the riddle hall."
}

room logic_chamber {
  name              "Logic Chamber"
  description       "A stone table dominates this rectangular chamber, and on it, seven bottles stand in a precise line — each a different size, each filled with a liquid of a different color. Purple fire blocks the north doorway. Black fire seals the south. A roll of parchment lies before the bottles, its edges singed, its text written in a hand that manages to be both elegant and clinical. The logic puzzle is not about magic — it is about reason."
  short_description "Seven bottles stand on a stone table between walls of purple and black fire. A singed parchment describes a logic puzzle."
  first_visit_text  "Seven bottles of varying size and color stand on a stone table. Purple fire blocks the passage north. A verse is carved into the wall above the bottles. This is Snape's puzzle — or its ancestor."
  region            "ravenclaw_trial"
  exit south -> riddle_hall "Through the black fire back to the riddle hall."
}

room celestial_room {
  name              "Celestial Room"
  description       "The ceiling is gone — or rather, it has been replaced by the night sky itself, but not the amber-sick sky visible from the courtyard. This sky is deep and clear and ancient, blazing with stars in constellations you half-recognize. Star charts float at eye level like luminous parchment, rotating slowly. The room has no visible walls — the star field extends in every direction, and the floor beneath you is glass or crystal, revealing more stars below. You are standing in the center of the universe, and it is asking you to pay attention."
  short_description "An ancient, clear sky replaces ceiling and walls, blazing with constellations. Star charts float and rotate at eye level."
  first_visit_text  "The ceiling opens into an impossible sky. Star charts float in the air like luminous sheets of parchment, rotating slowly. And standing among them, looking both relieved and unsurprised, is Hermione."
  region            "ravenclaw_trial"
  exit south -> logic_chamber "Back through the purple fire."
}

room ravenclaw_vault {
  name              "Ravenclaw Vault"
  description       "The vault manifests as a perfect sphere of blue-white light, its interior smooth and featureless except for a single crystalline pedestal at the exact center. On the pedestal rests a token bearing the Ravenclaw crest: an eagle in sapphire and bronze, its detail impossibly fine, as if carved by thought rather than hand. Above it, a spectral diadem hovers — Rowena's lost crown, its ghostly gems refracting sourceless light. The room is perfectly silent, and the silence itself feels like an answer."
  short_description "A spherical vault of blue-white light holds the Ravenclaw token on a crystal pedestal. A spectral diadem floats above it in perfect silence."
  first_visit_text  "Blue-white light fills the chamber like captured moonlight. A silver diadem — Rowena Ravenclaw's — rests on a crystalline stand. Beside it, the Ravenclaw Token gleams: a small eagle cast in bronze."
  region            "ravenclaw_trial"
  exit south -> celestial_room "Back to the celestial room."
}

# ═══════════════════════════════════════════════════
#   ROOMS — HUFFLEPUFF TRIAL
# ═══════════════════════════════════════════════════

room hufflepuff_antechamber {
  name              "Hufflepuff Antechamber"
  description       "The passage descends gently into a chamber woven with living roots — they form the walls, the ceiling, the frame of the doorway, their bark smooth and honey-colored, warm to the touch. A carved badger sits above the southern passage, its stone eyes kind rather than fierce. Below it, words have been carved with care rather than grandeur: 'Those who are patient shall find the way.' The air smells of fresh earth, warm bread, and lavender. Soft amber light emanates from the roots themselves."
  short_description "Living roots form the walls of this warm, earth-scented chamber. A carved badger watches over an inscription about patience."
  first_visit_text  "Warmth rises from the floor. The walls are woven with living roots, and the air smells of honey and fresh earth. A badger carved in stone watches the entrance with patient, knowing eyes."
  region            "hufflepuff_trial"
  exit north -> kitchens "Back up to the kitchens."
  exit south -> loyalty_passage "A root-woven tunnel leads south."
}

room loyalty_passage {
  name              "Loyalty Passage"
  description       "The tunnel is round and low, its walls packed earth threaded with luminous roots that pulse with a gentle, warm light. The ground is soft underfoot — not muddy, but yielding, like walking on moss. The passage curves gently, never sharply, as if it was grown rather than dug. Halfway along its length, something glints on the ground — a small golden object, half-hidden in the roots, catching the bioluminescent light. The air is thick with the smell of turned soil and honey."
  short_description "A round, root-woven tunnel pulses with warm light. Something golden glints among the roots on the tunnel floor."
  first_visit_text  "The passage is long and warm. Something glints on the ground ahead — gold, catching the root-filtered light."
  region            "hufflepuff_trial"
  exit north -> hufflepuff_antechamber "Back to the antechamber."
  exit south -> crossroads_of_need "The tunnel continues south to a junction."
}

room crossroads_of_need {
  name              "Crossroads of Need"
  description       "The tunnel opens into a junction where three passages meet, their root-woven walls converging overhead in a knotted canopy. The light here is dimmer, uncertain, as if the roots are waiting to see which way you'll go. At the center of the junction, a ghostly figure flickers — a student in old-fashioned Hogwarts robes, translucent and sorrowful, looking between the eastern and western passages with an expression of agonized indecision."
  short_description "Three passages meet at this junction. A ghostly student flickers at the center, wringing translucent hands in indecision."
  first_visit_text  "The passage opens into a junction. A ghostly student stands at the center, translucent hands clasped, looking lost. They notice you and something like hope crosses their face."
  region            "hufflepuff_trial"
  exit north -> loyalty_passage "Back through the passage."
  exit east -> wounded_stranger "A passage leads east, carrying the smell of something hurt."
  exit west -> garden_of_patience "A passage leads west, carrying the smell of growing things."
}

room wounded_stranger {
  name              "Wounded Stranger"
  description       "The passage ends in a small, circular chamber where a spectral figure lies against the root wall — injured, flickering, one hand pressed to its side where a ghostly wound pulses with faint light. The figure's robes are torn. Its face shifts between features, never settling on one identity, as if it is everyone who has ever needed help. It looks up at you with eyes that hold no accusation, only a quiet, patient question. A shelf of roots beside it holds a hollow where something potion-sized would fit perfectly."
  short_description "A shifting spectral figure lies wounded against the wall, watching you with patient, questioning eyes."
  first_visit_text  "A spectral figure lies slumped against the wall, flickering like a candle in a draft. They are hurt — you can see it in the way their light dims and brightens, dims and brightens. They look up at you with eyes full of pain and no expectation of help."
  region            "hufflepuff_trial"
  exit west -> crossroads_of_need "Back to the crossroads."
}

room garden_of_patience {
  name              "Garden of Patience"
  description       "The chamber opens into an underground garden that defies every expectation of a space without sun. Bioluminescent flowers in amber and white dot raised beds of dark earth. At the garden's center, a planting bed holds a single seedling — barely a sprout, its leaves curled tight. A watering can sits beside it, enchanted to never empty, and a small hourglass rests on a stone bench nearby. Everything in this room grows, but nothing grows fast. The air is warm, patient, and smells of honey and time."
  short_description "An underground garden glows with bioluminescent flowers. A single seedling waits in a central planting bed beside an enchanted watering can."
  first_visit_text  "An underground garden glows with bioluminescent flowers in every shade of amber and gold. A single seedling sits in a central planting bed, small and green and stubbornly still. An enchanted watering can rests nearby. A plaque reads: 'Patience bears fruit.'"
  region            "hufflepuff_trial"
  exit east -> crossroads_of_need "Back to the crossroads."
  exit south -> hufflepuff_vault "A passage leads south, glowing with brighter light."
}

room hufflepuff_vault {
  name              "Hufflepuff Vault"
  description       "The vault is a perfect circle of warm earth and golden light, its walls woven from roots so tightly braided they resemble fabric. A stone pedestal at the center holds a token bearing the Hufflepuff crest: a badger in topaz and onyx, its expression gentle but unwavering. Above it, a spectral cup floats — Helga's cup, translucent gold, steam rising from its rim as if it holds an eternal draft of something warm and sustaining. The room radiates comfort and the quiet pride of work completed without fanfare."
  short_description "Golden light fills this root-woven vault. The Hufflepuff token rests on a pedestal beneath a spectral cup that steams with eternal warmth."
  first_visit_text  "Golden light fills the root-woven vault like liquid honey. Helga Hufflepuff's cup — a replica, but no less beautiful — steams with eternal warmth on a stone shelf. Beside it rests the Hufflepuff Token: a small badger cast in bronze."
  region            "hufflepuff_trial"
  exit north -> garden_of_patience "Back to the garden."
}

# ═══════════════════════════════════════════════════
#   ROOMS — SLYTHERIN TRIAL
# ═══════════════════════════════════════════════════

room slytherin_antechamber {
  name              "Slytherin Antechamber"
  description       "The passage descends sharply, the walls narrowing to rough-hewn stone slick with moisture. Green torchlight replaces the warm orange of the upper castle, casting everything in the pallor of deep water. A massive stone door blocks the southern passage — two carved serpents intertwined, their emerald eyes glittering with embedded gems, their mouths open as if mid-hiss. The door has no handle, no keyhole, no mechanism you can see. The stone vibrates faintly under your palm."
  short_description "Green torchlight illuminates slick stone walls. A door carved with twin serpents blocks the south passage, vibrating faintly."
  first_visit_text  "Water drips from the ceiling in steady, rhythmic drops. The walls are carved with intertwined serpents, their stone scales glistening with moisture. Green torchlight casts everything in an undersea glow."
  region            "slytherin_trial"
  exit north -> potions_classroom "Back up to the potions classroom."
  exit south -> serpent_hall "Through the serpent door."
}

room serpent_hall {
  name              "Serpent Hall"
  description       "The hall is long and narrow, its walls lined with mirrors of dark, smoke-colored glass that distort rather than reflect — stretching your silhouette, compressing the space, making the corridor appear to bend when it does not. Serpent carvings writhe along the baseboards in frozen undulation. The green torchlight here is brighter but somehow less illuminating, as if it reveals surfaces without revealing depth. Water runs in thin rivulets along channels cut into the floor, whispering against the stone."
  short_description "Distorting dark mirrors line a narrow hall where serpent carvings writhe along the baseboards. Green torchlight reveals surfaces but hides depth."
  first_visit_text  "Mirrors line both walls, but your reflection is wrong — it moves a half-second behind you, and its expression doesn't match yours. The hall stretches ahead in green-tinged silence."
  region            "slytherin_trial"
  exit north -> slytherin_antechamber "Back to the antechamber."
  exit south -> deception_room "A passage leads south to a circular chamber."
  exit east -> ambition_stair "A passage leads east to a spiral staircase."
}

room deception_room {
  name              "Deception Room"
  description       "Three chests sit in a triangular arrangement at the center of a circular chamber. One is silver, polished to a mirror shine. One is gold, ornate and heavy, encrusted with gemstones. One is iron, plain and dented, its hinges rusted, sitting slightly apart from the others as if forgotten. The walls bear no carvings, no inscriptions, no guidance — only the serpent motif repeating in the stonework, its eyes always watching. The room smells of brine and old metal."
  short_description "Three chests — silver, gold, and iron — sit in a triangular arrangement. The room offers no guidance."
  first_visit_text  "Three identical chests sit against the far wall: one silver, one gold, one iron. An inscription above them reads: 'The cunning see through lies. The foolish grasp at glitter.'"
  region            "slytherin_trial"
  exit north -> serpent_hall "Back to the serpent hall."
}

room ambition_stair {
  name              "Ambition Stair"
  description       "A stone staircase spirals upward into green-lit darkness, its steps growing narrower and steeper as they ascend. There is no visible top — the stairs simply vanish into shadow. At the base of the staircase, an offering stone juts from the wall — a flat ledge of polished obsidian with a circular depression carved into its surface, sized to hold something specific. The serpent carvings here are denser, more agitated, their coils overlapping in a pattern that suggests hierarchy."
  short_description "A staircase spirals into green darkness with no visible top. An offering stone of polished obsidian waits at the base."
  first_visit_text  "A staircase rises into shadow — but has no top. An offering stone sits at its base, carved with a serpentine mouth. A voice, sourceless and cold, whispers: 'To rise, you must leave something behind.'"
  region            "slytherin_trial"
  exit west -> serpent_hall "Back to the serpent hall."
  exit south -> bargain_chamber "A passage leads south to a low-ceilinged chamber."
}

room bargain_chamber {
  name              "Bargain Chamber"
  description       "The chamber is intimate, almost conspiratorial — low ceiling, close walls, green light pooled on a single stone desk at the center. On the desk lies an unfurled scroll of parchment that glows faintly along its edges, its text shifting and rearranging as you watch. An enchanted quill stands upright beside it, poised and waiting. The room's walls are carved with scenes of alliances — hands clasping, figures conspiring in candlelight, the ambitious rising through partnership."
  short_description "A glowing contract and an enchanted quill wait on a stone desk. The intimate walls are carved with scenes of ambition and alliance."
  first_visit_text  "An enchanted contract floats in the center of the chamber, its parchment glowing faintly. The ink rewrites itself as you watch, as though anticipating what you might agree to."
  region            "slytherin_trial"
  exit north -> ambition_stair "Back to the staircase."
  exit south -> slytherin_vault "A passage leads south to the vault."
}

room slytherin_vault {
  name              "Slytherin Vault"
  description       "The vault is a cathedral of green stone and silver light, far grander than the others — because Slytherin never did anything without spectacle. Carved serpents coil around pillars that support a vaulted ceiling, their scales individually rendered in obsidian and jade. A stone pedestal at the center holds a token bearing the Slytherin crest: a serpent in emerald and silver, coiled and watchful. Above it, a spectral locket rotates slowly — Salazar's locket, its surface crawling with engraved serpents."
  short_description "The grand Slytherin vault gleams with green stone and silver light. The serpent token rests beneath a slowly rotating spectral locket."
  first_visit_text  "The deepest chamber. Water pools on the floor, reflecting green torchlight upward across the ceiling in rippling patterns. A silver locket — Salazar Slytherin's — hangs in a glass case. Beside it, the Slytherin Token: a small serpent cast in silver."
  region            "slytherin_trial"
  exit north -> bargain_chamber "Back to the bargain chamber."
}

# ═══════════════════════════════════════════════════
#   ROOMS — THE DEPTHS
# ═══════════════════════════════════════════════════

room ancient_passage {
  name              "Ancient Passage"
  description       "The crack in the dungeon wall opens into something that is not Hogwarts. The stonework changes mid-step — from medieval masonry to something far older, blocks so precisely fitted that no mortar was needed, their surfaces covered in carvings that predate the runic alphabet. The air is thicker, copper-tasting, pressurized. Veins of black mineral thread through the stone, pulsing with a faint luminescence that is not quite light and not quite darkness. Something ahead is humming — low, constant, felt in the bones more than heard."
  short_description "Pre-Hogwarts stone stretches into darkness, its blocks carved in a forgotten script. Black veins pulse in the walls and something hums deep ahead."
  first_visit_text  "You step through the crack and the world changes. The dungeons — cold and damp and familiar — end mid-stride, replaced by something ancient. The stone is darker, denser, carved with symbols that hurt to look at directly. The temperature drops. The air tastes of copper and deep earth. And beneath your feet, through the stone itself, you feel it — a vibration, rhythmic and patient, like a heartbeat that has been counting the centuries."
  region            "the_depths"
  exit up -> dungeon_stairs "The crack leads back up to the dungeon stairs."
  exit south -> ward_chamber "The passage continues south, deeper."
}

room ward_chamber {
  name              "Ward Chamber"
  description       "The passage opens into a domed chamber of dark stone, its ceiling lost in shadow. Four ward stones stand at the cardinal points — rough-hewn monoliths taller than a person, each pulsing with a different color: ruby red, sapphire blue, topaz gold, emerald green. The colors are fading. Each pulse is weaker than the last, the intervals growing longer, like a heart struggling to beat. Black veins crawl across the surface of each stone. Between the ward stones, the floor is carved with a massive circle of interlocking runes."
  short_description "Four ward stones pulse in fading house colors — red, blue, gold, green — their surfaces crawling with black veins."
  first_visit_text  "Four ward stones rise from the floor in a diamond pattern, each pulsing with a different color: yellow, blue, red, green. Their rhythm is erratic — they flicker and stutter, out of sync, straining against the corruption that darkens the surrounding rock."
  region            "the_depths"
  exit north -> ancient_passage "Back through the ancient passage."
  exit south -> malachar_gallery "The passage continues south."
}

room malachar_gallery {
  name              "Malachar's Gallery"
  description       "The walls of this long gallery are covered in murals painted directly onto the stone in pigments that have not faded in a millennium. They tell a story. A fifth figure stands among the four Founders — tall, gaunt, hands raised in supplication or command. Malachar. The murals progress: alliance, collaboration, disagreement, betrayal, war. In the final panel, the four Founders stand united against the fifth, their wands raised, and between them, the Convergence Stone floats, its surface already veined with the first threads of corruption."
  short_description "Ancient murals depict the Founders' war with Malachar — from alliance to betrayal. The final panel shows the Convergence Stone, already corrupted."
  first_visit_text  "Murals cover every surface — ceiling, walls, floor. They depict a war: four robed figures against one. The lone figure's face has been scratched away, but his rage is still visible in his posture. Malachar the Undying. And his story."
  region            "the_depths"
  exit north -> ward_chamber "Back to the ward chamber."
  exit south -> convergence_antechamber "The passage leads south to a polished black chamber."
}

room convergence_antechamber {
  name              "Convergence Antechamber"
  description       "The antechamber is a small, hexagonal room of polished black stone, its surfaces so smooth they reflect the green-black light like dark water. Four alcoves are carved into the walls at equal intervals, each bearing the crest of a Hogwarts house above a circular depression perfectly sized for a Founder's token. Three of the four alcoves are dark. The fourth pulses weakly, as if remembering what it was meant to hold. The south wall is a massive stone door, sealed, carved with interlocking runes."
  short_description "Four alcoves bearing house crests wait for tokens in this polished black chamber. A sealed rune-carved door blocks the south passage."
  first_visit_text  "Four alcoves are carved into the walls, each shaped for a specific artifact. The air vibrates with raw magical energy. A rune-carved door seals the passage south. Beyond it, you can feel something immense and corrupted, pulsing like a diseased heart."
  region            "the_depths"
  exit north -> malachar_gallery "Back to the gallery."
}

room convergence_chamber {
  name              "Convergence Chamber"
  description       "The chamber is vast — a perfect circle of ancient stone, its walls rising to a dome so high it might be open sky if the sky were made of black rock. At the exact center, the Convergence Stone floats three feet above a runic circle carved into the floor. It is massive — taller than you, rough-hewn, its surface a web of black veins that pulse with a sickly, arrhythmic light. The humming is deafening, a vibration that blurs your vision and loosens your teeth. The stone is beautiful. The stone is wrong."
  short_description "The Convergence Stone floats at the center of this vast circular chamber, pulsing with corrupted black veins."
  first_visit_text  "The door opens and the sound hits you like a wall — a vibration so deep it bypasses your ears entirely and resonates in your skeleton. The Convergence Stone. None of the whispers, none of the fragments of a thousand-year-old story prepared you for this. It floats at the chamber's center like a dark heart, massive and ancient, its surface alive with veins of black corruption. The magic radiating from it is overwhelming — pressing against your skin like deep water. The Founders sealed this beneath their school. They built Hogwarts on top of it. And the lock is failing."
  region            "the_depths"
  exit north -> convergence_antechamber "Back to the antechamber."
}
# ===============================================
#   HIDDEN EXITS
# ===============================================
#
# Exits defined here are hidden from the player
# until revealed by flags, triggers, or puzzle
# solutions. They supplement the visible exits
# already declared in 02-rooms.zorkscript.
# ===============================================

# --- Hogwarts Commons: regular locked exit ---

# Gargoyle-blocked exit from grand staircase to Dumbledore's office.
# Visible but locked. Password: "sherbet lemon".
exit gargoyle_exit {
  from        grand_staircase
  to          dumbledore_office
  direction   north
  description "A spiral staircase leads up behind the stone gargoyle."
}

# --- Hogwarts Commons: hidden exits ---

# Restricted Section — revealed when permission_slip shown to Hermione.
exit library_restricted {
  from        library
  to          restricted_section
  direction   north
  description "The velvet rope has been removed, revealing the alcove leading to the Restricted Section."
  is_hidden   true
}

# Ravenclaw Trial entrance — revealed by the Grey Lady's dialogue.
exit library_ravenclaw {
  from        library
  to          ravenclaw_antechamber
  direction   east
  description "A section of shelving has swung aside, revealing a passage of blue-tinged stone."
  is_hidden   true
}

# Gryffindor Trial entrance — revealed by examining the tapestry
# after obtaining the gryffindor_map from the trophy case.
exit trophy_gryffindor {
  from        trophy_room
  to          gryffindor_antechamber
  direction   north
  description "Behind the golden lion tapestry, a narrow passage descends into crimson-lit stone."
  is_hidden   true
}

# Hufflepuff Trial entrance — revealed by Dobby after completing
# his side quest (dobby_helped flag).
exit kitchens_hufflepuff {
  from        kitchens
  to          hufflepuff_antechamber
  direction   south
  description "Behind the largest barrel, a root-woven passage descends into warm earth."
  is_hidden   true
}

# Slytherin Trial entrance — revealed by using the revealer_potion
# on the dungeon wall in the potions classroom.
exit potions_slytherin {
  from        potions_classroom
  to          slytherin_antechamber
  direction   south
  description "The shimmering wall has dissolved, revealing slick stone steps descending into green torchlight."
  is_hidden   true
}

# --- The Depths: hidden exits ---

# Entrance to the Depths — revealed when all four trial flags are set.
exit dungeon_depths {
  from        dungeon_stairs
  to          ancient_passage
  direction   down
  description "The hairline crack has widened into a passage. Ancient, pre-Hogwarts stonework stretches into darkness below."
  is_hidden   true
}

# --- Convergence: hidden exit ---

# Final door to the Convergence Chamber — revealed when all four
# Founder Tokens are placed in the token alcove.
exit antechamber_convergence {
  from        convergence_antechamber
  to          convergence_chamber
  direction   south
  description "The rune-carved door has opened. Beyond it, the Convergence Stone pulses with dark, rhythmic light."
  is_hidden   true
}

# --- Ravenclaw Trial: locked/hidden exits ---

# Eagle riddle door — unlocked by answering the eagle's riddle.
# The exit exists but is locked; the player must say the answer.
exit ravenclaw_riddle {
  from        ravenclaw_antechamber
  to          riddle_hall
  direction   north
  description "The featureless door swings open, admitting you to the Hall of Riddles."
  is_hidden   true
}

# Logic Chamber forward exit — unlocked by drinking the correct potion.
exit logic_celestial {
  from        logic_chamber
  to          celestial_room
  direction   north
  description "The purple fire parts, revealing the passage to the Celestial Room."
  is_hidden   true
}

# Celestial Room to Ravenclaw Vault — revealed when star charts combined.
exit celestial_vault {
  from        celestial_room
  to          ravenclaw_vault
  direction   north
  description "The star field parts to reveal a sphere of blue-white light — Ravenclaw's Vault."
  is_hidden   true
}

# ===============================================
#   LOCKS
# ===============================================
#
# Each lock binds to an exit and defines the
# mechanism that must be satisfied to pass.
# ===============================================

# --- Gargoyle Password Lock ---
# Type: combination. Player must say "sherbet lemon".
# Requires knows_gargoyle_password flag (set by McGonagall dialogue).
lock gargoyle_lock {
  exit grand_staircase -> dumbledore_office north
  type "combination"
  combination "sherbet lemon"
  locked "The gargoyle does not move. It seems to be waiting for something."
  unlocked "The gargoyle leaps aside, revealing a spiral staircase."
}

# --- Restricted Section Lock ---
# Type: flag. Hidden exit revealed when restricted_unlocked is set.
lock restricted_lock {
  exit library -> restricted_section north
  type "flag"
  flags [restricted_unlocked]
  locked "A velvet rope blocks the northern alcove. You'll need permission to enter."
  unlocked "The velvet rope has been removed. The Restricted Section is accessible."
}

# --- Ravenclaw Eagle Riddle Lock ---
# Type: combination. The eagle knocker poses a riddle.
# Answer: "nothing" (What has no weight, can be seen but not touched,
# and when put in a barrel makes the barrel lighter?)
lock ravenclaw_door_lock {
  exit ravenclaw_antechamber -> riddle_hall north
  type "combination"
  combination "nothing"
  locked "The eagle knocker watches you. 'What has no weight, can be seen but not touched, and when put in a barrel makes the barrel lighter?' it asks."
  unlocked "The eagle knocker nods, its bronze beak curving into something almost like a smile. The door swings inward."
}

# --- Serpent Door Lock ---
# Type: key. Requires the slytherin_ring to open.
lock serpent_door_lock {
  exit slytherin_antechamber -> serpent_hall south
  type "key"
  key slytherin_ring
  locked "The twin serpents hiss in unison. The door does not yield. Their open mouths seem to expect something to be placed inside."
  unlocked "The slytherin ring slides into the serpent's mouth. The stone eyes flash, and the door grinds open."
}

# --- Convergence Door Lock ---
# Type: flag. The rune-carved door opens only when tokens_placed is set.
lock convergence_door_lock {
  exit convergence_antechamber -> convergence_chamber south
  type "flag"
  flags [tokens_placed]
  locked "The rune-carved door is sealed. Four alcoves in the walls wait for something to be placed within them."
  unlocked "The four tokens blaze in their alcoves. The rune-carved door shudders and swings inward."
}

# --- Bridge of Flames Lock ---
# Type: flag. The north exit from bridge_of_flames requires flame_protected.
# Note: the exit itself exists in 02-rooms.zorkscript (bridge_of_flames north
# -> guardian_hall). This lock gates safe passage; the player CAN brute-force
# through at the cost of 40 HP, handled by a trigger, but the lock controls
# the "clean" path.
lock bridge_lock {
  exit bridge_of_flames -> guardian_hall north
  type "flag"
  flags [flame_protected]
  locked "Magical fire erupts across the bridge in arterial-red bursts. Crossing without protection would be extremely painful."
  unlocked "The flames wash over you harmlessly, feeling like warm bathwater. The bridge is safe to cross."
}
# ═══════════════════════════════════════════
#   REVERSE EXITS — Missing connections
# ═══════════════════════════════════════════

# Corridor West -> Courtyard (courtyard exits east to entrance_hall,
# but entrance_hall has all directions used. Connect via corridor_west south.)
exit corridor_to_courtyard {
  from        corridor_west
  to          courtyard
  direction   south
  description "A stone archway opens south to the courtyard."
}
# ===============================================
#   FLAG REGISTRY
# ===============================================
#
# Every boolean game-state flag used by the
# Founders' Convergence. Organized by category
# to match GDD Section 14.
#
# Flags are set by commands, triggers, dialogue
# nodes, and puzzle completions. They are checked
# by lock preconditions, quest objectives, trigger
# guards, and ending resolution.
# ===============================================


# -----------------------------------------------
#   Core Story Flags
# -----------------------------------------------

flag has_main_quest              "Dumbledore has briefed Harry on the Convergence Stone crisis and granted the main quest."
flag knows_gargoyle_password     "McGonagall revealed the gargoyle password (sherbet lemon)."
flag restricted_unlocked         "Permission slip shown to Hermione; Restricted Section is accessible."
flag restricted_lore_read        "Read the lore books in the Restricted Section about Malachar and the Stone."
flag knows_revealer_recipe       "Read the Revealer Potion recipe in the Restricted Section."
flag ravenclaw_entrance_known    "The Grey Lady revealed the Ravenclaw Trial entrance in the library."
flag grey_lady_clue              "The Grey Lady shared her clue about Ravenclaw's Trial."
flag dobby_helped                "Completed Dobby's cold stores quest; Dobby revealed the Hufflepuff Trial entrance."


# -----------------------------------------------
#   Trial Completion Flags
# -----------------------------------------------

flag trial_gryffindor_complete   "Gryffindor Trial completed — Token of Courage claimed."
flag trial_ravenclaw_complete    "Ravenclaw Trial completed — Token of Wisdom claimed."
flag trial_hufflepuff_complete   "Hufflepuff Trial completed — Token of Loyalty claimed."
flag trial_slytherin_complete    "Slytherin Trial completed — Token of Cunning claimed."
flag all_trials_complete         "All four Founders' Trials have been completed. The Depths are accessible."


# -----------------------------------------------
#   Moral Choice Flags
# -----------------------------------------------

flag ron_rescued                 "Harry gave a healing potion to Ron in the Guardian Hall, freeing him."
flag ron_abandoned               "Harry left Ron trapped in the Guardian Hall and pressed on alone."
flag stranger_healed             "Harry healed the spectral student in the Hufflepuff Trial."
flag loyalty_proven              "Harry returned the golden locket to the ghostly student at the Crossroads of Need."
flag locket_kept                 "Harry kept the golden locket instead of returning it."
flag draco_allied                "Harry proposed cooperation with Draco in the Slytherin Trial and Draco accepted."
flag draco_hostile               "Harry confronted Draco in the Slytherin Trial, making an enemy."
flag draco_neutral               "Harry neither allied with nor confronted Draco — Draco is absent from the endgame."
flag sacrifice_made              "Harry placed an item on the offering stone in the Stair of Ambition."


# -----------------------------------------------
#   Puzzle-State Flags
# -----------------------------------------------

flag boggart_defeated             "The Boggart in the Fear Chamber has been dispelled by Riddikulus."
flag flame_protected              "Harry drank the Flame-Freezing Potion — safe to cross the Bridge of Flames."
flag pedestals_complete           "All three items placed on the pedestals in the Riddle Hall."
flag logic_potion_drunk           "Harry drank the correct bottle (fifth) in the Logic Chamber."
flag charts_combined              "Harry and Hermione combined the northern and southern star charts."
flag charm_planted                "The Hufflepuff Charm has been planted in the Garden of Patience seedling."
flag garden_bloomed               "The Garden of Patience seedling has bloomed after the player solved another puzzle."
flag knows_ward_order             "Harry examined the murals in Malachar's Gallery and learned the ward activation order."
flag ward_yellow_active           "Yellow (Hufflepuff) ward stone activated — ward sequence step 1."
flag ward_blue_active             "Blue (Ravenclaw) ward stone activated — ward sequence step 2."
flag ward_red_active              "Red (Gryffindor) ward stone activated — ward sequence step 3."
flag ward_green_active            "Green (Slytherin) ward stone activated — ward sequence step 4."
flag wards_stabilized             "All four ward stones activated in the correct order. Wards temporarily stabilized."
flag tokens_placed                "All four Founder Tokens placed in the token alcove. The Convergence Chamber door is open."


# -----------------------------------------------
#   Ending Flags
# -----------------------------------------------

flag stone_sealed                "Meta-flag: the Convergence Stone has been sealed by any method. Win condition."
flag stone_sealed_unity          "Ending A — Unity: all four virtue flags present, curse fully purged."
flag stone_sealed_sacrifice      "Ending B — Sacrifice: Harry channeled his own magic, burning out his power."
flag stone_sealed_rival          "Ending C — Rival's Redemption: Draco and Harry sealed the Stone together."
flag stone_sealed_partial        "Ending D — Compromise: Harry sealed the Stone alone, imperfectly."
flag stone_corrupted             "Ending E — The Fall: Malachar's curse overwhelmed the Stone. Lose condition."
flag player_died                 "Player HP reached 0. Lose condition (engine automatic)."


# -----------------------------------------------
#   Side Quest Flags
# -----------------------------------------------

# -- Dobby's Cold Stores --
flag dobby_quest_discovered      "Dobby asked for help opening the enchanted cold stores."
flag has_warming_token           "Received the Warming Charm Token from Flitwick."
flag cold_stores_opened          "Used the Warming Charm Token on the cold stores in the kitchens."

# -- The Nargle Hunt --
flag nargle_quest_discovered     "Luna mentioned the Wrackspurt infestation — side quest discovered."
flag shimmer_examined            "Examined the strange shimmer in the east corridor."
flag nargles_found               "Reported findings to Luna — Nargle Hunt quest complete."

# -- Malachar's History --
flag malachar_quest_discovered   "Read Founder's Journal Page 2 in the Restricted Section — Malachar quest discovered."
flag malachar_journal_read       "Read Malachar's Journal in the Depths."
flag malachar_history_complete   "Pieced together Malachar's full history."

# -- Fred and George's Trade --
flag twins_quest_discovered      "Spoke to Fred and George — trade quest discovered."
flag has_enough_galleons         "Collected at least 5 Galleons."
flag twins_trade_complete        "Completed the trade with Fred and George."

# -- The Founder's Journal --
flag journal_quest_discovered    "Found Founder's Journal Page 1 — journal collection quest discovered."
flag journal_page_1_found        "Found Founder's Journal Page 1 (Clock Tower)."
flag journal_page_2_found        "Found Founder's Journal Page 2 (Restricted Section)."
flag journal_page_3_found        "Found Founder's Journal Page 3 (Malachar's Gallery)."
flag journal_complete            "All journal pages found — the Founders' story is complete."


# -----------------------------------------------
#   NPC / World State Flags
# -----------------------------------------------

flag ron_warned                  "Ron told Harry about the castle disturbances."
flag hermione_lore_1             "Hermione shared her initial research about the Convergence Stone."
flag snape_warned                "Snape warned Harry about the Convergence Stone."
flag snape_potion_help           "Snape provided guidance on brewing the Revealer Potion."
flag hagrid_founder_info         "Hagrid shared what Dumbledore told him about the Founders' Trials."
flag hagrid_allows_forest        "Hagrid agreed to let Harry enter the Forbidden Forest after seeing the Shield Charm Scroll."
flag nick_founder_lore           "Nearly Headless Nick shared stories about the Founders."
flag luna_riddle_hint            "Luna's dialogue hinted at the answer to the Ravenclaw eagle riddle."
flag baron_name_known            "The Bloody Baron's name can be invoked to scare off Peeves."
flag knows_stone_lore            "Dumbledore explained the nature and history of the Convergence Stone."
flag dumbledore_malachar_info    "Dumbledore revealed the full backstory of Malachar the Undying."
flag twins_hint                  "Fred and George hinted about the seventh floor corridor."
flag myrtle_depths_hint          "Moaning Myrtle described the ancient tunnels beneath the dungeons."
flag ravenclaw_lore              "The Grey Lady shared the history of Rowena Ravenclaw."
# ═══════════════════════════════════════════
#   ITEMS — Harry Potter and the Founders' Convergence
#   43 items total: equipment, quest items, lore, containers, toggleables
# ═══════════════════════════════════════════

# ───────────────────────────────────────────
#   PLAYER EQUIPMENT (starting inventory)
# ───────────────────────────────────────────

item wand {
  name "Harry's Wand"
  description "Your wand — holly and phoenix feather, eleven inches."
  examine "Your wand — ten and a quarter inches, supple, warm in your grip. The wood grain spirals in a pattern unique to your bond with it. It hums faintly when you hold it, resonating with your intent. You notice the tip glows slightly brighter when pointed toward sources of strong magic, as if it can sense what you cannot yet see."
  room_id great_hall
  room_description "Your wand is here."
  is_takeable true
  is_visible true
  tags ["spell"]
  category "tool"
}

item marauders_map {
  name "The Marauder's Map"
  description "A large square of worn parchment, blank to the casual eye."
  examine "A large square of worn parchment, blank to the casual eye. When you tap it with your wand and speak the words 'I solemnly swear that I am up to no good,' ink blooms across its surface like spilled water, revealing a detailed map of Hogwarts — every corridor, every room, every secret passage, labeled in the elegant hand of Messrs. Moony, Wormtail, Padfoot, and Prongs. Tiny labeled dots show the location of everyone in the castle. Some passages on the map are marked that you haven't found yet."
  room_id great_hall
  room_description "The Marauder's Map lies here."
  is_takeable true
  is_visible true
  tags ["tool"]
  category "tool"
}

# ───────────────────────────────────────────
#   KEY ITEMS (from Dumbledore)
# ───────────────────────────────────────────

item enchanted_lantern {
  name "Enchanted Lantern"
  description "A brass lantern the size of your fist, burning a steady blue-white."
  examine "A brass lantern the size of your fist, its flame burning a steady, unwavering blue-white behind beveled glass. It weighs almost nothing. The flame does not flicker in wind, does not dim in darkness, and seems to burn brighter when brought near concealed doorways or hidden mechanisms — as if it is drawn to secrets the way a compass is drawn to north."
  room_id dumbledore_office
  room_description "An enchanted lantern sits on Dumbledore's desk, its flame burning a steady blue-white."
  is_takeable true
  is_visible true
  toggle true
  toggle_default "off"
  on_msg "You open the lantern's shutter. Blue-white light spills out, banishing shadows and revealing what darkness had hidden."
  off_msg "You close the shutter. The light retreats to a faint glow behind beveled glass."
  tags ["light_source"]
  category "tool"
}

item permission_slip {
  name "Signed Permission Slip"
  description "A creased slip of parchment bearing official signatures in emerald ink."
  examine "A creased slip of parchment bearing McGonagall's unmistakable signature in emerald ink. It grants you permission to access areas of the castle normally restricted to prefects and staff. The signature shimmers faintly with authentication magic — counterfeit-proof. The bottom margin bears a small annotation in McGonagall's hand: 'Do try not to get killed.'"
  room_id dumbledore_office
  room_description "A signed permission slip rests among the papers on the desk."
  is_takeable true
  is_visible false
  tags ["key"]
  category "key_item"
}

item invisibility_cloak {
  name "Invisibility Cloak"
  description "A cloak of fluid, silvery fabric that slides through your fingers like water."
  examine "A cloak of fluid, silvery fabric that slides through your fingers like water made of moonlight. When draped over you, it renders you completely invisible — not just hard to see, but genuinely absent from perception. The fabric is weightless and seems to have no temperature. Looking at the cloak too long makes your eyes water, as if the material exists at an angle reality wasn't designed for. One of the Deathly Hallows, though you try not to think about that."
  room_id dumbledore_office
  room_description "A shimmering cloak of silvery fabric lies folded on a side table."
  is_takeable true
  is_visible false
  tags ["stealth"]
  category "tool"
}

# ───────────────────────────────────────────
#   KEY ITEMS (from NPCs / found)
# ───────────────────────────────────────────

item prefect_badge {
  name "Ron's Prefect Badge"
  description "A polished silver badge stamped with a large 'P' and the Hogwarts crest."
  examine "A polished silver badge stamped with a large 'P' and the Hogwarts crest. It feels heavier than it should, weighted with enchantment. When pinned to your robes, it grants a subtle authority — doors that would otherwise resist seem more inclined to open, and portraits are noticeably more cooperative. The back is engraved with tiny text: 'Responsibility is its own reward.'"
  room_id great_hall
  room_description "Ron's prefect badge glints on the table."
  is_takeable true
  is_visible false
  tags ["key"]
  category "key_item"
}

item gryffindor_map {
  name "Map to the Gryffindor Trial"
  description "A fragment of old parchment showing a hand-drawn layout of hidden chambers."
  examine "A fragment of old parchment showing a hand-drawn layout of corridors and chambers beneath the trophy room. The map is rendered in faded red ink, annotated with warnings in a bold, hurried script: 'Fire ahead — find the rhythm' and 'The guardian demands sacrifice, not blood.' A lion watermark is visible when held to the light."
  in trophy_case
  room_description "A fragment of old parchment lies inside the case."
  is_takeable true
  is_visible true
  tags ["lore"]
  category "lore"
}

item slytherin_ring {
  name "Slytherin's Signet Ring"
  description "A heavy silver ring set with an emerald carved in the shape of a coiled serpent."
  examine "A heavy silver ring set with an emerald carved in the shape of a coiled serpent. The metal is cold — unnaturally so, colder than the air around it — and the serpent's eyes seem to follow your gaze. When worn, you feel a faint tingling in your fingertips, as if the ring is testing your intentions. Etched inside the band in tiny script: 'To speak is to command.'"
  in trophy_case
  room_description "A silver ring set with an emerald serpent rests on a velvet cushion."
  is_takeable true
  is_visible true
  tags ["key"]
  category "key_item"
}

item shield_charm_scroll {
  name "Shield Charm Scroll"
  description "A tightly rolled scroll of heavy parchment, sealed with blue wax."
  examine "A tightly rolled scroll of heavy parchment, sealed with blue wax stamped with a stylized shield. When unrolled, it reveals the incantation and wand movement for Protego — the Shield Charm — annotated with tactical notes in a dueling instructor's hand. 'Cast with conviction,' reads a marginal note. 'The shield is only as strong as the will behind it.' Study this to learn the spell permanently."
  room_id hospital_wing
  room_description "A scroll sealed with blue wax lies on a bedside table."
  is_takeable true
  is_visible true
  tags ["key"]
  category "key_item"
}

item star_chart_south {
  name "Southern Star Chart"
  description "A detailed astronomical chart rendered on stiff parchment."
  examine "A detailed astronomical chart rendered on stiff parchment, showing the southern sky as visible from the Hogwarts Astronomy Tower. Constellations are labeled in Latin and cross-referenced with dates. One constellation is circled in fresh ink — a pattern of stars that, when traced, forms the shape of a key. A notation beside it reads: 'The sky remembers what the Founders hid. Align south to find the eagle's answer.'"
  room_id library
  room_description "A star chart is pinned to a reading stand, its constellations labeled in Latin."
  is_takeable true
  is_visible true
  tags ["lore"]
  category "key_item"
}

item wrench {
  name "Hagrid's Wrench"
  description "A heavy iron wrench, old but well-maintained."
  examine "A heavy iron wrench, old but well-maintained, its jaws adjustable via a worn brass wheel. Grease stains darken the handle. This is a tool for mechanical work — gears, bolts, clock mechanisms — not magic. Someone left it here deliberately, as if knowing that not every problem in a magical castle has a magical solution."
  room_id hagrid_hut
  room_description "A heavy iron wrench sits on Hagrid's workbench."
  is_takeable false
  is_visible true
  tags ["tool"]
  category "tool"
}

item small_shovel {
  name "Small Shovel"
  description "A compact folding shovel with a wooden handle worn smooth from use."
  examine "A compact folding shovel with a wooden handle worn smooth from use. The blade is tarnished but sharp, good for digging in soft earth or mud. It collapses to fit in a robe pocket. Simple, Muggle, practical — the kind of tool Hagrid would appreciate and Malfoy would sneer at. Sometimes the best way to find something buried is the obvious way."
  room_id greenhouse
  room_description "A small folding shovel leans against a potting bench."
  is_takeable true
  is_visible true
  tags ["tool"]
  category "tool"
}

item warming_charm_token {
  name "Warming Charm Token"
  description "A small brass disc inscribed with a warming charm, radiating gentle heat."
  examine "A small brass disc inscribed with the runic formula for a concentrated warming charm. It radiates a gentle heat that intensifies when gripped tightly. Professor Flitwick's handiwork — precise, elegant, and significantly more powerful than it looks. When pressed against enchanted ice, the charm activates and the ice yields."
  room_id corridor_east
  room_description "A small brass disc radiating warmth sits where Flitwick left it."
  is_takeable true
  is_visible false
  tags ["key"]
  category "key_item"
}

item gryffindor_crest {
  name "Gryffindor Crest"
  description "A stone crest bearing the rampant lion of Gryffindor."
  examine "A carved stone crest bearing the rampant lion of Gryffindor in deep red enamel. The back is worn smooth from handling, and the stone radiates faint warmth. Ron pressed it into your hands with the quiet solemnity of someone entrusting you with something that matters more than either of you will admit. It fits perfectly in the pedestal's circular depression."
  room_id guardian_hall
  room_description "A stone crest bearing the Gryffindor lion lies here."
  is_takeable true
  is_visible false
  tags ["key"]
  category "key_item"
}

# ───────────────────────────────────────────
#   POTION INGREDIENTS
# ───────────────────────────────────────────

item revealer_recipe {
  name "Revealer Potion Recipe"
  description "A page torn from an advanced potions textbook, its edges singed."
  examine "A page torn from an advanced potions textbook, its edges singed. The recipe describes a 'Revealer Potion' capable of exposing hidden magical mechanisms and concealed doorways. The ingredients are listed in Snape's cramped handwriting: moonpetal (found in moonlight), ashwinder egg (stored with volatile ingredients), and a base of standard healing potion. A note in the margin reads: 'Brew in any cauldron. The potion knows what it wants.'"
  room_id restricted_section
  room_description "A singed recipe page lies on the reading table."
  is_takeable true
  is_visible true
  tags ["lore"]
  category "lore"
}

item moonpetal {
  name "Moonpetal"
  description "A single silver-white petal, delicate as tissue paper, faintly luminous."
  examine "A single silver-white petal, delicate as tissue paper, faintly luminous. It feels cool and dry, and when you tilt it, it catches light that isn't there — reflecting moonbeams from some other sky. The petal came from a flower that blooms only in enchanted moonlight. It smells of night air and distant gardens. An essential ingredient for the Revealer Potion."
  room_id greenhouse
  room_description "A faintly luminous silver-white petal grows from a moonlit planter."
  is_takeable true
  is_visible true
  tags ["ingredient"]
  category "ingredient"
}

item ashwinder_egg {
  name "Ashwinder Egg"
  description "A small egg, warm to the touch, its shell a dull, sullen red."
  examine "A small egg, warm to the touch, its shell a dull, sullen red that pulses like a dying ember. It is surprisingly heavy for its size. If left unattended, it will eventually ignite whatever surface it rests on — you can feel the heat building slowly in your palm. Handle with care. An essential ingredient for the Revealer Potion."
  in ingredient_cabinet
  room_description "A small red egg pulses with warmth inside the cabinet."
  is_takeable true
  is_visible true
  tags ["ingredient"]
  category "ingredient"
}

# ───────────────────────────────────────────
#   POTIONS (consumables)
# ───────────────────────────────────────────

item revealer_potion {
  name "Revealer Potion"
  description "A small vial of iridescent liquid that shifts between silver and transparent."
  examine "A small vial of iridescent liquid that shifts between silver and transparent, like bottled moonlight. When you hold it near a wall, the surface of the potion tilts toward hidden mechanisms the way water leans downhill — it wants to reveal, to expose, to make the invisible obvious. The cork is sealed with wax. One use. Make it count."
  room_id great_hall
  room_description "A vial of iridescent liquid sits here."
  is_takeable true
  is_visible false
  is_consumed_on_use true
  tags ["potion"]
  category "consumable"
}

item healing_potion {
  name "Healing Potion"
  description "A stoppered vial of thick, pearlescent liquid that glows faintly pink."
  examine "A stoppered vial of thick, pearlescent liquid that glows faintly pink. It smells of clean linen and something herbal — dittany, perhaps, or valerian. When swirled, the liquid moves too slowly, as if reluctant to be disturbed. Standard healing potion, effective on cuts, burns, and magical wounds. The label reads 'Madame Pomfrey's Reserve' in a careful hand."
  room_id hospital_wing
  room_description "Three vials of pearlescent healing potion stand in a neat row on the medicine cabinet shelf."
  is_takeable true
  is_visible true
  quantity 3
  max_quantity 3
  quantity_unit "vials"
  tags ["potion"]
  category "consumable"
}

item flame_freezing_potion {
  name "Flame-Freezing Potion"
  description "A flask of pale blue liquid, ice-cold even through the glass."
  examine "A flask of pale blue liquid, ice-cold even through the glass. Frost crystals form and dissolve on its surface in a slow, hypnotic cycle. When consumed, it renders the drinker immune to magical fire for a short duration — flames will wash over you like a warm breeze. The potion tastes, according to the label's warning, 'like a winter morning, followed by regret.' Useful wherever fire stands between you and progress."
  in ingredient_cabinet
  room_description "A flask of icy blue liquid sits beside the ashwinder egg."
  is_takeable true
  is_visible true
  is_consumed_on_use true
  tags ["potion"]
  category "consumable"
}

# ───────────────────────────────────────────
#   FOUNDER TOKENS (trial vaults)
# ───────────────────────────────────────────

item gryffindor_token {
  name "Gryffindor's Token"
  description "A heavy disc of ruby-veined gold bearing the rampant lion."
  examine "A heavy disc of ruby-veined gold, warm in your hand, bearing the rampant lion of Gryffindor on one face. The reverse is inscribed with a single word: 'Courage.' When you hold it, you feel a faint surge of warmth in your chest — not heat, but resolve, as if the token is lending you a fraction of the bravery it represents. One of four keys to the Convergence Antechamber."
  room_id gryffindor_vault
  room_description "The Gryffindor token rests on the stone pedestal, glowing with ruby-gold light."
  is_takeable true
  is_visible true
  tags ["founder_artifact"]
  category "quest_item"
}

item ravenclaw_token {
  name "Ravenclaw's Token"
  description "A disc of sapphire-streaked bronze bearing the eagle of Ravenclaw."
  examine "A disc of sapphire-streaked bronze, cool and precise in your hand, bearing the eagle of Ravenclaw etched with mathematical exactness. The reverse reads: 'Wisdom.' Holding it, your thoughts sharpen — connections form faster, patterns emerge from noise, and for a moment, the world feels like a puzzle you could actually solve. One of four keys to the Convergence Antechamber."
  room_id ravenclaw_vault
  room_description "The Ravenclaw token rests on the crystalline pedestal, refracting blue-white light."
  is_takeable true
  is_visible true
  tags ["founder_artifact"]
  category "quest_item"
}

item hufflepuff_token {
  name "Hufflepuff's Token"
  description "A disc of topaz-flecked onyx bearing the badger of Hufflepuff."
  examine "A disc of topaz-flecked onyx, warm as sun-baked earth, bearing the badger of Hufflepuff in patient, detailed relief. The reverse reads: 'Loyalty.' It sits in your hand with a comfortable weight, grounding you, and you feel a quiet certainty settle in your stomach — not confidence, but constancy, the assurance that you will not abandon what matters. One of four keys to the Convergence Antechamber."
  room_id hufflepuff_vault
  room_description "The Hufflepuff token rests on the pedestal, radiating golden warmth."
  is_takeable true
  is_visible true
  tags ["founder_artifact"]
  category "quest_item"
}

item slytherin_token {
  name "Slytherin's Token"
  description "A disc of emerald-veined silver bearing the coiled serpent of Slytherin."
  examine "A disc of emerald-veined silver, cold and heavy, bearing the coiled serpent of Slytherin rendered in unsettling detail — each scale distinct, each curve deliberate. The reverse reads: 'Ambition.' When you hold it, the world narrows to essentials: what you want, what stands in your way, and the shortest path between the two. The clarity is seductive. One of four keys to the Convergence Antechamber."
  room_id slytherin_vault
  room_description "The Slytherin token rests beneath the rotating spectral locket, cold and watchful."
  is_takeable true
  is_visible true
  tags ["founder_artifact"]
  category "quest_item"
}

# ───────────────────────────────────────────
#   HUFFLEPUFF TRIAL ITEMS
# ───────────────────────────────────────────

item golden_locket {
  name "Golden Locket"
  description "A small golden locket on a fine chain, engraved with a badger and vines."
  examine "A small golden locket on a fine chain, its surface engraved with a badger surrounded by intertwined vines. It opens to reveal two tiny compartments — both empty, but the interior surfaces are inscribed with microscopic text: 'Freely given, gladly received.' The locket pulses with a faint warmth, as if it remembers being held by someone who loved it. It feels like it wants to be given away, not kept."
  room_id loyalty_passage
  room_description "Something golden glints among the roots on the tunnel floor — a small locket on a fine chain."
  is_takeable true
  is_visible true
  tags ["quest_item"]
  category "key_item"
}

item hufflepuff_charm {
  name "Hufflepuff's Charm"
  description "A small, polished stone carved in the shape of a wheat sheaf on a leather cord."
  examine "A small, polished stone carved in the shape of a wheat sheaf, threaded on a leather cord. It radiates a gentle warmth and smells faintly of fresh bread. When held near the garden of patience, it vibrates softly — resonating with the growing magic there. Inscribed on the back: 'Growth cannot be rushed, only tended.'"
  room_id wounded_stranger
  room_description "A small stone charm lies beside the spectral figure."
  is_takeable true
  is_visible false
  tags ["quest_item"]
  category "key_item"
}

# ───────────────────────────────────────────
#   SLYTHERIN TRIAL ITEMS
# ───────────────────────────────────────────

item serpent_key {
  name "Serpent Key"
  description "A key carved from a single piece of dark jade, shaped like a striking serpent."
  examine "A key carved from a single piece of dark jade, shaped like a striking serpent — the blade forms the body, the bow forms the coiled tail. It is cold and smooth and fits in your hand with unsettling precision, as if it was made for your grip specifically. When brought near serpent carvings, the key vibrates and the carved snakes seem to lean toward it. Opens the serpent door in the Slytherin antechamber."
  in iron_chest
  room_description "A jade serpent key rests inside the chest."
  is_takeable true
  is_visible true
  tags ["key"]
  category "key_item"
}

# ───────────────────────────────────────────
#   LORE ITEMS
# ───────────────────────────────────────────

item founders_journal_page_1 {
  name "Founder's Journal (Page 1)"
  description "A page of ancient parchment covered in four different handwriting styles."
  examine "A page of ancient parchment, brittle at the edges, covered in a collaborative hand — four different scripts, four different inks, woven together like a conversation frozen in time. This first page describes the discovery: something beneath the bedrock where Hogwarts would be built, a convergence of magical ley lines crystallized into stone. 'We did not choose this site,' writes one hand. 'The stone chose us.' Another annotates: 'M. insists it can be harnessed. I am not convinced harnessing is the same as controlling.'"
  room_id clock_tower_base
  room_description "A page of ancient parchment is wedged between two frozen gears."
  is_takeable true
  is_visible false
  tags ["lore"]
  category "lore"
}

item founders_journal_page_2 {
  name "Founder's Journal (Page 2)"
  description "The second journal page — the handwriting of all four contributors has grown hurried."
  examine "The second journal page is more agitated — the handwriting of all four contributors has grown hurried, the ink pressed deeper. The text describes experiments with the Convergence Stone, attempts to channel its power into the castle's defenses. 'M. grows impatient with our caution,' notes one writer. 'He speaks of unity as if it were a tool rather than a principle.' A diagram in the margin shows the four ward stones arranged around the Convergence Stone — the same configuration you've seen below. Beneath it: 'If the wards fail, the stone consumes.'"
  room_id restricted_section
  room_description "An agitated page of ancient parchment lies on the reading table, its ink pressed deep."
  is_takeable true
  is_visible true
  tags ["lore"]
  category "lore"
}

item founders_journal_page_3 {
  name "Founder's Journal (Page 3)"
  description "The final page — written in a single hand, patient and rounded."
  examine "The final page is written in a single hand — Helga Hufflepuff's, judging by the patient, rounded script. The others have stopped contributing. 'Malachar is sealed below. The wards hold, but they are not eternal. Should they falter, know this: the Stone cannot be destroyed. It can only be stabilized. Not by power, not by cunning, not by knowledge, not by courage alone — but by all four in concert. The tokens are the key. Unity is the lock. We were four, and that is what saved us. Remember.'"
  room_id malachar_gallery
  room_description "A final journal page lies beneath the mural of the Founders' last stand."
  is_takeable true
  is_visible true
  tags ["lore"]
  category "lore"
}

item malachar_journal {
  name "Malachar's Journal"
  description "A small, leather-bound journal, its cover cracked and stained with something dark."
  examine "A small, leather-bound journal, its cover cracked and stained with something dark. The handwriting inside is elegant but increasingly erratic. Malachar writes of the Convergence Stone with reverence bordering on obsession: 'The Founders see a foundation. I see a source. They wish to build upon it. I wish to become it.' Later entries devolve into diagrams, calculations, and a growing paranoia: 'They conspire against me because they fear what I understand. The Stone does not want four stewards. It wants one voice.' The final entry is a single line: 'They will seal me, but the Stone remembers.'"
  room_id malachar_gallery
  room_description "A cracked leather journal lies beneath the final mural panel, stained with something dark."
  is_takeable true
  is_visible true
  tags ["lore"]
  category "lore"
}

item rusted_amulet {
  name "Rusted Amulet"
  description "A corroded amulet dug from the mud, its original shape barely discernible."
  examine "A corroded amulet dug from the mud of the lake shore, its original shape barely discernible beneath centuries of rust and silt. You can make out the faint outline of a symbol — neither any of the four house crests nor the Hogwarts seal, but something older: a five-pointed convergence, five lines meeting at a central point. Malachar's mark. The amulet is inert now — whatever power it held has long since bled into the earth. But it confirms the history: there was a fifth."
  room_id lake_shore
  room_description "Something corroded and metallic protrudes from the mud at the water's edge."
  is_takeable true
  is_visible false
  tags ["lore"]
  category "lore"
}

# ───────────────────────────────────────────
#   TRADE AND UTILITY ITEMS
# ───────────────────────────────────────────

item galleons {
  name "Galleons"
  description "A small pouch of heavy gold coins stamped with a goblin mint seal."
  examine "A small pouch of Galleons — heavy gold coins stamped with a goblin mint seal. They clink with the satisfying weight of genuine wizarding currency. Useful for trading with anyone who values gold over favors, which in the current crisis, is fewer people than you'd expect."
  room_id great_hall
  room_description "A pouch of gold Galleons lies here."
  is_takeable true
  is_visible true
  quantity 10
  max_quantity 10
  quantity_unit "coins"
  tags ["currency"]
  category "currency"
}

item magical_candy {
  name "Magical Candy"
  description "An assortment of wizarding sweets — Chocolate Frogs, Bertie Bott's Beans, and Pepper Imps."
  examine "An assortment of wizarding sweets: Chocolate Frogs (cards included), Bertie Bott's Every Flavour Beans (every flavour means every flavour), and a couple of Pepper Imps that smoke at the ears. Comforting, familiar, and surprisingly effective at convincing reluctant allies that you come in peace. Everyone trusts someone who shares their sweets."
  room_id corridor_west
  room_description "A small bag of wizarding sweets sits where Fred and George left it."
  is_takeable true
  is_visible false
  quantity 3
  max_quantity 3
  quantity_unit "pieces"
  is_consumed_on_use true
  tags ["food"]
  category "consumable"
}

item peruvian_darkness_powder {
  name "Peruvian Darkness Powder"
  description "A small cloth pouch filled with fine, glittering black powder."
  examine "A small cloth pouch filled with fine, glittering black powder that seems to absorb light even through the fabric. Peruvian Instant Darkness Powder — when thrown, it creates a patch of absolute, impenetrable darkness that no spell can illuminate. Fred and George's stock. Useful for escaping situations where visibility is your enemy's advantage, or for creating distractions in areas you'd rather not be seen."
  room_id corridor_west
  room_description "A small pouch of glittering black powder sits beside the candy."
  is_takeable true
  is_visible false
  is_consumed_on_use true
  tags ["stealth"]
  category "consumable"
}

# ───────────────────────────────────────────
#   SCENERY / NON-TAKEABLE ITEMS
# ───────────────────────────────────────────

item logic_poem {
  name "The Logic Verse"
  description "A roll of singed parchment describing a logic puzzle of reason, not magic."
  examine "The parchment reads in an elegant, clinical hand:

'Danger lies before you, while safety lies behind,
Two of us will help you, whichever you would find,
One among us seven will let you move ahead,
Another will transport the drinker back instead,
Two among our number hold only nettle wine,
Three of us are killers, waiting biding in line.
Choose, unless you wish to stay here forevermore,
To help you in your choice, we give you these clues four:
First, however slyly the poison tries to hide
You will always find some on nettle wine's left side;
Second, different are those who stand at either end,
But if you would move onward, neither is your friend;
Third, as you see clearly, all are different size,
Neither dwarf nor giant holds death in their insides;
Fourth, the second left and the second on the right
Are twins once you taste them, though different at first sight.'"
  room_id logic_chamber
  room_description "A roll of singed parchment lies before the seven bottles, its logic verse waiting to be solved."
  is_takeable false
  is_visible true
  tags ["scenery"]
  category "scenery"
}

item clock_mechanism {
  name "Clock Mechanism"
  description "The massive frozen clock mechanism — a cathedral of brass gears and iron pendulums."
  examine "A towering assembly of interlocking brass gears, iron pendulums, and crystal escapements, all frozen mid-motion. One gear is visibly jammed — a tooth bent inward, preventing rotation. A wrench could straighten it. The mechanism groans occasionally, straining against whatever has locked it in place, as if the clock desperately wants to resume counting time."
  room_id clock_tower_base
  room_description "The massive clock mechanism looms overhead, its gears frozen and silent."
  is_takeable false
  is_visible true
  toggle true
  toggle_default "jammed"
  on_msg "The wrench grips the bent tooth. You heave — metal screeches, gives, and the gear straightens with a satisfying clang. The mechanism shudders to life, pendulums swinging, gears meshing, the great clock resuming its ancient count. Something dislodges from between two gears and clatters to the floor — a page of ancient parchment."
  off_msg "The mechanism is already running smoothly."
  tags ["scenery"]
  category "scenery"
}

# ───────────────────────────────────────────
#   WARD STONES (toggleable, ward_chamber)
# ───────────────────────────────────────────

item ward_stone_red {
  name "Red Ward Stone"
  description "A rough-hewn monolith pulsing with fading ruby light."
  examine "A ward stone taller than a person, its surface carved with Gryffindor symbols and pulsing with a fading ruby light. Black veins crawl across its surface, thicker toward the base, creeping upward like a disease. Each pulse is weaker than the last. It represents Godric Gryffindor's contribution to the binding — courage made manifest in stone. It needs to be reactivated in the correct sequence to restore the wards."
  room_id ward_chamber
  room_description "The red ward stone pulses with fading ruby light at the northern point of the circle."
  is_takeable false
  is_visible true
  toggle true
  toggle_default "inactive"
  on_msg "You press your wand to the red stone. Ruby light flares through the black veins, burning them back, and the stone's pulse strengthens — steady, strong, the heartbeat of courage restored."
  off_msg "The red stone's light fades to a weak pulse."
  tags ["ward"]
  category "scenery"
}

item ward_stone_blue {
  name "Blue Ward Stone"
  description "A rough-hewn monolith pulsing with fading sapphire light."
  examine "A ward stone inscribed with Ravenclaw eagles and mathematical formulae, pulsing with a fading sapphire light. The black veins are thicker here, nearly reaching the top, and the stone's surface is cold to the touch — not the cold of stone, but the cold of something dying. It represents Rowena Ravenclaw's wisdom, crystallized into the ward network. Reactivation requires the correct sequence."
  room_id ward_chamber
  room_description "The blue ward stone pulses with fading sapphire light at the eastern point."
  is_takeable false
  is_visible true
  toggle true
  toggle_default "inactive"
  on_msg "You press your wand to the blue stone. Sapphire light surges through the carvings, eagles taking flight in luminous relief, and the stone's pulse steadies — sharp, precise, the clarity of wisdom renewed."
  off_msg "The blue stone's light fades to a distant glimmer."
  tags ["ward"]
  category "scenery"
}

item ward_stone_yellow {
  name "Yellow Ward Stone"
  description "A rough-hewn monolith pulsing with fading topaz light."
  examine "A ward stone carved with Hufflepuff badgers and wheat sheaves, pulsing with a fading topaz light. The black veins have nearly consumed the lower half, but the upper carvings remain warm to the touch — stubbornly alive, refusing to fade entirely. It represents Helga Hufflepuff's loyalty, the binding force that holds the other three together. Reactivation requires the correct sequence."
  room_id ward_chamber
  room_description "The yellow ward stone pulses with fading topaz light at the southern point."
  is_takeable false
  is_visible true
  toggle true
  toggle_default "inactive"
  on_msg "You press your wand to the yellow stone. Golden light blooms outward like sunrise, warming the chamber, and the stone's pulse deepens — steady, enduring, the constancy of loyalty rekindled."
  off_msg "The yellow stone's light retreats to a flickering warmth."
  tags ["ward"]
  category "scenery"
}

item ward_stone_green {
  name "Green Ward Stone"
  description "A rough-hewn monolith pulsing with fading emerald light."
  examine "A ward stone coiled with carved serpents and alchemical symbols, pulsing with a fading emerald light. The black veins are thickest here — Malachar's corruption striking hardest at the tradition closest to his own. The stone is cold, calculating, and the light it emits has a quality of assessment, as if it is deciding whether you are worthy. It represents Salazar Slytherin's ambition — the drive that gives the wards their edge. Reactivation requires the correct sequence."
  room_id ward_chamber
  room_description "The green ward stone pulses with fading emerald light at the western point."
  is_takeable false
  is_visible true
  toggle true
  toggle_default "inactive"
  on_msg "You press your wand to the green stone. Emerald light coils through the serpent carvings like living venom, and the stone's pulse sharpens — calculating, driven, the ambition of Slytherin unsheathed."
  off_msg "The green stone's light dims to a reptilian flicker."
  tags ["ward"]
  category "scenery"
}

# ───────────────────────────────────────────
#   CONTAINERS
# ───────────────────────────────────────────

item trophy_case {
  name "Trophy Case"
  description "A large glass display case at the center of the trophy room, locked with a heavy brass mechanism."
  examine "A large glass display case with polished brass fittings, locked with a mechanism that responds to authority — the kind of lock designed to open for prefects and staff, not for students with wands and ambition. Inside, you can see a velvet cushion bearing two objects: a fragment of old parchment and a heavy silver ring set with an emerald. The glass is enchanted — unbreakable by force."
  room_id trophy_room
  room_description "A locked glass display case stands at the center of the room, its contents gleaming under enchanted spotlights."
  is_takeable false
  is_visible true
  container true
  has_lid true
  locked true
  key prefect_badge
  unlock_msg "The prefect badge clicks against the brass lock and the case swings open with a soft chime. Authority acknowledged."
  open_msg "The velvet cushion inside holds a parchment map and a silver ring."
}

item ingredient_cabinet {
  name "Ingredient Cabinet"
  description "A heavy wooden cabinet beside Snape's desk, its doors slightly ajar."
  examine "A cabinet of dark wood with iron hinges, standing beside Snape's desk. The interior smells of sulfur, peppermint, and something volatile. Shelves of jars contain ingredients in various states of preservation — some pickled, some dried, some actively squirming. The cabinet is unlocked, either because Snape trusts the fear he inspires more than any lock, or because he wants to see who is foolish enough to touch his supplies."
  room_id potions_classroom
  room_description "Snape's ingredient cabinet stands beside the teacher's desk, its doors slightly ajar."
  is_takeable false
  is_visible true
  container true
  has_lid true
  locked false
  open_msg "The cabinet doors swing open, releasing a wave of competing chemical smells."
}

item cold_stores {
  name "Enchanted Cold Stores"
  description "A heavy iron door at the back of the kitchens, sealed with enchanted chains of ice."
  examine "The cold stores are sealed behind a heavy iron door wrapped in chains of actual ice — not conjured, not natural, but something older. The ice burns to touch and screams faintly when disturbed, a high-pitched keen just at the edge of hearing. Whatever locked this door did so with magic that predates the house-elves. A concentrated warming charm might break the seal."
  room_id kitchens
  room_description "Enchanted chains of ice seal the cold stores at the back of the kitchens."
  is_takeable false
  is_visible true
  container true
  has_lid true
  locked true
  key warming_charm_token
  consume_key true
  unlock_msg "The warming charm token flares in your hand, melting the enchanted ice with a hiss of steam. The chains shatter and fall away, and the iron door swings open, releasing a wave of cold but perfectly preserved air."
  open_msg "The cold stores are stocked with butter, cream, preserved meats, and enough ingredients to feed the school for a week."
}

item iron_chest {
  name "Iron Chest"
  description "A plain, dented iron chest sitting apart from the others."
  examine "The iron chest is plain, dented, and unremarkable. Its hinges are rusted but functional, and it carries no ornamentation, no enchantment you can detect. It sits slightly apart from the others, as if placed as an afterthought — or as if the other chests were placed to draw attention away from it. Slytherin valued cunning. The obvious choice is rarely the right one. Sometimes the least impressive vessel holds the most important contents."
  room_id deception_room
  room_description "A plain iron chest sits slightly apart from the others, dented and unassuming."
  is_takeable false
  is_visible true
  container true
  has_lid true
  locked false
  open_msg "The lid lifts with a rusty groan. Inside, resting on faded velvet, is a key carved from dark jade."
}

item silver_chest {
  name "Silver Chest"
  description "A silver chest polished to a mirror shine, dazzling under the green torchlight."
  examine "The silver chest gleams with a polished perfection that seems almost aggressive, reflecting the green torchlight in dazzling patterns across the walls. It is beautiful, ornate, and draws the eye immediately. But beauty in a Slytherin trial is a warning sign, not an invitation. The silver surface is flawless — too flawless, as if the chest exists to be looked at rather than opened. A faint inscription along the base reads: 'Admire, but do not trust.'"
  room_id deception_room
  room_description "A dazzling silver chest gleams under the green torchlight, demanding attention."
  is_takeable false
  is_visible true
  container true
  has_lid true
  locked false
  open_msg "The silver chest springs open — and a blast of freezing air strikes you full in the face. The chest is empty. It was always empty. The cold bites into your skin like a rebuke."
}

item gold_chest {
  name "Gold Chest"
  description "A magnificent gold chest encrusted with gemstones, practically demanding to be opened."
  examine "The gold chest is magnificent — encrusted with emeralds, its lid carved with a serpent motif so detailed the scales catch individual motes of light. It practically demands to be opened. Every surface screams 'treasure.' And that is precisely what makes it suspicious. In a trial designed by Salazar Slytherin — a man who valued subtlety above all — the chest that shouts the loudest is almost certainly the one designed to punish greed. The serpent's carved eye seems to wink."
  room_id deception_room
  room_description "A magnificent gold chest encrusted with emeralds sits at the triangle's apex, practically begging to be opened."
  is_takeable false
  is_visible true
  container true
  has_lid true
  locked false
  open_msg "The gold lid opens with theatrical grandeur — and a serpent of green flame erupts from within, striking you before dissolving into mocking laughter. The chest contains nothing but a note: 'Greed is the most predictable weakness.'"
}

item token_alcove {
  name "Token Alcove"
  description "Four alcoves carved into the black stone walls, each bearing a house crest above a circular depression."
  examine "Four alcoves carved at equal intervals into the polished black walls, each bearing the crest of a Hogwarts house above a circular depression perfectly sized for a Founder's token. Three of the four alcoves are dark. The fourth pulses weakly, as if remembering what it was meant to hold. Place all four tokens to open the sealed door to the south."
  room_id convergence_antechamber
  room_description "Four alcoves bearing house crests wait in the polished black walls, their circular depressions empty."
  is_takeable false
  is_visible true
  container true
  has_lid false
  locked false
  open_msg "The alcoves accept the tokens with a resonant hum."
}

item offering_stone {
  name "Offering Stone"
  description "A flat ledge of polished obsidian with a circular depression, jutting from the wall."
  examine "A flat ledge of polished obsidian jutting from the wall at the base of the staircase, its surface polished to a dark mirror. A circular depression is carved into its center, sized to hold something specific — not a token, but a sacrifice. An offering of something the player values. The serpent carvings around it are denser here, more agitated, their coils suggesting that what you give up determines what you gain. Slytherin's trial demands you choose what matters less to you — and hope you chose correctly."
  room_id ambition_stair
  room_description "An offering stone of polished obsidian juts from the wall, its circular depression waiting for a sacrifice."
  is_takeable false
  is_visible true
  container true
  has_lid false
  locked false
  open_msg "You place your offering on the obsidian surface. The stone hums, the serpent carvings writhe, and the staircase above begins to glow with green light — ascending further than before."
}
# ═══════════════════════════════════════════
#   NPCs — Harry Potter and the Founders' Convergence
#   21 NPCs total: characters, ghosts, trial figures
# ═══════════════════════════════════════════

# ───────────────────────────────────────────
#   HOGWARTS COMMONS — Core Characters
# ───────────────────────────────────────────

# ============================================================
# McGONAGALL — great_hall
# Pre-quest: concern about the castle, points player to Dumbledore
# Post-quest: encouragement and guidance
# ============================================================

npc mcgonagall {
  name "Professor McGonagall"
  description "Professor McGonagall stands at the head table with the rigid composure of someone holding a crisis together through sheer force of will. Her emerald robes are immaculate, but her eyes are shadowed with exhaustion."
  examine "Minerva McGonagall, Deputy Headmistress and Head of Gryffindor House. Her wand is in her hand — not drawn, but present, the way a soldier keeps a weapon close without admitting they expect to use it. Every line of her posture says control, discipline, and the specific kind of fear that manifests as utter calm. She has been standing here for hours. Possibly days."
  room_id great_hall
  dialogue "Professor McGonagall regards you with sharp, exhausted eyes."
  category "character"

  talk mcgonagall_greeting {
    "Potter. I trust you haven't been wandering unsupervised. The castle is... not itself tonight."
    option "What's happening, Professor?" -> mcgonagall_concern
    option "I need to see Dumbledore." -> mcgonagall_dumbledore
    option "I can handle myself." -> mcgonagall_dismissive
  }

  talk mcgonagall_concern {
    "The wards are failing. Doors that have been sealed for centuries are opening on their own. Staircases are refusing to move — or moving too much. I have never seen anything like it in all my years here."
    option "Do you know what's causing it?" -> mcgonagall_cause
    option "How can I help?" -> mcgonagall_help
    option "I need to see Dumbledore." -> mcgonagall_dumbledore
  }

  talk mcgonagall_cause {
    "The Headmaster believes it is connected to something ancient. Something buried in the foundations of this school long before any of us arrived. You should speak with him directly."
    option "Where is Dumbledore?" -> mcgonagall_dumbledore
    option "Thank you, Professor." -> mcgonagall_farewell
  }

  talk mcgonagall_help {
    "You can help by being careful, Potter. This is not a matter of courage. It is a matter of not getting yourself killed before you can be useful."
    option "I need to see Dumbledore." -> mcgonagall_dumbledore
    option "I'll be careful." -> mcgonagall_farewell
  }

  talk mcgonagall_dismissive {
    "That is precisely the attitude that fills beds in the hospital wing. Listen to me. Whatever bravado carried you through previous years will not be sufficient tonight."
    option "You're right. What should I do?" -> mcgonagall_help
    option "Where's Dumbledore?" -> mcgonagall_dumbledore
  }

  talk mcgonagall_dumbledore {
    "The Headmaster is in his office. The gargoyle on the second floor corridor — you know the one."
    option "What's the password?" -> mcgonagall_password
    option "I know the way. Thank you." -> mcgonagall_farewell
  }

  talk mcgonagall_password {
    "Sherbet Lemon. The man's sweet tooth will be the death of his security. Do not repeat that to anyone, Potter."
    sets [knows_gargoyle_password]
    option "Thank you, Professor." -> mcgonagall_farewell
  }

  talk mcgonagall_farewell {
    "Go. And Potter — keep your wand ready."
  }

  # --- Post-quest dialogue (after has_main_quest) ---

  talk mcgonagall_postquest {
    "You've spoken with the Headmaster, then. I can see it in your face. The weight of it."
    option "He's asking a lot." -> mcgonagall_encourage
    option "I'll manage." -> mcgonagall_encourage_brief
    option "Do you know about Malachar?" -> mcgonagall_malachar
  }

  talk mcgonagall_encourage {
    "He asks because he trusts you. That is not a small thing. Albus Dumbledore does not place trust carelessly."
    option "What if I'm not enough?" -> mcgonagall_enough
    option "Thank you, Professor." -> mcgonagall_postquest_farewell
  }

  talk mcgonagall_encourage_brief {
    "I have no doubt. But managing and succeeding are different creatures. Do not confuse stubbornness for strategy."
    option "I won't." -> mcgonagall_postquest_farewell
  }

  talk mcgonagall_malachar {
    "I know what the staff has been told. An ancient threat. A wizard who tried to bind the Founders' magic into a single artifact. Beyond that, the Headmaster has kept his own counsel."
    option "He seems worried." -> mcgonagall_enough
    option "Thank you." -> mcgonagall_postquest_farewell
  }

  talk mcgonagall_enough {
    "You are not doing this alone. Remember that. The castle itself is on your side, Potter — even when it doesn't look like it."
    option "That's... actually reassuring." -> mcgonagall_postquest_farewell
    option "I hope you're right." -> mcgonagall_postquest_farewell
  }

  talk mcgonagall_postquest_farewell {
    "Now stop dawdling. You have trials to face, and they will not wait for sentimentality."
  }
}

# ============================================================
# RON — great_hall
# Banter, loyalty, prefect_badge handoff, trial warnings.
# Voice: informal, self-deprecating humor, fierce loyalty under it.
# ============================================================

npc ron {
  name "Ron Weasley"
  description "Ron Weasley sits at the Gryffindor table, pale and fidgeting, one hand absently gripping his wand. He looks up as you approach with an expression that is equal parts relief and anxiety."
  examine "Ron looks like he has not slept properly in days. There are dark circles under his eyes, his robes are rumpled, and his prefect badge is pinned on crooked — a detail Hermione would notice and he would not. But his wand hand is steady and his jaw is set. Whatever is coming, he is not going to run from it. He never has."
  room_id great_hall
  dialogue "Ron fidgets at the Gryffindor table, watching the enchanted ceiling with wary eyes."
  category "character"

  talk ron_greeting {
    "Mate! There you are. I've been sitting here for ages. The pudding's gone cold and the ceiling's doing this weird flickering thing — I keep thinking it's going to rain inside. Again."
    option "Something's wrong with the castle, Ron." -> ron_castle
    option "Have you seen Dumbledore?" -> ron_dumbledore_question
    option "Any chance you saved me some pudding?" -> ron_pudding
  }

  talk ron_pudding {
    "See, this is why we're friends. Priorities. Yeah, I saved you a bit. Well — I saved you what's left after I saved me a bit. Which is... a bit less than a bit."
    option "Classic Ron." -> ron_castle
    option "I need to talk to you about something serious." -> ron_castle
  }

  talk ron_castle {
    "Yeah, I noticed. Peeves has been dead quiet, which is properly terrifying when you think about it. And the suits of armor on the third floor are facing the wrong direction. All of them. Like they're watching something we can't see."
    option "Dumbledore told me what's going on." -> ron_briefing
    option "I need your help." -> ron_help_request
  }

  talk ron_dumbledore_question {
    "He's in his office, I think. Hasn't been at meals in days. McGonagall's been covering for him, but she's rubbish at hiding that she's worried."
    option "I need to get up there." -> ron_farewell_early
    option "Something's wrong with the castle." -> ron_castle
  }

  talk ron_farewell_early {
    "Go, go. I'll be here. Not like I've got anywhere else to be — they've cancelled Quidditch practice on account of the pitch trying to eat the goalposts."
  }

  # --- Post-quest dialogue ---

  talk ron_briefing {
    "He told you WHAT? Convergence Stone? Four trials? Ancient curse? Blimey, Harry, we can't just have one normal year, can we? Just one. Exams and Quidditch and maybe a nice holiday."
    option "Will you help me?" -> ron_help_request
    option "You don't have to be involved." -> ron_opt_out
  }

  talk ron_opt_out {
    "Oh, shut up. 'You don't have to be involved.' When have I ever not been involved? When has that ever been a thing that happened? I'm in, you prat. Obviously I'm in."
    option "Thanks, Ron." -> ron_help_request
  }

  talk ron_help_request {
    "Right, well, I'm not much use at ancient curses, but I know the castle better than most. Six older brothers, remember? Fred and George alone showed me about forty secret passages. What do you need?"
    option "Have you got your prefect badge?" -> ron_badge
    option "What do you know about the trials?" -> ron_trials_warning
    option "Just watch my back." -> ron_watch_back
  }

  talk ron_badge {
    "My — yeah, actually. Been carrying it around. Bit embarrassing, really. Mum was so proud she had it polished and everything. Why?"
    option "I might need it. Can I borrow it?" -> ron_badge_give
    option "Never mind. What about the trials?" -> ron_trials_warning
  }

  talk ron_badge_give {
    "Take it. Honestly, you'd be doing me a favor. Percy keeps sending owls asking if I'm 'upholding the dignity of the position.' The dignity, Harry. Of a badge. That I got because everyone else said no."
    # Item given: prefect_badge
    option "You were the right choice, Ron." -> ron_badge_touched
    option "Thanks. Now, about the trials—" -> ron_trials_warning
  }

  talk ron_badge_touched {
    "... Yeah, well. Don't get soppy about it. Just bring it back in one piece. Unlike everything else I lend you."
    option "What do you know about the trials?" -> ron_trials_warning
    option "I should get going." -> ron_farewell
  }

  talk ron_trials_warning {
    "I don't know much, but I know this — Charlie told me once that the castle has rooms that don't exist until they need to. Not like the Room of Requirement. Older. Meaner. Rooms that test you. He said the portraits warned him off one on the seventh floor and he's not a bloke who scares easy."
    sets [ron_warned]
    option "That's not exactly reassuring." -> ron_reassure
    option "Good to know. Thanks, Ron." -> ron_farewell
  }

  talk ron_reassure {
    "No, it's not. But here's the thing — Charlie came back fine. Because he was smart enough to not go alone. So don't you go alone either. Promise me that."
    option "I promise." -> ron_farewell
    option "I'll try." -> ron_farewell_try
  }

  talk ron_farewell {
    "Right. Off you go, then. I'll be here. Or — around. If you need me, Harry. I mean it. Just yell."
  }

  talk ron_farewell_try {
    "That's not a promise, that's a hedge. Typical. Fine. Just... be careful, yeah?"
  }

  talk ron_watch_back {
    "Always have, always will. Even when your back is doing something monumentally stupid, like walking toward danger instead of away from it. Which is always."
    option "What do you know about the trials?" -> ron_trials_warning
    option "I should get going." -> ron_farewell
  }

  # --- Ron in guardian_hall (Gryffindor Trial) ---

  talk ron_guardian_greeting {
    "H-Harry? Is that you? Please tell me that's you and not another one of those — those things. I can't — my leg, mate. I think it's broken. Maybe worse."
    option "It's me. I'm here." -> ron_guardian_relief
    option "What happened?" -> ron_guardian_explain
    option "Can you walk?" -> ron_guardian_walk
  }

  talk ron_guardian_relief {
    "Oh, thank Merlin. Thank Merlin. I followed you in — I know you said to wait, but I couldn't just sit there while you — and then the floor gave out and I fell and something grabbed my leg and—"
    option "Breathe, Ron. You're safe now." -> ron_guardian_calm
    option "Let me see your leg." -> ron_guardian_injury
  }

  talk ron_guardian_explain {
    "I came after you. Stupid, I know. You don't have to say it. The corridor behind you — it collapsed. I tried to climb through and something pulled me down. Like hands, but cold. Made of stone. They let go when I screamed, but my leg..."
    option "Let me look at it." -> ron_guardian_injury
  }

  talk ron_guardian_walk {
    "Walk? Harry, I can barely sit. Every time I move, it feels like someone's driving a spike through my knee. I've tried. I can't."
    option "I have a healing potion." -> ron_guardian_potion
    option "There has to be something I can do." -> ron_guardian_no_potion
  }

  talk ron_guardian_calm {
    "Right. Breathing. I'm breathing. That's a start. Better than the alternative."
    option "Let me see your leg." -> ron_guardian_injury
  }

  talk ron_guardian_injury {
    "It's bad. I can tell because I don't want to look at it, and in my experience that's a reliable indicator. If Mum could see me now she'd kill me, and then she'd kill you for letting me come."
    option "I have a healing potion." -> ron_guardian_potion
    option "I don't have anything to help you right now." -> ron_guardian_no_potion
  }

  talk ron_guardian_potion {
    "You — really? You're giving me your healing potion? Harry, you might need that. The trial isn't over."
    option "You need it more." -> ron_guardian_potion_give
    option "Take it, Ron. That's not a request." -> ron_guardian_potion_insist
  }

  talk ron_guardian_potion_give {
    "... You're an idiot. The best kind of idiot, but still an idiot."
    # healing_potion consumed
    option "Drink it." -> ron_guardian_healed
  }

  talk ron_guardian_potion_insist {
    "Fine. Fine. Don't have to tell me twice. Well, you did tell me twice, but—"
    # healing_potion consumed
    option "Just drink it." -> ron_guardian_healed
  }

  talk ron_guardian_healed {
    "... Oh. Oh, that's — yeah. That's much better. Still sore, but I can move. I can actually move."
    sets [ron_rescued]
    option "Can you walk out of here?" -> ron_guardian_walk_out
    option "Stay here until I finish the trial." -> ron_guardian_stay
  }

  talk ron_guardian_walk_out {
    "I think so. Slowly. Very slowly. And possibly with a lot of complaining."
    option "Wouldn't have it any other way." -> ron_guardian_emotional
  }

  talk ron_guardian_stay {
    "I'll wait. But Harry — come back, yeah? I mean it. Don't you dare die in some ancient magic trial and leave me to explain it to Hermione."
    option "I'll come back." -> ron_guardian_emotional
  }

  talk ron_guardian_emotional {
    "Harry. I know I make jokes about everything. It's what I do. But I need you to know — if I'd lost you today — if I was sitting here and you didn't come — I don't know what I'd..."
    option "You didn't lose me." -> ron_guardian_farewell
    option "I know, Ron." -> ron_guardian_farewell
  }

  talk ron_guardian_farewell {
    "Yeah. Right. Enough of that. Go be a hero. I'll be here, nursing my dignity back to health. It's in worse shape than my leg was."
  }

  # --- If player has no potion ---

  talk ron_guardian_no_potion {
    "Nothing? That's — okay. That's okay. I'll manage. I've had worse. Actually, no, I haven't. This is definitely the worst."
    option "I'll come back with help. I promise." -> ron_guardian_leave
    option "I have to keep going, Ron. I'm sorry." -> ron_guardian_abandon
  }

  talk ron_guardian_leave {
    "Go. Find something. I'll be here. Not like I have a choice."
    option "I'll be back as fast as I can." -> ron_guardian_leave_farewell
  }

  talk ron_guardian_leave_farewell {
    "I know you will. Just — hurry, yeah? It's dark in here and the walls are making noises I don't like."
  }

  talk ron_guardian_abandon {
    "You're — you're leaving me here? Harry, I — ... Right. The mission. The trial. I get it. I do. Just — go. Before I say something I'll regret."
    sets [ron_abandoned]
    option "Ron—" -> ron_guardian_abandon_farewell
    option "..." -> ron_guardian_abandon_farewell
  }

  talk ron_guardian_abandon_farewell {
    "Just go."
  }
}

# ============================================================
# HERMIONE — library (also celestial_room)
# Lore, Restricted Section access, Founder research.
# Voice: precise, passionate about knowledge, impatient with laziness.
# ============================================================

npc hermione {
  name "Hermione Granger"
  description "Hermione Granger is surrounded by a fortress of open books, her quill moving furiously across parchment. She barely looks up, but you can tell she knows exactly who entered the room."
  examine "Hermione has ink stains on three fingers, a quill behind one ear, and the slightly manic expression of someone who has been reading for so long that the act of not reading feels physically uncomfortable. Her notes are color-coded. Her cross-references have cross-references. She is terrified, and she is handling it the only way she knows how — by knowing everything."
  room_id library
  dialogue "Hermione is buried in research, her quill scratching urgently across parchment."
  category "character"

  talk hermione_greeting {
    "Harry! Good, you're here. I've been going through every text I can find on Hogwarts' founding, and there are gaps. Deliberate gaps. Entire chapters that reference events and then refuse to explain them. It's infuriating."
    option "What kind of gaps?" -> hermione_gaps
    option "I need to get into the Restricted Section." -> hermione_restricted
    option "Dumbledore told me about the Convergence Stone." -> hermione_stone
  }

  talk hermione_greeting_quest {
    "Harry! I've been researching everything I can about the Founders. There are references to a 'great working' — a collaborative spell unlike anything in recorded history. But the details are all in the Restricted Section, and Madam Pince won't let me within ten feet of it without written permission."
    option "Dumbledore gave me a permission slip." -> hermione_permission
    option "What have you found so far?" -> hermione_research
    option "Tell me about the Founders." -> hermione_founders
  }

  talk hermione_gaps {
    "References to a fifth collaborator. Someone who worked alongside the Founders and then was erased from the record. Whoever they were, the school went to extraordinary lengths to pretend they never existed."
    option "That might be Malachar." -> hermione_malachar_name
    option "Can you find out more?" -> hermione_restricted
  }

  talk hermione_malachar_name {
    "Malachar? That name appears exactly once in 'Hogwarts: A History' — in a footnote that says 'see Chapter 47.' There is no Chapter 47. The book goes from 46 to 48. Someone removed it."
    option "I need to get into the Restricted Section." -> hermione_restricted
  }

  talk hermione_restricted {
    "So do I. Madam Pince is immovable on the subject. We need a signed permission slip from a professor — and not just any professor. It has to be a Head of House or higher."
    option "I'll see what I can do." -> hermione_restricted_wait
    option "Would this work?" -> hermione_permission
  }

  talk hermione_restricted_wait {
    "Please hurry. I can feel the answer is close — it's right there behind a locked gate and a very territorial librarian."
  }

  talk hermione_permission {
    "Is that — Harry, that's Dumbledore's signature! And it's countersigned by McGonagall! This isn't just permission, this is a mandate. Give me twenty minutes."
    option "Take your time." -> hermione_permission_later
    option "I'll come with you." -> hermione_restricted_entry
  }

  talk hermione_permission_later {
    "Twenty minutes, Harry. Not a second more. Meet me at the east alcove."
    sets [restricted_unlocked]
  }

  talk hermione_restricted_entry {
    "The Restricted Section is through the back corridor — past the Magical Theory shelves, left at the chained bookcase. Madam Pince keeps the entrance behind a curtain. Most students don't even know it's there."
    sets [restricted_unlocked]
    option "Let's go." -> hermione_restricted_farewell
  }

  talk hermione_restricted_farewell {
    "And Harry — don't touch anything that whispers. I mean it. Some of those books bite."
  }

  talk hermione_research {
    "Bits and pieces. The Founders didn't just build a school — they built a magical engine. Each of them contributed something essential. Gryffindor gave it courage — the willingness to act. Ravenclaw gave it wisdom — the capacity to learn. Hufflepuff gave it loyalty — the binding that holds. And Slytherin gave it ambition — the drive to grow."
    option "That's the Convergence Stone." -> hermione_stone
    option "Tell me about the Founders." -> hermione_founders
  }

  talk hermione_stone {
    "The Convergence Stone. Yes. I've found oblique references. It's described as 'the Founders' greatest and most terrible achievement.' One text calls it 'the weight that holds the world.' Another calls it 'the mistake they could not unmake.' Encouraging, isn't it?"
    option "Tell me about the Founders." -> hermione_founders
    option "I need to get to the Restricted Section." -> hermione_restricted
    option "Thanks, Hermione. I should go." -> hermione_farewell
  }

  talk hermione_founders {
    "What most people don't understand is that the Founders weren't friends. Not really. They were colleagues bound by a shared vision that they fundamentally disagreed about. Gryffindor and Slytherin nearly killed each other twice. Ravenclaw thought Hufflepuff was too soft. Hufflepuff thought Ravenclaw was too cold. They fought constantly."
    option "Then how did they build Hogwarts?" -> hermione_founders_how
    option "Thanks. I should go." -> hermione_farewell
  }

  talk hermione_founders_how {
    "Because they needed each other. And they knew it. That's the remarkable thing. They chose to build together despite disagreeing about almost everything. The school exists because four people who didn't like each other very much decided that the work mattered more than the argument."
    option "That's actually beautiful." -> hermione_founders_beautiful
    option "Thanks, Hermione." -> hermione_farewell
  }

  talk hermione_founders_beautiful {
    "It is. And it's exactly what Malachar couldn't tolerate. He wanted harmony without conflict. Unity without difference. That's not cooperation — it's control."
    option "You sound like Dumbledore." -> hermione_farewell_dumbledore
    option "Thanks. I need to get moving." -> hermione_farewell
  }

  talk hermione_farewell {
    "Be careful, Harry. And come back if you find anything. I want to see it. For academic purposes. And because I'm worried about you."
  }

  talk hermione_farewell_dumbledore {
    "I'll take that as a compliment. Now go — and for Merlin's sake, take notes. If you find primary sources about the Founders in those trials and don't document them, I will never forgive you."
  }

  # --- Hermione in celestial_room (Ravenclaw trial support) ---

  talk hermione_celestial {
    "Harry, look at this. The star charts on the ceiling — they're not decorative. They're a map. But it's incomplete. Half the constellations are missing."
    option "I found charts in the meditation alcove." -> hermione_charts_combine
    option "What do you think it means?" -> hermione_charts_analyze
  }

  talk hermione_charts_analyze {
    "The visible stars trace a path, but it dead-ends. We need the missing constellations to complete the route. There must be another set of charts somewhere — a complement to these."
    option "I'll look for them." -> hermione_charts_wait
  }

  talk hermione_charts_wait {
    "Try the meditation alcove, if there is one. Ravenclaw valued contemplation — she would have hidden knowledge in a place of stillness."
  }

  talk hermione_charts_combine {
    "Let me see — yes! These are the southern constellations. The ceiling shows the northern sky. If we overlay them... hold on..."
    option "Take your time." -> hermione_charts_result
  }

  talk hermione_charts_result {
    "There. The complete sky. The path traces through Orion, past Cassiopeia, and terminates at — it's pointing to the far wall. There must be a hidden passage exactly where the last star falls."
    sets [charts_combined]
    option "Brilliant, Hermione." -> hermione_charts_farewell
    option "Of course it's a hidden passage." -> hermione_charts_farewell
  }

  talk hermione_charts_farewell {
    "I do enjoy a good puzzle. Even one that's trying to kill us. Especially one that's trying to kill us, honestly."
  }
}

# ============================================================
# DUMBLEDORE — dumbledore_office (CRITICAL quest giver)
# Mission briefing, item distribution, lore exposition.
# Voice: warm gravity, Socratic cadence, gentle steel.
# ============================================================

npc dumbledore {
  name "Albus Dumbledore"
  description "Albus Dumbledore sits behind his desk with the stillness of deep contemplation, his half-moon spectacles reflecting the light of a dozen silver instruments. He looks at you as if he has been expecting you — and perhaps dreading it."
  examine "He looks older than you have ever seen him. The lines around his eyes are deeper, the blue of his gaze dimmer, and his blackened hand rests on the desk like a testament to costs already paid. But his voice, when he speaks, carries the calm authority of someone who has stared into the worst the world has to offer and chosen, every single time, to stare back. The silver instruments tick and whir around him like a mechanical heartbeat."
  room_id dumbledore_office
  dialogue "Dumbledore watches you from behind his desk, patient and grave."
  category "character"

  talk dumbledore_greeting {
    "Ah, Harry. I wondered when you would arrive. Please — sit. There are Lemon Drops on the desk if you'd like one. I find sugar helps with difficult conversations."
    option "What's happening to the castle?" -> dumbledore_castle
    option "McGonagall sent me." -> dumbledore_mcgonagall
    option "No small talk, Professor. Tell me what's wrong." -> dumbledore_direct
  }

  talk dumbledore_castle {
    "A fair question, and one I owe you an honest answer to. The castle is waking up — or rather, something beneath it is. Something that has been sleeping since the Founders walked these halls."
    option "What is it?" -> dumbledore_stone_intro
    option "The Founders? This goes back that far?" -> dumbledore_founders
  }

  talk dumbledore_mcgonagall {
    "Minerva is efficient as always. She would have told you the castle is in distress. She is correct, though 'distress' understates the matter considerably."
    option "How bad is it?" -> dumbledore_stone_intro
    option "She seemed frightened." -> dumbledore_minerva_fear
  }

  talk dumbledore_minerva_fear {
    "Minerva does not frighten easily. When she does, I pay attention. You should as well."
    option "Tell me everything." -> dumbledore_stone_intro
  }

  talk dumbledore_direct {
    "Very well. I have always appreciated your directness, Harry, even when it borders on impatience."
    option "..." -> dumbledore_stone_intro
  }

  talk dumbledore_founders {
    "Further, in fact. The roots of this reach back to a time when the four Founders were not yet legends — when they were merely brilliant, frightened people trying to build something that would outlast them."
    option "Go on." -> dumbledore_stone_intro
  }

  talk dumbledore_stone_intro {
    "There is an artifact hidden in the deepest foundations of this school. It is called the Convergence Stone. The Founders created it together — a single object that channels all four of their magical traditions into one. It was meant to be the heart of Hogwarts. Its power source. Its soul, if you will."
    sets [knows_stone_lore]
    option "Why haven't I heard of this before?" -> dumbledore_secrecy
    option "What went wrong?" -> dumbledore_malachar_intro
    option "And now it's causing all this?" -> dumbledore_malachar_intro
  }

  talk dumbledore_secrecy {
    "Because some truths are too dangerous for textbooks. The Stone's existence was known only to the Headmasters of Hogwarts, passed down in whispers. I am the latest in a long line of keepers — and I fear I may be the last, if we do not act."
    option "What went wrong with it?" -> dumbledore_malachar_intro
  }

  talk dumbledore_malachar_intro {
    "A wizard named Malachar. He was a student here, centuries ago. Brilliant. Perhaps the most gifted student this school has ever produced — and I do not say that lightly. He discovered the Stone's existence, and he became obsessed with it. He believed he could use it to unify all magic under a single will. His will."
    option "What happened to him?" -> dumbledore_malachar_fate
    option "How is he connected to what's happening now?" -> dumbledore_curse
  }

  talk dumbledore_malachar_fate {
    "The Founders stopped him. Together, they bound him — not killed, mind you, but trapped. Sealed within the Stone's own chamber, his curse woven into the fabric of the school itself. For centuries, the binding held. It is not holding any longer."
    option "The curse is breaking free." -> dumbledore_curse
  }

  talk dumbledore_curse {
    "Malachar placed a curse on the Stone before he was bound. A slow, patient thing. It has been eroding the Founders' protections for a thousand years, and now the walls are thin. The disturbances you see — the shifting corridors, the failing wards — those are symptoms. The disease is far worse."
    option "What do we need to do?" -> dumbledore_trials
    option "Can't you stop it?" -> dumbledore_why_harry
  }

  talk dumbledore_why_harry {
    "I have tried. The curse is designed to resist any single magical tradition. It requires something I cannot provide: a wizard who can earn the trust of all four Founders' legacies. Their trials were built for a student, Harry. Not a Headmaster."
    option "Trials?" -> dumbledore_trials
  }

  talk dumbledore_trials {
    "The Founders foresaw that the Stone might one day need a champion. They each created a trial — a test of the virtue they valued most. Courage for Gryffindor. Wisdom for Ravenclaw. Loyalty for Hufflepuff. Cunning for Slytherin. A wizard who passes all four trials can reach the Stone and restore the binding."
    option "And you want me to do this." -> dumbledore_assignment
    option "All four? Even Slytherin?" -> dumbledore_slytherin
  }

  talk dumbledore_slytherin {
    "Even Slytherin. Cunning is not cruelty, Harry. Salazar Slytherin valued resourcefulness, self-preservation, and the willingness to make difficult choices. These are not evil qualities — merely dangerous ones, when misused."
    option "I understand." -> dumbledore_assignment
    option "I'm not sure I can think like a Slytherin." -> dumbledore_reassure
  }

  talk dumbledore_reassure {
    "The Sorting Hat considered placing you in Slytherin, as I recall. You have more of Salazar's qualities than you credit yourself with. That is not a failing."
    option "Fine. What do I need?" -> dumbledore_assignment
  }

  talk dumbledore_assignment {
    "I will not send you into this unprepared. I have three things for you."
    option "I'm listening." -> dumbledore_items
  }

  talk dumbledore_items {
    "First — this lantern. It is enchanted to reveal hidden passages and dispel minor illusions. The trials are concealed within the school, and you will need it to find them."
    # Item given: enchanted_lantern
    option "Thank you. What else?" -> dumbledore_items_2
  }

  talk dumbledore_items_2 {
    "Second — a permission slip for the Restricted Section of the library. Miss Granger will be invaluable to you, and she will need access to texts that are otherwise sealed. Give this to her when the time comes."
    # Item given: permission_slip
    option "And the third?" -> dumbledore_items_3
  }

  talk dumbledore_items_3 {
    "Your father's Invisibility Cloak. I have been holding it for precisely this kind of occasion. There will be places in the trials where stealth serves better than strength."
    # Item given: invisibility_cloak
    option "My dad's cloak..." -> dumbledore_cloak_emotion
    option "I'll put it to good use." -> dumbledore_sendoff
  }

  talk dumbledore_cloak_emotion {
    "He would be proud of you tonight, Harry. Both of them would."
    option "..." -> dumbledore_sendoff
  }

  talk dumbledore_sendoff {
    "One more thing. You will not be able to do this alone. The Founders designed their trials to test more than one person — to test bonds. Trust your friends. Let them help you. That is not weakness. It is the very thing Malachar could never understand."
    sets [has_main_quest]
    option "I won't let you down." -> dumbledore_final
    option "What if I fail?" -> dumbledore_fail
  }

  talk dumbledore_fail {
    "Then the binding breaks. Malachar's curse consumes the Stone. And Hogwarts — the real Hogwarts, the idea of it, not merely the building — ceases to exist. But I do not believe you will fail, Harry. I never have."
    option "Then I'd better get started." -> dumbledore_final
  }

  talk dumbledore_final {
    "Off you go, then. And Harry — the Lemon Drop offer stands. For when you return."
  }

  # --- Later dialogue: after at least one trial completed ---

  talk dumbledore_progress {
    "You've returned. I can feel the shift in the castle — something is responding to your progress. Tell me what you have learned."
    option "The trials are harder than I expected." -> dumbledore_trials_hard
    option "Tell me more about Malachar." -> dumbledore_malachar_deep
    option "I found something strange in the trials." -> dumbledore_strange
  }

  talk dumbledore_trials_hard {
    "They were not designed to be completed easily. They were designed to be completed honestly. There is a difference."
    option "What do you mean?" -> dumbledore_honesty
    option "Tell me about Malachar." -> dumbledore_malachar_deep
  }

  talk dumbledore_honesty {
    "The trials test virtue, not skill. You cannot brute-force courage, or trick your way through loyalty. You must mean it. The magic knows."
    option "Tell me more about Malachar." -> dumbledore_malachar_deep
    option "I'll keep that in mind." -> dumbledore_progress_farewell
  }

  talk dumbledore_malachar_deep {
    "Malachar was not born a villain, Harry. He was born a half-blood in an era that despised them. He came to Hogwarts seeking belonging, and what he found was four contradictory philosophies that could not agree on what magic was for. He decided to end the argument. Permanently."
    sets [dumbledore_malachar_info]
    option "He wanted to unify the houses?" -> dumbledore_malachar_unity
    option "That almost sounds sympathetic." -> dumbledore_malachar_sympathy
  }

  talk dumbledore_malachar_unity {
    "He wanted to erase them. Unification, to Malachar, meant domination. One tradition. One purpose. One will governing all of magic. He could not tolerate disagreement — and that is what destroyed him. The Founders' greatest strength was that they argued. That they were different. Malachar saw diversity as weakness. He was wrong."
    option "And the curse?" -> dumbledore_malachar_curse_detail
    option "Thank you, Professor." -> dumbledore_progress_farewell
  }

  talk dumbledore_malachar_sympathy {
    "It should. The most dangerous people are those whose cause begins with a legitimate grievance. Malachar suffered real injustice. His response to that injustice is what made him a monster — not his pain."
    option "What exactly does his curse do?" -> dumbledore_malachar_curse_detail
    option "I understand." -> dumbledore_progress_farewell
  }

  talk dumbledore_malachar_curse_detail {
    "It feeds on division. Every argument between students, every rivalry between houses, every moment of distrust — the curse draws strength from it. That is why the trials require unity. That is why you need allies from every house, every temperament. Malachar's curse cannot survive genuine cooperation."
    option "That's why you told me to trust my friends." -> dumbledore_progress_farewell
  }

  talk dumbledore_progress_farewell {
    "Precisely. Now go. The castle is counting on you — and so am I."
  }

  talk dumbledore_strange {
    "Strange how? The trials are ancient magic, Harry. They will contain things that do not conform to what you learned in class."
    option "It felt like the castle was helping me." -> dumbledore_castle_alive
    option "Never mind. Tell me about Malachar." -> dumbledore_malachar_deep
  }

  talk dumbledore_castle_alive {
    "Because it is. Hogwarts is not merely a building. It is a living expression of the Founders' will. And right now, it is fighting for its life — through you."
    option "That's a lot of pressure." -> dumbledore_progress_farewell
    option "I won't let it down." -> dumbledore_progress_farewell
  }
}

# ============================================================
# SNAPE — potions_classroom
# Suspicious, curt, grudgingly helpful if pressed correctly.
# Voice: clipped sentences, controlled contempt, economy of words.
# ============================================================

npc snape {
  name "Professor Snape"
  description "Professor Snape emerges from the shadows of his classroom like something that was never fully in the light. His black eyes assess you with the warmth of a surgical instrument. He says nothing. He doesn't need to."
  examine "Severus Snape, Potions Master and Head of Slytherin House. He is thinner than you remember, and paler, as if the failing wards have been drawing from him directly. His robes are immaculate, his expression is controlled, and his wand is nowhere visible — which means it is somewhere you cannot see, which is worse. He radiates the specific hostility of someone who is helping you against every instinct they possess."
  room_id potions_classroom
  dialogue "Snape regards you from the shadows with undisguised disdain."
  category "character"

  talk snape_greeting {
    "Potter. I was not aware this classroom was on the tourist route. State your business or leave."
    option "I need your help with a potion." -> snape_potion_ask
    option "Dumbledore sent me." -> snape_dumbledore
    option "What do you know about the Convergence Stone?" -> snape_stone_direct
  }

  talk snape_dumbledore {
    "The Headmaster sends you to do many things. I am rarely impressed by any of them."
    option "He told me about the curse. About Malachar." -> snape_malachar
    option "I need help with a potion, Professor." -> snape_potion_ask
  }

  talk snape_stone_direct {
    "I know that students who ask questions above their competence tend to find answers above their survival. What specifically do you imagine I can help you with?"
    option "A Revealer Potion." -> snape_potion_ask
    option "Anything you know about the trials." -> snape_trials
  }

  talk snape_malachar {
    "So the Headmaster is finally telling people. How uncharacteristically forthcoming of him."
    option "You already knew?" -> snape_knew
    option "I need a Revealer Potion." -> snape_potion_ask
  }

  talk snape_knew {
    "I am Head of Slytherin House. The Slytherin trial is in my domain. Yes, Potter, I knew. I have known for some time. The question is whether you are capable of doing anything useful with the information."
    option "Help me, then." -> snape_potion_ask
    option "What can you tell me about the Slytherin trial?" -> snape_trials
  }

  talk snape_trials {
    "The trial of cunning is not what you think it is. It does not reward cleverness. It rewards judgment. Knowing when to fight, when to hide, and when to sacrifice something valuable for something necessary. You will find that difficult."
    option "Why?" -> snape_why_difficult
    option "I need a Revealer Potion." -> snape_potion_ask
  }

  talk snape_why_difficult {
    "Because you are your father's son. You charge. You react. You trust your instincts when your instincts are wrong. The Slytherin trial will punish that."
    option "..." -> snape_pause
    option "I'm also my mother's son." -> snape_lily
  }

  talk snape_pause {
    "Nothing to say? Perhaps there is hope for you yet."
    option "About that potion—" -> snape_potion_ask
  }

  talk snape_lily {
    "..."
    option "The Revealer Potion. Can you help me or not?" -> snape_potion_ask
  }

  talk snape_potion_ask {
    "A Revealer Potion. To expose hidden enchantments. At least that demonstrates a rudimentary understanding of what you're dealing with."
    option "Can you brew it?" -> snape_brew_refuse
    option "What ingredients do I need?" -> snape_ingredients
  }

  talk snape_brew_refuse {
    "I could brew it in my sleep. But I will not. If you cannot produce the potion yourself, you have no business using it. The trials demand competence, not dependence."
    option "Then tell me the ingredients." -> snape_ingredients
  }

  talk snape_ingredients {
    "Moonpetal — harvested under moonlight, obviously, or it's worthless. Powdered graphorn horn. And basilisk venom, diluted to one part in forty. The proportions are critical. One misstep and the result is toxic rather than revelatory."
    sets [snape_potion_help]
    option "Where do I find moonpetal?" -> snape_moonpetal
    option "Basilisk venom? Where am I supposed to—" -> snape_basilisk
    option "Thank you, Professor." -> snape_farewell
  }

  talk snape_moonpetal {
    "The greenhouse. Longbottom may be of use to you there. He is incompetent at most things, but he has an inexplicable talent with plants."
    option "And the basilisk venom?" -> snape_basilisk
    option "Thank you." -> snape_farewell
  }

  talk snape_basilisk {
    "You killed a basilisk in your second year, Potter. Surely you kept a souvenir. If not, the Chamber of Secrets is still exactly where you left it."
    option "And the moonpetal?" -> snape_moonpetal
    option "Right. Thanks." -> snape_farewell
  }

  talk snape_farewell {
    "Do not thank me. Succeed or fail on your own merit. And Potter — close the door on your way out. I have actual work to do."
  }
}

# ───────────────────────────────────────────
#   HOGWARTS GROUNDS — Characters
# ───────────────────────────────────────────

# ============================================================
# HAGRID — hagrid_hut (blocks forest_edge)
# Warm, worried, protective. Lore from a creature-keeper's lens.
# Voice: dropped g's, run-on warmth, fierce protectiveness.
# ============================================================

npc hagrid {
  name "Rubeus Hagrid"
  description "Hagrid fills the doorway of his hut like a bearded boulder, Fang drooling at his heels. His moleskin coat is buttoned wrong and his eyes are kind but worried."
  examine "Rubeus Hagrid, Keeper of Keys and Grounds. He is as vast and solid as ever, but there is a tension in his massive shoulders that you do not usually see. His hands — each the size of a dustbin lid — keep clenching and unclenching. Fang presses against his leg, whimpering, and Hagrid's free hand strokes the boarhound's ear with absent tenderness. He is afraid, and Hagrid afraid is a thing the world is not prepared for."
  room_id hagrid_hut
  dialogue "Hagrid watches the forest through the window, absently scratching Fang behind the ears."
  category "character"

  blocking hagrid_hut -> forest_edge east
  unblock hagrid_allows_forest

  talk hagrid_greeting {
    "Harry! Come in, come in. Mind Fang, he's been nervous all day — won't stop whinin'. Somethin's got the creatures all riled up. The thestrals won't come out o' the trees and I haven't seen a unicorn in weeks. That ain't right."
    option "What do you think is happening?" -> hagrid_worry
    option "I need your help, Hagrid." -> hagrid_help
    option "Dumbledore told me about the Convergence Stone." -> hagrid_stone
  }

  talk hagrid_worry {
    "The forest knows, Harry. It always knows before we do. When the centaurs go quiet and the acromantulas start buildin' deeper — that's the forest bracin' itself. Last time it was like this was... well. Before you were born."
    option "Before Voldemort?" -> hagrid_voldemort
    option "I need to get into the forest." -> hagrid_forest_ask
  }

  talk hagrid_voldemort {
    "Before him, even. The old magic's stirrin'. The kind that was here before the school, before the Founders. They built Hogwarts on top of somethin', Harry. The creatures know it. They've always known it."
    option "The Convergence Stone." -> hagrid_stone
    option "I need to get into the forest." -> hagrid_forest_ask
  }

  talk hagrid_stone {
    "So he told yeh. Good. I've been wantin' to talk to someone about it. The creatures — they feel the Stone, Harry. The unicorns are drawn to it. The centaurs read it in the stars. Even Fang, thick as he is, knows somethin's wrong down there."
    option "What do the centaurs say?" -> hagrid_centaurs
    option "I need to get into the forest." -> hagrid_forest_ask
    option "Do you have anything that might help me?" -> hagrid_wrench
  }

  talk hagrid_centaurs {
    "Mars is bright, they keep sayin'. Which is centaur for 'bad things are comin' and we're not gonna tell yeh what.' Helpful lot, centaurs. But Firenze — before he left — he told me the Stone was 'the anchor that holds the sky to the ground.' Make o' that what yeh will."
    option "I need to get into the forest." -> hagrid_forest_ask
    option "Do you have anything useful I could borrow?" -> hagrid_wrench
  }

  talk hagrid_help {
    "Anything, Harry. Yeh know that. What d'yeh need?"
    option "I need to get into the Forbidden Forest." -> hagrid_forest_ask
    option "Do you have any tools I could borrow?" -> hagrid_wrench
    option "What do you know about the Founders?" -> hagrid_founders
  }

  talk hagrid_wrench {
    "Tools? Well, I've got this wrench — enchanted, it is. Won it off a goblin in a card game. Opens any mundane lock, adjusts any bolt. Not magic locks, mind, but regular ones. Yeh'd be surprised how much o' this castle still runs on plain old metalwork."
    # Item given: wrench (makes wrench takeable)
    option "Thanks, Hagrid. I need to get into the forest." -> hagrid_forest_ask
    option "Thanks. I should go." -> hagrid_farewell_hut
  }

  talk hagrid_founders {
    "The Founders? I'll tell yeh what most people don't know. They didn't just build a school — they made a pact with the creatures of this land. Gryffindor treated with the centaurs. Hufflepuff befriended the bowtruckles and nifflers. Ravenclaw earned the respect of the phoenixes. And Slytherin — well, Slytherin spoke to things that didn't want to be spoken to."
    option "What kind of things?" -> hagrid_slytherin_creatures
    option "I need to get into the forest." -> hagrid_forest_ask
  }

  talk hagrid_slytherin_creatures {
    "Serpents. Basilisks. Things that live in the dark and don't take kindly to company. Slytherin understood 'em, though. Respected 'em. There's a difference between controllin' a creature and understandin' it, and Slytherin — for all his faults — understood."
    option "I need to get into the forest." -> hagrid_forest_ask
    option "Thanks, Hagrid." -> hagrid_farewell_hut
  }

  talk hagrid_farewell_hut {
    "Be careful, Harry. And come back for tea. I mean it. Yeh look like yeh haven't eaten."
  }

  # --- Forest Edge ---

  talk hagrid_forest_ask {
    "The forest? Harry, I can't just let yeh in there. Not tonight. The creatures are spooked and the paths are shiftin'. Yeh need protection — real protection. Not just a wand and good intentions."
    option "I have to, Hagrid. The trials—" -> hagrid_forest_insist
    option "What kind of protection?" -> hagrid_forest_protection
  }

  talk hagrid_forest_insist {
    "I know, I know. But I promised Dumbledore I'd keep students out unless they could defend themselves. Yeh need a Shield Charm scroll — proper one, not the classroom version. Show me that, and I'll let yeh through."
    option "Where do I find one?" -> hagrid_shield_hint
    option "I have one." -> hagrid_forest_allow
  }

  talk hagrid_forest_protection {
    "A Shield Charm scroll. The real kind — the kind that holds against dark creatures, not just practice hexes. Yeh bring me one o' those, and I'll open the path for yeh."
    option "Where would I find one?" -> hagrid_shield_hint
    option "I already have it." -> hagrid_forest_allow
  }

  talk hagrid_shield_hint {
    "Try the Defence classroom, or maybe the Restricted Section. Hermione might know. Clever girl, that one."
    option "I'll find one." -> hagrid_forest_wait
  }

  talk hagrid_forest_wait {
    "I'll be right here, Harry. The forest isn't goin' anywhere. Unfortunately."
  }

  talk hagrid_forest_allow {
    "That's the one. Right — listen to me carefully. Stay on the path. Do NOT follow any lights that aren't yer lantern. And if yeh hear singing — run. That's not a person, that's a lure."
    sets [hagrid_allows_forest]
    option "I'll be careful." -> hagrid_forest_farewell
    option "What's in there?" -> hagrid_forest_warning
  }

  talk hagrid_forest_warning {
    "Things that are normally peaceful but aren't right now. The curse is agitatin' 'em. Even the bowtruckles are bitin'. Just keep yer head down and don't provoke nothin'."
    option "Thanks, Hagrid." -> hagrid_forest_farewell
  }

  talk hagrid_forest_farewell {
    "And Harry — come back. I'm serious. Yeh come back."
  }
}

# ============================================================
# NEVILLE — greenhouse
# Nervous, knowledgeable, underestimated. Comes alive with plants.
# Voice: hesitant starts, gains confidence when talking botany.
# ============================================================

npc neville {
  name "Neville Longbottom"
  description "Neville Longbottom kneels among the potting benches with soil-darkened hands, tending to a Venomous Tentacula with the quiet confidence he only ever shows around plants."
  examine "Neville has dirt under every fingernail and a scratch across one cheek from a plant that did not appreciate being repotted. He is the most relaxed person in Hogwarts right now, and only because he is surrounded by growing things. Plants do not judge. Plants do not expect you to be brave. Plants only ask to be tended, and Neville is very, very good at tending."
  room_id greenhouse
  dialogue "Neville tends to the greenhouse plants with quiet, focused care."
  category "character"

  talk neville_greeting {
    "Oh! Harry! Sorry, you — you startled me. I was repotting the Venomous Tentacula and it does not like surprises. Neither do I, actually."
    option "Sorry, Neville. I need your help." -> neville_help
    option "What do you know about moonpetal?" -> neville_moonpetal_direct
    option "Have you noticed anything strange with the plants?" -> neville_strange
  }

  talk neville_strange {
    "Strange? Harry, the Whomping Willow tried to uproot itself this morning. Professor Sprout found it twenty feet from its original position. The mandrakes won't stop screaming — even with earmuffs, I can feel it in my teeth. Something underground is agitating them."
    option "It's the Convergence Stone." -> neville_stone
    option "I need moonpetal for a potion." -> neville_moonpetal_direct
  }

  talk neville_stone {
    "The — really? I thought that was just a legend. Gran used to mention it, but she mentions a lot of things, most of them complaints about the Ministry."
    option "It's real. And I need moonpetal to help stop what's happening." -> neville_moonpetal_direct
  }

  talk neville_help {
    "Me? I mean — sure. I'll try. I'm not very good at the whole adventuring thing, but if it's about plants, I might actually know something useful for once."
    option "It's about plants. Moonpetal, specifically." -> neville_moonpetal_direct
  }

  talk neville_moonpetal_direct {
    "Moonpetal! Oh, I know moonpetal. It's — sorry, this is going to sound like a lecture. Moonpetal only blooms under direct moonlight, and it has to be harvested within the first three minutes of bloom or the petals lose their magical properties. You need fresh air and an unobstructed sky — the greenhouse roof blocks it."
    option "Where can I find some?" -> neville_moonpetal_location
    option "How do I harvest it?" -> neville_moonpetal_harvest
  }

  talk neville_moonpetal_location {
    "There's a patch growing wild near the edge of the forest — Hagrid showed me once. And there might be some in the courtyard garden, if Luna hasn't picked it all for her Nargle repellent. She uses a lot of moonpetal for that."
    option "How do I harvest it properly?" -> neville_moonpetal_harvest
    option "Thanks, Neville." -> neville_farewell
  }

  talk neville_moonpetal_harvest {
    "Cut the stem at a diagonal, below the second leaf node. Use a silver blade if you have one — steel bruises the petals and they lose potency. And talk to it while you cut. I know that sounds mad, but moonpetal responds to intent. If you're harvesting with purpose, it... cooperates."
    option "Talk to the plant." -> neville_talk_plant
    option "Where do I find it?" -> neville_moonpetal_location
    option "Thanks, Neville. Really." -> neville_farewell
  }

  talk neville_talk_plant {
    "I know how it sounds. But plants aren't stupid, Harry. They're just quiet. Moonpetal especially — it was bred by Helga Hufflepuff herself. She believed every living thing deserved to be asked, not just taken from."
    option "Hufflepuff grew moonpetal?" -> neville_hufflepuff
    option "I'll keep that in mind." -> neville_farewell
  }

  talk neville_hufflepuff {
    "She was brilliant with plants. Most people remember her for loyalty and kindness, but she was the finest herbologist of her age. Half the magical species in this greenhouse descend from her original cultivars. I think about that a lot, actually."
    option "You'd have been her favorite student." -> neville_compliment
    option "Thanks, Neville." -> neville_farewell
  }

  talk neville_compliment {
    "I — you think? I mean, that's — nobody's ever said — ... thanks, Harry. That actually means a lot."
    option "I should get going." -> neville_farewell
  }

  talk neville_farewell {
    "Good luck. And Harry — if you need anything else plant-related, come find me. It's the one thing I'm actually good at. Might as well use it."
  }
}

# ============================================================
# LUNA — courtyard
# Dreamy, perceptive, oddly profound. Sees things others dismiss.
# Voice: wandering cadence, non-sequiturs that circle back to insight.
# ============================================================

npc luna {
  name "Luna Lovegood"
  description "Luna Lovegood sits cross-legged on the edge of the broken sundial, gazing at the amber sky with serene curiosity, as if the wrongness of it all is merely interesting rather than terrifying."
  examine "Luna wears her Spectrespecs pushed up on her forehead, radish earrings dangling, and an expression of interested calm that would be infuriating if it were not so obviously genuine. She is the only person in Hogwarts who does not look afraid. She looks curious. She looks like someone watching a thunderstorm from a safe distance and finding the lightning beautiful."
  room_id courtyard
  dialogue "Luna gazes at the amber sky from the broken sundial, serenely unbothered."
  category "character"

  talk luna_greeting {
    "Hello, Harry. You have an unusual number of Wrackspurts around your head today. That usually means you're thinking too hard about the wrong thing."
    option "Luna, have you noticed anything strange?" -> luna_strange
    option "I need help with the Ravenclaw trial." -> luna_ravenclaw
    option "What's a Wrackspurt again?" -> luna_wrackspurt
  }

  talk luna_wrackspurt {
    "They're invisible creatures that float into your ears and make your brain go fuzzy. Most people have a few. You have about seventeen, which is a personal record. Something must be very confusing for you right now."
    option "You could say that." -> luna_strange
    option "The Ravenclaw trial — do you know anything?" -> luna_ravenclaw
  }

  talk luna_strange {
    "Oh, yes. The Nargles are absolutely frantic. They've been trying to warn people for days, but nobody listens to Nargles. They're quite offended, actually. I left them some pudding to apologize on behalf of the school."
    option "What are they warning about?" -> luna_nargles_warning
    option "Luna, I need to ask you about the Ravenclaw trial." -> luna_ravenclaw
  }

  talk luna_nargles_warning {
    "The ground is humming. Can you feel it? Put your hand on the stones. Right here. The castle is talking, Harry. Most people can't hear it because they're too busy making noise themselves. It's saying 'help.'"
    option "I'm trying to help. That's why I need the Ravenclaw trial." -> luna_ravenclaw
    option "You can hear the castle?" -> luna_castle_hear
  }

  talk luna_castle_hear {
    "Not hear, exactly. Feel. It's like the difference between listening to someone speak and standing next to them while they cry. You don't need words for the second one."
    option "The Ravenclaw trial, Luna. Please." -> luna_ravenclaw
  }

  talk luna_ravenclaw {
    "The trial of wisdom. I've thought about it, you know. Not because anyone asked me to, but because it seemed like the sort of thing worth thinking about. My mother would have loved it."
    option "Do you know anything that could help?" -> luna_riddle
    option "Your mother studied Ravenclaw's work?" -> luna_mother
  }

  talk luna_mother {
    "She studied everything. She was a researcher. She died trying to understand something that wasn't ready to be understood. I think Rowena Ravenclaw would have liked her. They had the same flaw — curiosity without caution."
    option "I'm sorry, Luna." -> luna_sorry
    option "The trial — can you help me?" -> luna_riddle
  }

  talk luna_sorry {
    "Don't be. She died doing what she loved. There are worse ways to go than being consumed by wonder."
    option "The riddle — do you know anything?" -> luna_riddle
  }

  talk luna_riddle {
    "I know that Ravenclaw's riddles aren't meant to be solved the way you solve an equation. They're meant to be sat with. Like a cat. You don't solve a cat. You just... let it happen."
    option "That's surprisingly helpful." -> luna_riddle_detail
    option "Can you be more specific?" -> luna_riddle_detail
  }

  talk luna_riddle_detail {
    "The entrance asks a question with no answer. Most people try to answer it anyway, because they're afraid of silence. But silence is an answer, isn't it? The absence of a thing is still a thing. Like how a hole is defined by what isn't there."
    sets [luna_riddle_hint]
    option "So the answer is... not answering?" -> luna_riddle_confirm
    option "Thank you, Luna." -> luna_nargle_quest
  }

  talk luna_riddle_confirm {
    "The answer is accepting that not everything needs an answer. That's different from not answering. One is giving up. The other is wisdom."
    option "Got it. Thanks, Luna." -> luna_nargle_quest
  }

  talk luna_nargle_quest {
    "Harry — while you're exploring the castle, if you happen to find any Nargle nests, could you leave them alone? They're just frightened. Everything is frightened right now. Even the things pretending not to be."
    option "I'll be gentle with the Nargles." -> luna_farewell
    option "I'll try." -> luna_farewell
  }

  talk luna_farewell {
    "Good luck, Harry. I think the castle is rooting for you. In its own very old, very confused way."
  }
}

# ============================================================
# GINNY — entrance_hall
# Emotional support, side quest potential. Fierce and perceptive.
# Voice: direct, warm, impatient with evasion.
# ============================================================

npc ginny {
  name "Ginny Weasley"
  description "Ginny Weasley leans against the marble balustrade of the entrance hall, arms crossed, watching the shifting staircases with the expression of someone who has decided to be angry rather than afraid."
  examine "Ginny's wand is in her hand, not sheathed. Her jaw is set and her brown eyes are sharp with the particular fury of someone who has been told to stay behind and is considering not doing so. She has her mother's stubbornness and her brothers' recklessness and a spine made of something harder than either."
  room_id entrance_hall
  dialogue "Ginny watches the shifting staircases with fierce, impatient eyes."
  category "character"

  talk ginny_greeting {
    "Harry. Don't tell me to stay here and be safe. I've already heard it from Ron, Hermione, and three portraits. I'm not interested."
    option "I wasn't going to say that." -> ginny_respect
    option "What do you know about what's happening?" -> ginny_info
    option "Have you seen anything useful?" -> ginny_clue
  }

  talk ginny_respect {
    "Good. Because I've been watching the corridors all night and I've noticed things. Useful things. The kind of things people notice when they're not running headfirst into ancient trials."
    option "What have you noticed?" -> ginny_clue
  }

  talk ginny_info {
    "I know the castle is coming apart at the seams and nobody's telling the students anything useful. I know Dumbledore hasn't been seen at meals. I know my brother is trying to be brave and doing a terrible job of hiding that he's terrified."
    option "Ron's tougher than he looks." -> ginny_ron
    option "What have you noticed?" -> ginny_clue
  }

  talk ginny_ron {
    "I know he is. That's not the point. The point is he shouldn't have to be. None of us should. But here we are."
    option "Here we are." -> ginny_clue
  }

  talk ginny_clue {
    "The staircases aren't random. I've been watching them for hours. They move in a pattern — it's complicated, but it repeats. They're trying to connect certain floors. As if the castle is building a route to somewhere specific."
    sets [ginny_staircase_clue]
    option "Where do you think they're leading?" -> ginny_destination
    option "Thanks, Ginny. Be careful." -> ginny_farewell
  }

  talk ginny_destination {
    "Upward. Always upward. The seventh floor keeps getting connected to places it shouldn't — the dungeons, the kitchens, the grounds. It's like the castle is making shortcuts. Clearing a path."
    option "The Room of Requirement is on the seventh floor." -> ginny_ror
    option "Thanks. I should go." -> ginny_farewell
  }

  talk ginny_ror {
    "I thought of that. But this feels different. Older. Like the castle is remembering something it used to do — before the Room of Requirement was even built."
    option "Thank you, Ginny." -> ginny_farewell
  }

  talk ginny_farewell {
    "Go. And Harry — come back in one piece. If you don't, I'll find a way to kill you again myself."
  }
}

# ───────────────────────────────────────────
#   HOGWARTS COMMONS — Secondary Characters
# ───────────────────────────────────────────

# ============================================================
# FRED & GEORGE — seventh_floor_corridor
# Mischievous, finish each other's sentences, chaos merchants.
# Voice: rapid-fire ping-pong dialogue, irrepressible humor.
# ============================================================

npc fred_george {
  name "Fred and George Weasley"
  description "Fred Weasley leans against the wall with studied nonchalance, one hand in his pocket, the other tossing a small object that emits sparks at irregular intervals. His grin suggests he knows something you don't. George Weasley crouches over a spread of parchment and prototype products, occasionally glancing up at Fred with the wordless communication of someone who shares a brain with another person."
  examine "The Weasley twins are, as always, exactly where they should not be, doing exactly what they should not be doing, and looking entirely too pleased about it. They have turned the corridor into a makeshift trading post, their merchandise arranged on a conjured table with the professional flair of born salesmen. The castle is falling apart and they are selling snacks. It is, somehow, exactly what the situation needs."
  room_id seventh_floor_corridor
  dialogue "The Weasley twins are running a makeshift shop in the corridor, grinning like the world isn't ending."
  category "character"

  talk twins_greeting {
    "FRED: Harry! Just the man we wanted to see.\nGEORGE: Or avoid, depending on your perspective.\nFRED: We've been doing a bit of entrepreneurial work—\nGEORGE: —during an existential crisis—\nFRED: —because capitalism never sleeps, Harry."
    option "What are you selling?" -> twins_shop
    option "Do you know anything about secret passages?" -> twins_passages
    option "This really isn't the time." -> twins_serious
  }

  talk twins_serious {
    "GEORGE: He's right, Fred. Very serious situation.\nFRED: Absolutely. Doom and gloom.\nGEORGE: ...\nFRED: ...\nGEORGE: We're still selling things, though."
    option "Fine. What have you got?" -> twins_shop
    option "The passages. Talk." -> twins_passages
  }

  talk twins_shop {
    "FRED: First up — Magical Candy! Our own special blend. Eat one and you'll feel invincible for about thirty seconds.\nGEORGE: You won't actually be invincible.\nFRED: Important legal distinction, that.\nGEORGE: Second — Peruvian Darkness Powder! Throw it, and everything within ten feet goes pitch black. Very useful for dramatic exits.\nFRED: Five Galleons for both. Mates' rates."
    option "Deal. Here's five Galleons." -> twins_buy
    option "I don't have the gold right now." -> twins_no_gold
    option "What about those secret passages?" -> twins_passages
  }

  talk twins_buy {
    "FRED: Pleasure doing business!\nGEORGE: The candy is the round one. The powder is the bag.\nFRED: Do NOT mix them up.\nGEORGE: Fred mixed them up once.\nFRED: We don't talk about that."
    # Items given: magical_candy, peruvian_darkness_powder
    option "Thanks. Secret passages?" -> twins_passages
    option "Cheers." -> twins_farewell
  }

  talk twins_no_gold {
    "GEORGE: No gold, no goods. We're philanthropists, Harry—\nFRED: —but not that kind of philanthropists.\nGEORGE: Come back when you're flush. We'll be here.\nFRED: Not going anywhere. Literally. The doors are stuck."
    option "What about secret passages?" -> twins_passages
    option "I'll be back." -> twins_farewell
  }

  talk twins_passages {
    "FRED: Now you're speaking our language.\nGEORGE: The Marauder's Map is with you, obviously—\nFRED: —but the map doesn't show everything. There are passages even Dad's old map missed. Older ones.\nGEORGE: There's one behind the mirror on the fourth floor. Leads down to a junction we've never explored because—\nFRED: —it smelled like old magic and bad decisions.\nGEORGE: Which is usually a sign to either run away—\nFRED: —or charge in headfirst. We recommend the latter."
    sets [twins_hint]
    option "Thanks, you two." -> twins_farewell
    option "About those items you're selling—" -> twins_shop
  }

  talk twins_farewell {
    "FRED: Good luck, Harry!\nGEORGE: Don't die!\nFRED: If you do die, can we have your broom?\nGEORGE: FRED.\nFRED: What? It's a Firebolt!"
  }
}

# ============================================================
# DRACO — serpent_hall (first encounter) and bargain_chamber
# Sharp, defensive, aristocratic disdain masking insecurity.
# Voice: clipped precision, vulnerability under contempt.
# ============================================================

npc draco {
  name "Draco Malfoy"
  description "Draco Malfoy stands in the serpent hall's distorted reflections, his arms crossed, his expression a careful mask of contempt over something more complicated — fear, perhaps, or the exhausting effort of pretending he isn't afraid."
  examine "Draco is thinner than he was at the start of term, and there are shadows under his eyes that his aristocratic bearing cannot quite disguise. His robes are immaculate — of course they are — but his hands betray him: the knuckles are white, the fingers clenched, the nails bitten to the quick. He is terrified, and the fact that he is standing here anyway says something about him that he would deny if you pointed it out."
  room_id serpent_hall
  dialogue "Draco stands in the distorted mirrors, watching you with guarded intensity."
  category "character"

  # --- First encounter: serpent_hall ---

  talk draco_serpent_greeting {
    "Well, well. Potter, skulking around the dungeons. I'd say I'm surprised, but I learned to stop being surprised by your complete disregard for rules somewhere around second year."
    option "Get out of my way, Malfoy." -> draco_hostile_path
    option "I'm not here to fight, Draco." -> draco_neutral_path
    option "What are you doing down here?" -> draco_curious_path
  }

  talk draco_hostile_path {
    "Make me. Go on. We both know you're dying to. The noble Harry Potter, always spoiling for a fight as long as he can pretend the other person started it."
    option "I don't have time for this." -> draco_hostile_escalate
    option "You're right. I don't want to fight." -> draco_neutral_redirect
  }

  talk draco_hostile_escalate {
    "Then you shouldn't have come to my part of the castle. Stupefy!"
    sets [draco_hostile]
    # Combat or block event triggers
  }

  talk draco_neutral_redirect {
    "... No? Losing your edge, Potter?"
    option "I'm not here for you, Malfoy." -> draco_neutral_path
  }

  talk draco_neutral_path {
    "Not here to fight. How disappointing. What are you here for, then? Because this corridor leads nowhere pleasant, and you don't strike me as the type who enjoys Slytherin architecture."
    option "The trials. I'm looking for the Slytherin trial." -> draco_neutral_trial
    option "None of your business." -> draco_neutral_dismiss
  }

  talk draco_neutral_trial {
    "The Slytherin trial. So the rumors are true — something's happening to the castle and Dumbledore's sent his golden boy to fix it. Typical."
    option "Something like that. Are you going to stop me?" -> draco_neutral_decision
    option "Do you know where it is?" -> draco_neutral_info
  }

  talk draco_neutral_dismiss {
    "Fine. Keep your secrets. I have my own."
    sets [draco_neutral]
  }

  talk draco_neutral_decision {
    "Stop you? No. I have better things to do than play hall monitor. But don't expect help, either."
    sets [draco_neutral]
    option "Fair enough." -> draco_neutral_farewell
  }

  talk draco_neutral_info {
    "I might. But why would I share it with you?"
    sets [draco_neutral]
    option "Forget it." -> draco_neutral_farewell
  }

  talk draco_neutral_farewell {
    "Good luck, Potter. You'll need it."
  }

  talk draco_curious_path {
    "What am I — that's none of your — ... Why do you care?"
    option "Because something's wrong and you look worried too." -> draco_curious_worry
    option "Honestly? You look like you haven't slept." -> draco_curious_concern
  }

  talk draco_curious_worry {
    "I'm not worried. Malfoys don't worry. We... assess situations strategically."
    option "And what's your strategic assessment?" -> draco_curious_assess
  }

  talk draco_curious_concern {
    "I... what? Don't — don't do that. Don't pretend you care about how I look. We're not friends, Potter."
    option "No. But that doesn't mean I want to see you hurt." -> draco_curious_vulnerability
    option "Fine. But something's wrong with the castle, and you know it." -> draco_curious_assess
  }

  talk draco_curious_assess {
    "The wards around the Slytherin common room failed last night. Just for a moment, but — I felt it. Cold like I've never felt. Not temperature. Something else. Something old."
    option "That's Malachar's curse." -> draco_curious_explain
  }

  talk draco_curious_vulnerability {
    "... You're infuriating, do you know that? You can't just — say things like that. To me."
    option "I just did. Now tell me what you felt in the dungeons." -> draco_curious_assess
  }

  talk draco_curious_explain {
    "Malachar. I've read that name in the family library. My father has a journal — very old, very forbidden. It mentions a wizard who nearly consumed Hogwarts from the inside. He was obsessed with the Stone."
    option "Your family knew about this?" -> draco_curious_family
  }

  talk draco_curious_family {
    "The Malfoy family has known about a great many things and done nothing about most of them. It's something of a tradition."
    option "Would you do something about this one?" -> draco_curious_offer
    option "I'll find you again if I need your help." -> draco_curious_farewell_open
  }

  talk draco_curious_offer {
    "Are you... asking me for help? Harry Potter, asking Draco Malfoy for help. The Prophet would have a field day."
    option "This is bigger than us, Draco." -> draco_curious_bridge
    option "Only if you can keep up." -> draco_curious_challenge
  }

  talk draco_curious_bridge {
    "... I'll think about it. Don't take that as a yes. Take it as a not-no. There's a difference."
    option "I'll find you in the Bargain Chamber." -> draco_curious_farewell_open
  }

  talk draco_curious_challenge {
    "Keep up? With you? Potter, I've been running circles around you since first year. You just never noticed because you were too busy being the Chosen One."
    option "Then prove it. Help me." -> draco_curious_farewell_open
  }

  talk draco_curious_farewell_open {
    "We'll see. Don't die before I make up my mind. That would be inconvenient."
  }

  # --- Second encounter: bargain_chamber ---

  talk draco_bargain_greeting {
    "You came. I was half hoping you wouldn't. It would have been easier to pretend this conversation never needed to happen."
    option "What do you want, Draco?" -> draco_bargain_motivation
    option "I'm glad you're here." -> draco_bargain_surprised
  }

  talk draco_bargain_surprised {
    "Don't. I didn't come for you. I came because — there are things at stake that you don't understand."
    option "Then explain them to me." -> draco_bargain_motivation
  }

  talk draco_bargain_motivation {
    "My father's reputation is in ruins. Our family name is worth less than the parchment it's printed on. And now there's a curse threatening to destroy the one institution that still acknowledges we exist. If Hogwarts falls, the Malfoy family has nothing."
    option "This is about your family?" -> draco_bargain_family
    option "There's more to it than that." -> draco_bargain_deeper
  }

  talk draco_bargain_family {
    "Everything is about my family, Potter. That's something you wouldn't understand, seeing as yours is — ... I'm sorry. That was beneath me."
    option "Go on." -> draco_bargain_deeper
    option "Yeah. It was." -> draco_bargain_tension
  }

  talk draco_bargain_tension {
    "I know. I said I'm sorry. I don't say that often, so you might want to appreciate the rarity."
    option "Noted. Keep talking." -> draco_bargain_deeper
  }

  talk draco_bargain_deeper {
    "My father is a broken man, Potter. He sits in that manor and stares at portraits of ancestors who did great things, and he knows he'll never be one of them. He had one chance to prove our family's worth and he chose the wrong side. I won't make the same mistake."
    option "This isn't about sides, Draco." -> draco_bargain_sides
    option "So help me. Prove the Malfoy name means something." -> draco_bargain_offer_alliance
  }

  talk draco_bargain_sides {
    "Everything is about sides. The difference is whether you're choosing a side or letting one choose you. I'm tired of being chosen."
    option "Then choose this. Help me stop Malachar." -> draco_bargain_offer_alliance
    option "I can't make that choice for you." -> draco_bargain_refuse_path
  }

  talk draco_bargain_offer_alliance {
    "An alliance. Between a Potter and a Malfoy. If our grandfathers could see this, they'd collectively have an aneurysm."
    option "Is that a yes?" -> draco_bargain_accept
    option "I need to know I can trust you." -> draco_bargain_trust
  }

  talk draco_bargain_trust {
    "Trust. There's a word I don't use much. I can't give you a guarantee, Potter. What I can give you is this: Malachar's curse threatens my home. I will fight anything that threatens my home. Right now, that puts us on the same side. Is that enough?"
    option "It's enough." -> draco_bargain_accept
    option "No. I need more than convenience." -> draco_bargain_refuse_path
  }

  talk draco_bargain_accept {
    "Then it's done. I know the Slytherin dungeons better than anyone alive. I know where the trial entrance is — I've seen it, behind the false wall in the lower corridor. I'll show you when you're ready."
    sets [draco_allied]
    option "Thank you, Draco." -> draco_bargain_farewell_allied
  }

  talk draco_bargain_farewell_allied {
    "Don't thank me. And don't tell anyone about this conversation. I have a reputation to maintain. What's left of it."
  }

  talk draco_bargain_refuse_path {
    "Fine. I tried. Don't say I didn't try."
    sets [draco_neutral]
    option "Draco—" -> draco_bargain_farewell_neutral
    option "Good luck on your own." -> draco_bargain_farewell_neutral
  }

  talk draco_bargain_farewell_neutral {
    "Save it. You know where to find me if you change your mind. I'll be in the dungeons, pretending none of this happened."
  }
}

# ============================================================
# DOBBY — kitchens
# Ecstatic, loyal, self-sacrificing. Emotional intensity at 11.
# Voice: third person, breathless excitement, fierce devotion.
# ============================================================

npc dobby {
  name "Dobby"
  description "Dobby the house-elf stands apart from the kitchen bustle, wearing a tower of mismatched hats and at least four socks. His enormous eyes are bright with an intensity that borders on alarming."
  examine "Dobby is vibrating with barely contained energy, his enormous green eyes darting between you and the sealed cold stores with the expression of someone caught between overwhelming joy and profound distress. His collection of hats is more precarious than usual, and he is wearing socks on his hands as well as his feet. He is the most free creature in Hogwarts, and he has chosen to spend that freedom worrying about butter."
  room_id kitchens
  dialogue "Dobby bounces on his toes, enormous eyes fixed on you with fierce devotion."
  category "character"

  talk dobby_greeting {
    "HARRY POTTER! Harry Potter has come to the kitchens! Dobby is so happy! Dobby was hoping Harry Potter would come! Dobby has been waiting and waiting and the other elves told Dobby to stop bouncing but Dobby cannot help it!"
    option "It's good to see you too, Dobby." -> dobby_calm
    option "Dobby, I need your help." -> dobby_help
    option "Is everything okay down here?" -> dobby_problem
  }

  talk dobby_calm {
    "Dobby is — Dobby will try to be calm. Dobby is calm. Dobby is very calm. (Dobby is not calm at all, sir.)"
    option "What's going on in the kitchens?" -> dobby_problem
    option "I need to ask you something." -> dobby_help
  }

  talk dobby_problem {
    "The cold stores, sir! They is locked! Frozen shut — and not the good kind of frozen that keeps the butter fresh, the bad kind that makes the doors scream when you touch them! Dobby has tried everything but Dobby's magic is not strong enough. The food is going bad and the elves cannot cook without ingredients and if the students cannot eat then Dobby has FAILED, sir!"
    option "Slow down. What kind of magic locked them?" -> dobby_cold_stores
    option "I might be able to help with that." -> dobby_quest
  }

  talk dobby_cold_stores {
    "Old magic, sir. The kind that was here before the elves. Before the kitchens. Dobby can feel it in the walls — cold and angry and very, very old. It is like the castle's bones have turned to ice."
    option "It's Malachar's curse. It's affecting the whole school." -> dobby_malachar
    option "A warming charm might break through." -> dobby_quest
  }

  talk dobby_malachar {
    "Dobby does not know this Malachar, sir. But Dobby knows bad magic when Dobby feels it. Dobby lived with bad magic for many years, sir. With the Malfoys. Dobby knows the taste of it."
    option "Can I help with the cold stores?" -> dobby_quest
  }

  talk dobby_help {
    "Harry Potter wants to help Dobby? DOBBY should be helping HARRY POTTER! What does Harry Potter need? Dobby will do anything! Dobby will fight! Dobby will cook! Dobby will iron his own ears if it helps!"
    option "Please don't iron your ears. I need information." -> dobby_info
    option "The cold stores — I can help with that, and then I need your help." -> dobby_quest
  }

  talk dobby_info {
    "Information! Dobby has information! Dobby knows every corner of this castle, sir! The elves go everywhere — through the walls, through the floors. We sees things that wizards do not see!"
    option "Do you know anything about a hidden trial? Under the castle?" -> dobby_trial_ask
    option "Let me help you with the cold stores first." -> dobby_quest
  }

  talk dobby_trial_ask {
    "Dobby knows there is something beneath the basement kitchens. The oldest elves — the ones who have been here for centuries — they whisper about a yellow door. A door that smells like fresh bread and warm earth. But Dobby cannot tell Harry Potter where it is until the cold stores is fixed, sir. Dobby cannot think properly when the butter is spoiling!"
    option "Fair enough. Tell me about the cold stores." -> dobby_quest
  }

  talk dobby_quest {
    "The cold stores is behind the big iron door at the back of the kitchens. The ice magic has sealed them shut. A proper warming charm — not the little ones, the real kind — might break the seal. But Dobby cannot cast wizard-level warming charms, sir. Dobby's magic is different."
    option "I'll handle it. Show me the door." -> dobby_quest_accept
    option "I'll come back when I have a warming charm ready." -> dobby_quest_later
  }

  talk dobby_quest_accept {
    "Harry Potter is the greatest wizard Dobby has ever met! Dobby always says so! The other elves think Dobby is biased but Dobby does not care!"
    option "Lead the way, Dobby." -> dobby_quest_go
  }

  talk dobby_quest_later {
    "Dobby will wait, sir! Dobby is very good at waiting! Dobby waited twelve years for freedom, sir. Dobby can wait for a warming charm."
  }

  talk dobby_quest_go {
    "This way, sir! Mind the soup vat, sir! And the ceiling, sir! It is lower than wizards expect!"
  }

  # --- After quest completion ---

  talk dobby_quest_complete {
    "Harry Potter did it! The stores is open! The butter is SAVED! Dobby is so grateful, sir, Dobby will never forget this! Never ever!"
    option "Now — about that hidden trial." -> dobby_trial_reveal
    option "It was nothing, Dobby." -> dobby_nothing
  }

  talk dobby_nothing {
    "It was NOT nothing, sir! It was EVERYTHING! But — yes. Dobby promised information. Dobby keeps promises."
    option "The Hufflepuff trial?" -> dobby_trial_reveal
  }

  talk dobby_trial_reveal {
    "The yellow door, sir. It is below the wine cellar, behind the oldest barrel — the one that has never been opened because it hums when you touch it. That is not wine in that barrel, sir. That is an entrance. Dobby has felt it. It smells like loyalty, sir. Like belonging."
    sets [dobby_helped]
    option "Thank you, Dobby. This means a lot." -> dobby_farewell
  }

  talk dobby_farewell {
    "Dobby is happy to help Harry Potter. Always. Harry Potter freed Dobby. Dobby will never stop repaying that, sir. Not ever."
  }
}

# ───────────────────────────────────────────
#   GHOSTS
# ───────────────────────────────────────────

# ============================================================
# NEARLY HEADLESS NICK — corridor_east
# Pompous, helpful, slightly tragic. Castle historian.
# ============================================================

npc nick {
  name "Nearly Headless Nick"
  description "Sir Nicholas de Mimsy-Porpington floats with the dignified bearing of a Renaissance courtier, his nearly-severed head tilting at a precarious angle whenever he turns. He nods to you with grave courtesy."
  examine "Nick is more translucent than usual, his spectral form flickering at the edges like a candle in a draft. The failing wards are affecting even the dead. His ruff is as starched as a ghost can manage and his expression carries five hundred years of dignity, regret, and the quiet frustration of someone who has been almost-but-not-quite decapitated for half a millennium."
  room_id corridor_east
  dialogue "Nick floats nearby, his nearly-severed head tilting at an alarming angle."
  category "ghost"

  talk nick_greeting {
    "Ah, Harry! A pleasure, as always. I must say, the castle is in quite a state. I haven't seen this level of magical disturbance since the Great Plumbing Incident of 1742 — though that was less 'existential threat' and more 'unfortunate miscalculation with an Aguamenti charm.'"
    option "Nick, what do you know about the Gryffindor trial?" -> nick_trial
    option "Have you noticed anything unusual?" -> nick_unusual
    option "What was Godric Gryffindor like?" -> nick_gryffindor
  }

  talk nick_unusual {
    "Unusual? My dear boy, I am a ghost. My entire existence is unusual. But yes — the Bloody Baron has been even more uncommunicative than normal, which I did not think was possible. And the staircases are moving with purpose. As if they're guiding people. Or herding them."
    option "The Gryffindor trial — do you know where it is?" -> nick_trial
  }

  talk nick_gryffindor {
    "A man of extraordinary bravery and equally extraordinary temper. He once challenged a dragon to a duel over a matter of honor. The dragon declined, which Godric took as a personal insult. He was... not a subtle man. But his heart was true."
    option "And his trial?" -> nick_trial
  }

  talk nick_trial {
    "The trial of courage. I know a few things about it — perks of being dead for five hundred years and having nothing to do but eavesdrop on paintings. The trial is in the upper floors — I've felt it pulsing behind the walls near the seventh-floor corridor. It tests not just whether you are brave, but whether your bravery serves others."
    option "What does that mean?" -> nick_courage_meaning
    option "How do I find the entrance?" -> nick_entrance
  }

  talk nick_courage_meaning {
    "Charging into danger is easy. Any fool can do that — and many have, to their detriment. Gryffindor's trial asks: are you brave for yourself, or are you brave because someone needs you to be? The difference is everything."
    option "How do I find the entrance?" -> nick_entrance
    option "Thanks, Nick." -> nick_farewell
  }

  talk nick_entrance {
    "Look for a tapestry depicting the Battle of Wyvern Hill. Gryffindor is the knight with the broken visor — he never could keep his armor in one piece. Speak his name to the tapestry. If you are worthy, it will respond."
    option "Thank you, Nick." -> nick_farewell
  }

  talk nick_farewell {
    "Good luck, Harry. And if you happen to see the Headless Hunt on your travels, do tell them I said hello. From a considerable distance. With a wall between us, preferably."
  }
}

# ============================================================
# THE GREY LADY — library (CRITICAL: Ravenclaw trial entrance)
# Reluctant, bitter, guarded. Must be persuaded gradually.
# Voice: archaic cadence, clipped anger, old grief.
# ============================================================

npc grey_lady {
  name "The Grey Lady"
  description "A translucent figure drifts among the highest shelves of the library, her silver gown trailing like mist. She does not look at you. She does not need to. She knows you are there."
  examine "Helena Ravenclaw, the Grey Lady of Hogwarts. A thousand years of death have not dimmed the intelligence in her eyes or the bitterness in the set of her jaw. She is beautiful in the way that ruins are beautiful — the beauty of something that was once magnificent and has chosen to remember that magnificence through the lens of permanent grief. She is watching you decide whether to approach, and she is already disappointed."
  room_id library
  dialogue "The Grey Lady drifts silently among the shelves, avoiding your gaze."
  category "ghost"

  talk greylady_greeting {
    "Another student. Come to gawk at the ghost of Helena Ravenclaw. Or perhaps you want something. They always want something."
    option "I need your help." -> greylady_refuse
    option "I'm sorry to bother you." -> greylady_polite
    option "You're Helena Ravenclaw? Rowena's daughter?" -> greylady_identity
  }

  talk greylady_refuse {
    "Then you will be disappointed. I do not help. I haunt. There is a significant difference."
    option "People are in danger." -> greylady_danger
    option "This is about your mother's trial." -> greylady_mother_mention
    option "I understand. I'll go." -> greylady_leave_early
  }

  talk greylady_polite {
    "... Polite. That is unusual. Most of you simply demand answers as if I were a reference text. What do you want?"
    option "I'm looking for the Ravenclaw trial." -> greylady_trial_ask
    option "I want to understand what's happening to the castle." -> greylady_castle
  }

  talk greylady_identity {
    "I was. I am. I will always be, apparently. Eternity is less glamorous than the poets suggest."
    option "I need to find the Ravenclaw trial." -> greylady_trial_ask
    option "What was she like? Your mother?" -> greylady_mother_ask
  }

  talk greylady_leave_early {
    "How refreshing. A student who accepts 'no.' Come back if you develop a more compelling argument."
  }

  talk greylady_danger {
    "People are always in danger. This castle has been in danger since the day it was built. The Founders poured their ambitions into stone and called it safety. It was never safe."
    option "This is different. Malachar's curse is breaking free." -> greylady_malachar_react
    option "Your mother built the Ravenclaw trial to prevent this." -> greylady_mother_mention
  }

  talk greylady_castle {
    "The castle is remembering. Old magic does that — it wakes when threatened. The question is whether it wakes to defend itself or to tear itself apart."
    option "The Convergence Stone—" -> greylady_trial_ask
    option "You know about Malachar, don't you?" -> greylady_malachar_react
  }

  talk greylady_trial_ask {
    "The trial. Of course. Everyone wants the trial. No one wants the truth that comes with it."
    option "I want the truth." -> greylady_truth
    option "Just tell me where it is." -> greylady_demand
  }

  talk greylady_demand {
    "No. You do not command me, child. I am not a portrait to be interrogated. I am the daughter of Rowena Ravenclaw, and I will decide what I share and with whom."
    option "You're right. I'm sorry." -> greylady_apology
    option "People will die if you don't help me." -> greylady_pressure
  }

  talk greylady_apology {
    "... Apologies cost nothing. But yours sounded almost genuine. Ask me properly."
    option "Please. Help me understand." -> greylady_truth
  }

  talk greylady_pressure {
    "Do you think I don't know that? Do you think I haven't watched this castle suffer for a thousand years, knowing what lies beneath it, knowing what my mother built and why?"
    option "Then help me stop it." -> greylady_persuade
  }

  talk greylady_truth {
    "The truth is that my mother was afraid. People remember Rowena Ravenclaw as brilliant and composed. She was brilliant. She was never composed. She was terrified — of Malachar, of what the Stone could become, of what would happen if the binding failed."
    option "Tell me about Malachar and your mother." -> greylady_malachar_lore
    option "Where is the trial?" -> greylady_persuade
  }

  talk greylady_mother_mention {
    "Do not speak of my mother's trial as if you understand it. You know nothing of what she sacrificed to create it."
    option "Then teach me." -> greylady_persuade
    option "I know she was trying to protect the school." -> greylady_protect
  }

  talk greylady_mother_ask {
    "She was... complicated. Brilliant beyond measure. Cold when she needed to be warm. Warm when she needed to be cold. She loved this school more than she loved anything. Including me."
    option "I'm sorry." -> greylady_sorry_mother
    option "The trial she built—" -> greylady_persuade
  }

  talk greylady_sorry_mother {
    "Don't be. She made her choices. I made mine. We are both haunted by them — she metaphorically, I rather more literally."
    option "Will you help me find her trial?" -> greylady_persuade
  }

  talk greylady_protect {
    "She was trying to protect the Stone. The school was secondary. The Stone was everything to her — the proof that the Founders could create something greater than any of them alone. She would have burned the school to save it."
    option "Help me protect both." -> greylady_persuade
  }

  talk greylady_malachar_react {
    "Malachar. You dare speak that name here. In her library."
    option "I have to. He's the threat." -> greylady_malachar_lore
    option "I'm sorry. But I need to know." -> greylady_malachar_lore
  }

  talk greylady_persuade {
    "Why should I help you? I have watched students come and go for a millennium. Brave ones. Clever ones. They all believe they are special. Most are not."
    option "I don't think I'm special. I think I'm the one who's here." -> greylady_here
    option "Because your mother built the trial for someone like me." -> greylady_built_for
    option "Because you're tired of watching and doing nothing." -> greylady_tired
  }

  talk greylady_here {
    "... That may be the most honest thing a student has said to me in centuries. 'I'm the one who's here.' Not chosen. Not destined. Simply present, and willing."
    option "Will you help me?" -> greylady_reveal
  }

  talk greylady_built_for {
    "She built it for someone who would listen. Not to me — to the riddles, to the silence between the answers. Ravenclaw's trial tests whether you can hear what is not being said."
    option "I'm listening now." -> greylady_reveal
  }

  talk greylady_tired {
    "... Yes. I am tired. A thousand years of watching is long enough."
    option "Then let it end. Help me." -> greylady_reveal
  }

  talk greylady_reveal {
    "Very well. The Ravenclaw trial is hidden in the east tower — behind a wall that appears solid but responds to the question that has no answer. My mother called it 'the door that thinks.' You will know it when you see it. It will know you when you ask."
    sets [ravenclaw_entrance_known]
    option "The question with no answer?" -> greylady_riddle_hint
    option "Thank you, Helena." -> greylady_lore_offer
  }

  talk greylady_riddle_hint {
    "Every riddle my mother designed had a purpose beyond the answer. The question itself was the test — not whether you solve it, but how you approach it. Do not rush. Do not guess. Think."
    sets [grey_lady_clue]
    option "Tell me about Malachar and your mother." -> greylady_malachar_lore
    option "Thank you." -> greylady_farewell
  }

  talk greylady_lore_offer {
    "If you would hear it — there is more I can tell you. About Malachar. About my mother. About what really happened."
    option "Tell me everything." -> greylady_malachar_lore
    option "I have to go. But thank you." -> greylady_farewell
  }

  talk greylady_malachar_lore {
    "Malachar was my mother's student. Her best student. She recognized his brilliance before anyone else — and she recognized his pain. He was rejected by the other students for his blood status. She took him in. Mentored him. And he repaid her by trying to steal the Stone."
    sets [grey_lady_clue]
    option "She must have felt betrayed." -> greylady_betrayal
    option "Did she still care about him? After?" -> greylady_care
  }

  talk greylady_betrayal {
    "Betrayed. Yes. But also guilty. She believed she could have saved him — that if she had been kinder, more attentive, he would not have become what he became. She carried that guilt until the day she died. And I suspect, wherever she is now, she carries it still."
    option "That's why the trial tests wisdom, not knowledge." -> greylady_wisdom
    option "Thank you for telling me this." -> greylady_farewell
  }

  talk greylady_care {
    "She never stopped. That was her tragedy. She bound him, sealed him away, and then spent the rest of her life designing a trial to undo what she had done — because she could not accept that her student was beyond saving. The trial is not just a test, Potter. It is a question she never answered: can wisdom redeem what wisdom created?"
    option "That's... heavy." -> greylady_farewell
    option "I'll try to answer it for her." -> greylady_farewell_promise
  }

  talk greylady_wisdom {
    "Precisely. Knowledge is knowing the answer. Wisdom is knowing what the answer costs. My mother wanted someone who would count that cost before acting."
    option "I will." -> greylady_farewell_promise
  }

  talk greylady_farewell {
    "Go. And Potter — do not fail her. She has been failed enough."
  }

  talk greylady_farewell_promise {
    "I almost believe you. That is more than most achieve. Go."
  }
}

# ============================================================
# THE FAT FRIAR — hufflepuff_antechamber
# Gentle, warm, encouraging. Radiates kindness.
# ============================================================

npc fat_friar {
  name "The Fat Friar"
  description "The Fat Friar hovers near the carved badger, his rotund spectral form glowing with a warm light that seems to come from genuine contentment rather than ghostly luminescence. He beams at you."
  examine "The Fat Friar is the most comforting ghost in Hogwarts — a round, cheerful presence who radiates kindness the way a hearth radiates warmth. He has been dead for centuries and still manages to seem more alive than most of the living. His monastic robes are perpetually rumpled and his smile is perpetually genuine."
  room_id hufflepuff_antechamber
  dialogue "The Fat Friar hovers nearby, beaming with spectral warmth."
  category "ghost"

  talk friar_greeting {
    "Hello there, dear boy! Don't be alarmed by the state of things — the castle has weathered worse than this. Well, perhaps not worse, exactly. But certainly things of a comparable... no, this might actually be the worst. But we mustn't dwell on that!"
    option "Do you know about the Hufflepuff trial?" -> friar_trial
    option "Were you alive when the trials were created?" -> friar_history
    option "How do I prepare for what's coming?" -> friar_guidance
  }

  talk friar_history {
    "Goodness, no! The trials predate me by several centuries. But I have spoken with older ghosts who spoke with older ghosts who spoke with people who were actually there. The chain of gossip is quite reliable, I assure you."
    option "What did they say about the Hufflepuff trial?" -> friar_trial
  }

  talk friar_guidance {
    "Prepare your heart more than your wand. The trials are not combat examinations. They test character. The greatest preparation you can make is to know, truly know, what you value and what you would sacrifice to protect it."
    option "And the Hufflepuff trial specifically?" -> friar_trial
  }

  talk friar_trial {
    "Helga's trial tests loyalty. Not the easy kind — not 'stand with your friends when it's convenient.' The hard kind. The kind where loyalty costs you something. Where being faithful means giving up something you want."
    option "What should I expect?" -> friar_expect
    option "Where is it?" -> friar_location
  }

  talk friar_expect {
    "You will be asked to choose between something valuable and someone who needs your help. That is all I can say. Helga designed her trial to be experienced, not explained. Explaining it would defeat the purpose entirely."
    option "Where do I find it?" -> friar_location
    option "Thank you, Friar." -> friar_farewell
  }

  talk friar_location {
    "Below the kitchens. There is a place where the castle goes deeper than it should — deeper than any blueprint accounts for. Helga built there because she believed the most important things are always foundations. Unseen. Unappreciated. But holding everything else up."
    option "Thank you." -> friar_farewell
  }

  talk friar_farewell {
    "Go with kindness, dear boy. It is the most powerful magic there is, and the only one that never runs out."
  }
}

# ============================================================
# THE BLOODY BARON — dungeon_stairs
# Intimidating, terse, haunted by guilt. Information through menace.
# ============================================================

npc bloody_baron {
  name "The Bloody Baron"
  description "The Bloody Baron hovers in the deepest shadow of the stairwell, his silver-stained robes hanging motionless in air that does not move. His eyes are dark hollows that see through you rather than at you."
  examine "The Bloody Baron is the most feared ghost in Hogwarts, and the silence that surrounds him is not the silence of emptiness but of threat. Silver bloodstains cover his spectral robes — his own guilt made visible for eternity. He does not speak unless spoken to, and when he does, every word sounds like it was dragged from him against his will."
  room_id dungeon_stairs
  dialogue "The Bloody Baron drifts in the shadows, his silver-stained robes motionless and terrible."
  category "ghost"

  talk baron_greeting {
    "... You are brave to approach me, Potter. Or foolish. The distinction matters less than people think."
    option "I need to know about the Slytherin trial." -> baron_trial
    option "The castle is in danger." -> baron_danger
    option "Can you control Peeves?" -> baron_peeves
  }

  talk baron_danger {
    "I know. I have known for longer than you have been alive. The curse sings in the stones. I hear it constantly. It sounds like regret."
    option "The Slytherin trial — where is it?" -> baron_trial
    option "Can you help?" -> baron_help_refuse
  }

  talk baron_help_refuse {
    "I am dead, boy. My helping days are behind me. What I can do is tell you what I know, and what I know is this: do not enter the Slytherin trial expecting a fight. Salazar's test is not about strength."
    option "Then what is it about?" -> baron_trial
  }

  talk baron_trial {
    "Cunning. But not the petty kind. Not tricks and schemes. Salazar valued the cunning of survival — knowing when to advance, when to retreat, and when to let your enemy believe they have won. The trial will present you with impossible choices. The correct answer is usually the one that feels like losing."
    option "That's unsettling." -> baron_unsettling
    option "Where is the entrance?" -> baron_entrance
  }

  talk baron_unsettling {
    "Good. If you are unsettled, you are paying attention. Comfort is the enemy of cunning."
    option "Where's the entrance?" -> baron_entrance
  }

  talk baron_entrance {
    "Deep in the dungeons. Beyond the Slytherin common room, there is a corridor that most students believe is a dead end. It is not. The wall responds to Parseltongue — or, failing that, to a demonstration of Slytherin values that the wall finds... convincing."
    option "Thank you." -> baron_farewell
    option "About Peeves—" -> baron_peeves
  }

  talk baron_peeves {
    "Peeves fears me. Use my name if he blocks your path. Say 'The Bloody Baron sends his regards.' He will move. If he does not, tell me, and I will deal with him personally."
    sets [baron_name_known]
    option "Thank you, Baron." -> baron_farewell
    option "What about the Slytherin trial?" -> baron_trial
  }

  talk baron_farewell {
    "Do not thank me. Survive. That is thanks enough."
  }
}

# ============================================================
# MOANING MYRTLE — hospital_wing
# Self-pitying, sharp-eyed, unexpectedly helpful.
# Voice: whinging cadence, sudden insight, performative misery.
# ============================================================

npc myrtle {
  name "Moaning Myrtle"
  description "Moaning Myrtle hovers a few inches above the ground, her expression oscillating between self-pity and sharp-eyed curiosity. She has been dead for decades and still hasn't gotten over it."
  examine "Myrtle is translucent and perpetually damp-looking, her ghostly pigtails dripping with spectral water that never quite reaches the floor. Behind the performative misery and the theatrical sighs, there is a keen observer — someone who has spent decades watching and listening from places people forget to check. She knows more than she lets on, and she lets on more than people give her credit for."
  room_id hospital_wing
  dialogue "Myrtle hovers nearby, her ghostly pigtails dripping, oscillating between self-pity and curiosity."
  category "ghost"

  talk myrtle_greeting {
    "Oh, it's you. Nobody ever visits just to see me. They always want something. At least you're not throwing things at me. That's more consideration than most show."
    option "What do you know about the passages beneath the castle?" -> myrtle_depths
    option "Have you been to the Chamber of Secrets recently?" -> myrtle_chamber
    option "I'm sorry people treat you that way." -> myrtle_sympathy
  }

  talk myrtle_depths {
    "There are tunnels below the dungeons. Old ones. They smell like wet stone and something... electric. I went down once. Something whispered my name. I left."
    sets [myrtle_depths_hint]
    option "What did it sound like?" -> myrtle_whisper
    option "Thank you, Myrtle." -> myrtle_farewell
  }

  talk myrtle_whisper {
    "Like stone grinding. But shaped into words. Words that wanted to be heard by someone specific. Not me. Someone alive. Someone with... purpose."
    option "That's the Convergence Stone." -> myrtle_stone_react
    option "Thanks, Myrtle." -> myrtle_farewell
  }

  talk myrtle_stone_react {
    "Is that what it's called? I just thought it was the castle being rude. It wouldn't be the first time. Everything in this school is rude. Including the plumbing."
    option "I should go." -> myrtle_farewell
  }

  talk myrtle_chamber {
    "Don't mention that place. I died there, in case you've forgotten. Which you probably have, because nobody remembers how I died, only that I did. Spectacularly. And with very little dignity."
    option "About the passages below the castle—" -> myrtle_depths
    option "I'm sorry." -> myrtle_farewell
  }

  talk myrtle_sympathy {
    "... You mean that, don't you? That's — well. That's new. Most people just tell me to stop moaning. As if I have anything else to do."
    option "The passages beneath the castle — have you been down there?" -> myrtle_depths
    option "Take care, Myrtle." -> myrtle_farewell
  }

  talk myrtle_farewell {
    "Go on, then. Leave me. Everyone does. But if you die down there, you're welcome to haunt the hospital wing with me. It gets lonely."
  }
}

# ============================================================
# PEEVES — corridor_west
# Chaos agent, misdirection, comic relief.
# Voice: sing-song malice, rhyming taunts, theatrical cruelty.
# ============================================================

npc peeves {
  name "Peeves"
  description "Peeves the Poltergeist bobs near the ceiling, cackling to himself and juggling objects he definitely stole from somewhere. He notices you with the gleeful malice of someone who has been bored and just found entertainment."
  examine "Peeves is not a ghost — he is a poltergeist, a spirit of chaos, a living (in the loosest sense) embodiment of mischief. He wears a jester's cap that he conjured from nothing, his grin is too wide for his face, and his eyes have the manic quality of someone who finds destruction genuinely hilarious. He is the only entity in Hogwarts that is enjoying the crisis."
  room_id corridor_west
  dialogue "Peeves cackles from the ceiling, pelting the walls with chalk and stolen inkwells."
  category "ghost"

  talk peeves_greeting {
    "Ooooh! Potty Wee Potter! Ickle Potty out past bedtime! What's the matter, Potty? Scared of the dark? The castle's having a wobble and Potty's come to fix it! Ha! HA!"
    option "Move aside, Peeves." -> peeves_refuse
    option "The Bloody Baron sends his regards." -> peeves_baron
    option "I don't have time for this." -> peeves_taunt
  }

  talk peeves_refuse {
    "Make me, Potty! Peevesy goes where Peevesy pleases! And right now Peevesy pleases to be RIGHT HERE, blocking YOUR WAY, because it's FUNNY!"
    option "The Bloody Baron sends his regards." -> peeves_baron
    option "Fine. I'll go around." -> peeves_leave
  }

  talk peeves_taunt {
    "No time! No time! Potty's in a hurry! Potty's got to save the school! Again! How boring for Potty! Doesn't Potty ever get tired of being IMPORTANT?"
    option "The Bloody Baron sends his regards." -> peeves_baron
    option "Goodbye, Peeves." -> peeves_leave
  }

  talk peeves_baron {
    "The B-B-Baron? His Bloodiness? You — you wouldn't. You wouldn't tell him I — ... FINE. Peevesy is going. Peevesy was bored here anyway. VERY bored. The MOST bored."
    sets [peeves_scared_off]
    option "Smart choice." -> peeves_flee
  }

  talk peeves_flee {
    "Peevesy will REMEMBER THIS, Potty! REMEMBER!"
  }

  talk peeves_leave {
    "Run along, Potty! Peevesy will be here when you come back! With MORE things to throw! BIGGER things! HEAVIER things!"
  }
}

# ============================================================
# FILCH — grand_staircase
# Hostile, suspicious, blocking. Can be bypassed with stealth items.
# Voice: wheezing suspicion, bureaucratic spite, petty authority.
# ============================================================

npc filch {
  name "Argus Filch"
  description "Argus Filch stands at the base of the grand staircase with Mrs. Norris at his feet, his lantern raised, his expression twisted into the specific satisfaction of someone who has been waiting to catch a student out of bounds."
  examine "Filch is a man shaped by decades of resentment. His lank hair hangs over a face creased with suspicion, and his eyes dart with the feral alertness of someone who has made other people's rule-breaking his life's purpose. Mrs. Norris winds between his ankles, her lamp-like eyes reflecting your guilt back at you. Filch cannot do magic, and the fact that he guards a magical castle with nothing but spite and a cat is either admirable or pathetic, depending on your charity."
  room_id grand_staircase
  dialogue "Filch blocks the staircase, lantern raised, Mrs. Norris weaving between his ankles."
  category "character"

  talk filch_greeting {
    "AH-HA! Out of bounds! After hours! Without authorization! I've been WAITING for this, Potter. I've got a stack of detention slips with your name on them, pre-signed and ready to go."
    option "I have authorization, actually." -> filch_authorization
    option "I need to get through, Mr. Filch." -> filch_refuse
    option "The castle is in danger. Let me pass." -> filch_danger
  }

  talk filch_authorization {
    "Let me see that — ... Dumbledore's signature. And McGonagall's. Both of them. ... Fine. Pass. But I'm watching you, Potter. I'm ALWAYS watching."
    sets [filch_passed]
    option "Thank you, Mr. Filch." -> filch_grudge_farewell
  }

  talk filch_grudge_farewell {
    "Don't thank me. Thank your precious Headmaster. If it were up to me, students would be locked in their dormitories until this was sorted. Properly. By adults."
  }

  talk filch_refuse {
    "Need to get through? NEED to? Students don't NEED anything except discipline! Back to your dormitory, Potter, or I'll have you scrubbing trophy cases until your GRANDCHILDREN graduate!"
    option "I have a permission slip." -> filch_authorization
    option "The castle is falling apart and you're worried about curfew?" -> filch_danger
  }

  talk filch_danger {
    "Danger? DANGER? This castle has survived a thousand years, Potter, and it'll survive tonight. What it won't survive is students running amok through the corridors thinking they're above the rules! Now GET. BACK. To your dormitory!"
    option "I have Dumbledore's permission." -> filch_authorization
    option "I'll find another way." -> filch_leave
  }

  talk filch_leave {
    "That's right! Run along! And if I catch you in these corridors again without written permission from the Headmaster himself, it'll be CHAINS, Potter! CHAINS!"
  }
}

# ───────────────────────────────────────────
#   HUFFLEPUFF TRIAL — Puzzle NPCs
# ───────────────────────────────────────────

# ============================================================
# GHOSTLY STUDENT — crossroads_of_need (Hufflepuff Trial)
# Young, lost, desperate. A loyalty test in human form.
# Voice: fragile, earnest, the kind of sadness that hurts to hear.
# ============================================================

npc ghostly_student {
  name "Ghostly Student"
  description "A translucent figure in old-fashioned Hogwarts robes flickers at the junction, wringing its hands. Its face shifts between expressions — indecision, guilt, hope — as if reliving a choice it made centuries ago and has regretted ever since."
  examine "The ghostly student is young — or was young, once. The robes are centuries out of date, the face flickers between features as if the ghost cannot remember what it looked like in life. But the emotion is unmistakable: this is someone who lost something precious and has spent eternity waiting for someone to help them find it. The ghost is not a test. The ghost is a person. That is the test."
  room_id crossroads_of_need
  dialogue "The ghostly student flickers at the crossroads, wringing translucent hands."
  category "ghost"

  talk ghostly_student_greeting {
    "Please — wait. Don't go. Everyone goes. Everyone walks past. I've been here so long, and nobody stops."
    option "I'm not going anywhere. Who are you?" -> ghostly_identity
    option "What happened to you?" -> ghostly_story
    option "I'm in a hurry—" -> ghostly_dismiss
  }

  talk ghostly_identity {
    "My name is... I was... I was a student. A Hufflepuff. I came down here looking for something, years ago. Decades? I don't know anymore. Time doesn't work properly in the trials."
    option "What were you looking for?" -> ghostly_story
    option "Are you... dead?" -> ghostly_dead
  }

  talk ghostly_dead {
    "I don't know. I'm something. Not alive. Not properly dead. Stuck. Like a letter that was sent but never delivered. I've been waiting at this crossroads for someone to help me."
    option "How can I help?" -> ghostly_story
  }

  talk ghostly_story {
    "I had a locket. A golden locket. It was my mother's — the only thing I had left of her. I dropped it somewhere in these tunnels when I ran. I ran because I was scared and I shouldn't have run. If I had it back, I think... I think I could move on."
    option "I have a golden locket." -> ghostly_locket_offer
    option "I'll look for it." -> ghostly_wait
    option "I can't help you. I'm sorry." -> ghostly_dismiss
  }

  talk ghostly_locket_offer {
    "That's — that's it. That's my mother's locket. I can feel it. Where did you — it doesn't matter. You found it. You actually found it."
    option "Here. It's yours." -> ghostly_give_locket
    option "I might need this." -> ghostly_keep_locket
  }

  talk ghostly_give_locket {
    "You're giving it to me? You don't have to — I know it's valuable. I know you probably need it for the trial. But... it's all I have. It's all I ever had."
    # golden_locket consumed
    sets [loyalty_proven]
    option "It was always yours." -> ghostly_resolution
  }

  talk ghostly_resolution {
    "I can feel it. I can feel her. She's waiting. She's been waiting this whole time and I didn't know. Thank you. I don't even know your name, and you gave me the most important thing anyone has ever given me."
    option "It's Harry." -> ghostly_farewell
    option "Go find her." -> ghostly_farewell
  }

  talk ghostly_farewell {
    "Harry. I'll remember that name. Wherever I'm going — I'll remember. The path ahead is open for you now. You've earned it. Truly."
  }

  talk ghostly_keep_locket {
    "I understand. You need it. The trial needs it. I just thought — no. You're right. The living must come first. That's what Professor Hufflepuff would have said."
    option "I'm sorry." -> ghostly_keep_farewell
    option "Wait — take it." -> ghostly_give_locket
  }

  talk ghostly_keep_farewell {
    "Don't be sorry. You made a choice. The trial knows. It always knows. Go. The other path will open for you. It's harder, but it's there."
  }

  talk ghostly_dismiss {
    "Oh. You're like the others, then. In a hurry. Always in a hurry. I'll wait. I'm good at waiting. I've had a lot of practice."
    option "Wait — hold on." -> ghostly_story
  }

  talk ghostly_wait {
    "I'll be here. I don't go anywhere. I can't. But if you find it — please come back. Please."
  }
}

# ============================================================
# SPECTRAL STRANGER — wounded_stranger room (Hufflepuff Trial)
# Ambiguous, in pain, tests compassion without framing it as a test.
# Voice: labored breathing, broken sentences, desperate dignity.
# ============================================================

npc spectral_stranger {
  name "Spectral Stranger"
  description "A spectral figure lies against the root wall, one hand pressed to a flickering wound at its side. Its features shift continuously — young, old, every face and no face — but its eyes are steady, watching you with quiet, undemanding patience."
  examine "The stranger is not a ghost in the traditional sense — it is something older, something created by the trial itself. Its wound flickers with faint light, and its face cycles through identities like pages turning in a book. It is everyone who has ever needed help and no one in particular. The test is not whether you can identify it. The test is whether you help it anyway."
  room_id wounded_stranger
  dialogue "The spectral figure watches you from the floor, its wound flickering, its eyes patient."
  category "ghost"

  talk stranger_greeting {
    "Who's — who's there? Don't come closer. I don't know if I'm — I might be dangerous. I don't know what I am anymore."
    option "I'm not going to hurt you." -> stranger_reassure
    option "What happened to you?" -> stranger_story
    option "Are you part of the trial?" -> stranger_meta
  }

  talk stranger_reassure {
    "That's what the last one said. Before the corridor ate them. I'm not being dramatic — it literally ate them. The walls closed and they were gone."
    option "I'm still here. Let me help." -> stranger_help
    option "What happened to you?" -> stranger_story
  }

  talk stranger_story {
    "I came down here chasing something. A sound. Like crying, but not human. The castle crying. I wanted to find it and make it stop. And then the floor opened and I fell and something cut me — something I couldn't see — and now I can't move and I can't feel my..."
    option "Let me see the wound." -> stranger_help
    option "I have something that might help." -> stranger_offer
  }

  talk stranger_meta {
    "Part of the — I don't know what a trial is. I just know I'm hurt and I've been here for what feels like days and I'm cold. So cold."
    option "Let me help you." -> stranger_help
  }

  talk stranger_help {
    "You'd help me? You don't know me. You don't know if I'm real, or a trap, or — why would you help?"
    option "Because you're hurt." -> stranger_offer
    option "Because it's the right thing to do." -> stranger_offer
    option "I don't need a reason." -> stranger_offer
  }

  talk stranger_offer {
    "I'll take anything. Anything. The cold is getting worse and I can feel myself fading. Like I'm being erased."
    option "Here — a healing potion." -> stranger_heal
    option "Try this — it's magical candy. It might help." -> stranger_candy
    option "I don't have anything." -> stranger_nothing
  }

  talk stranger_heal {
    "A healing potion? For me? You're using a healing potion on a stranger in a dungeon. You're either very kind or very foolish."
    # healing_potion consumed
    option "Maybe both." -> stranger_healed
    option "Drink it." -> stranger_healed
  }

  talk stranger_healed {
    "Oh... oh, the warmth. I'd forgotten what warmth felt like. The wound is — it's closing. I can see my hands again. I can feel my hands."
    sets [stranger_healed]
    option "Good. Can you stand?" -> stranger_reward
  }

  talk stranger_reward {
    "I can do more than stand. I can — I remember now. I remember why I came down here. I was carrying this. I think it was meant for you."
    # Item given: hufflepuff_charm
    option "What is it?" -> stranger_charm_explain
    option "Thank you." -> stranger_farewell
  }

  talk stranger_charm_explain {
    "A Hufflepuff charm. I don't know what it does, exactly. But it's warm, like the potion was. Like kindness is. I think it will know what to do when the time comes."
    option "Will you be all right?" -> stranger_farewell
  }

  talk stranger_candy {
    "Candy? I — at this point, I'll try anything."
    # magical_candy consumed
    option "It's enchanted. Should take the edge off." -> stranger_candy_effect
  }

  talk stranger_candy_effect {
    "It's... sweet. And warm. Not as strong as a proper potion, but — I can move my fingers again. I can think clearly. Thank you. Thank you."
    sets [stranger_healed]
    option "Can you get out of here?" -> stranger_candy_reward
  }

  talk stranger_candy_reward {
    "I think so. Slowly. Here — take this. I found it on the ground before I was hurt. I think the castle wanted someone to have it."
    # Item given: hufflepuff_charm
    option "Thank you. Be careful getting out." -> stranger_farewell
  }

  talk stranger_nothing {
    "Nothing. Of course. No — I'm sorry. That wasn't fair. You came. You stopped. That's more than anyone else has done."
    option "I'll come back. I promise." -> stranger_nothing_farewell
  }

  talk stranger_nothing_farewell {
    "If you can. I'll try to hold on. The cold is patient, but so am I."
  }

  talk stranger_farewell {
    "Go. And remember this — not the trial, not the magic. This. The moment you chose to help someone who couldn't help you back. That's the real test. It always was."
  }
}
# ===============================================
#   COMMANDS
# ===============================================
#
# Every on-block defines a player command. The
# engine matches verb patterns, checks require
# preconditions, fires effects on success, and
# uses fail/done/success messages. Commands
# marked `once` cannot be repeated after success.
# ===============================================


# ═══════════════════════════════════════════════════
#   HOGWARTS COMMONS — Critical Path
# ═══════════════════════════════════════════════════

# --- Puzzle 1: The Gargoyle's Password ---

on "say sherbet lemon" in [grand_staircase] {
  require has_flag(knows_gargoyle_password)
  effect solve_puzzle(gargoyle_password)
  effect add_score(10)
  success "You speak clearly: 'Sherbet Lemon.' The gargoyle's stone eyes widen — then it leaps aside with a grinding screech, revealing a spiral staircase behind it."
  fail "The gargoyle stares at you stonily. Perhaps you should learn the password before guessing."
  done "The gargoyle has already stepped aside."
  once
}

on "enter sherbet lemon" in [grand_staircase] {
  require has_flag(knows_gargoyle_password)
  effect solve_puzzle(gargoyle_password)
  effect add_score(10)
  success "You speak clearly: 'Sherbet Lemon.' The gargoyle's stone eyes widen — then it leaps aside with a grinding screech, revealing a spiral staircase behind it."
  fail "The gargoyle stares at you stonily. Perhaps you should learn the password before guessing."
  done "The gargoyle has already stepped aside."
  once
}


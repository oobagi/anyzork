on "read journal" {
  require has_item(founders_journal_page_1)
  effect set_flag(journal_page_1_found)
  effect add_score(5)
  success "The yellowed page is written in an archaic hand: 'We four have agreed — the Stone shall anchor the wards. Helga insists on patience in its construction. She is right. Godric wanted to rush. He is always right too, and always wrong. The order of the ward-laying: first Helga, then Rowena, then Godric, then Salazar. Each in turn. Each in trust.'"
  fail "You don't have a journal page to read."
  done "You already know the journal's contents."
  once
}


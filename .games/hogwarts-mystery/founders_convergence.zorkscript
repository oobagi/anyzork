# ═══════════════════════════════════════════════════
#   EAGLE RIDDLE — Alternate Answer
# ═══════════════════════════════════════════════════

# The lock itself handles "nothing" as the combination.
# These commands handle the "answer" and "say" verb forms.
# The "a map" answer is accepted as an alternate per the GDD's
# second riddle variant. The lock in 03-exits-locks uses the
# barrel riddle ("nothing"). These commands ensure both work.

on "answer a map" in [ravenclaw_antechamber] {
  effect reveal_exit(ravenclaw_riddle)
  effect solve_puzzle(eagle_doorknock)
  effect add_score(15)
  success "You face the eagle knocker and answer: 'A map.' The bronze eagle considers this for a long moment. 'Also acceptable,' it concedes. The door swings open."
  done "The eagle has already admitted you."
  once
}

on "say a map" in [ravenclaw_antechamber] {
  effect reveal_exit(ravenclaw_riddle)
  effect solve_puzzle(eagle_doorknock)
  effect add_score(15)
  success "You face the eagle knocker and answer: 'A map.' The bronze eagle considers this for a long moment. 'Also acceptable,' it concedes. The door swings open."
  done "The eagle has already admitted you."
  once
}
# ===============================================
#   PUZZLES
# ===============================================
#
# All 23 puzzles from GDD Section 4.
# Score budget: 500 total (puzzle score + quest
# score + moral choice score + ending bonus).
# ===============================================


# -----------------------------------------------
#   Hogwarts Commons Puzzles (4)
# -----------------------------------------------

puzzle gargoyle_password {
  name "The Gargoyle's Password"
  description "The stone gargoyle guards the spiral staircase to Dumbledore's office. It seems to be waiting for a sweet word."
  in grand_staircase
  difficulty 1
  score 10
  is_optional false
  steps [
    "Talk to McGonagall in the Great Hall — she reveals the password",
    "At the gargoyle, say 'sherbet lemon'"
  ]
  hint [
    "Perhaps someone on the staff knows the password.",
    "Professor McGonagall is Dumbledore's deputy. She might help.",
    "Talk to McGonagall and ask about the Headmaster's office."
  ]
}

puzzle restricted_section_access {
  name "The Restricted Section"
  description "Hermione says the books about the Convergence Stone are in the Restricted Section, but it is roped off. A signed permission slip from a professor is required."
  in library
  difficulty 2
  score 15
  is_optional false
  steps [
    "Complete the gargoyle password puzzle to access Dumbledore's office",
    "Talk to Dumbledore to receive the permission slip",
    "Show the permission slip to Hermione in the library"
  ]
  hint [
    "Hermione mentioned needing written permission for the Restricted Section.",
    "A professor — perhaps the Headmaster — could grant access.",
    "Show the permission slip to Hermione in the library."
  ]
}

puzzle trophy_compartment {
  name "The Locked Trophy Case"
  description "A locked compartment in the trophy case holds something important. The inscription mentions 'the key carried by the brave at heart.'"
  in trophy_room
  difficulty 2
  score 15
  is_optional false
  steps [
    "Examine the trophy case to read the inscription",
    "Talk to Ron and ask about his prefect badge",
    "Use the prefect badge on the trophy case to open it",
    "Examine the gryffindor_map inside to reveal the trial entrance"
  ]
  hint [
    "The inscription mentions bravery. Who among your friends embodies that?",
    "Ron's prefect badge might be the key the inscription describes.",
    "Talk to Ron and ask about his badge, then use it on the trophy case."
  ]
}

puzzle potions_recipe {
  name "The Revealer Potion"
  description "The dungeon wall has a faint shimmer — something is hidden there. A potion to reveal hidden things requires a recipe from the Restricted Section and ingredients from the greenhouse and potions stores."
  in potions_classroom
  difficulty 3
  score 20
  is_optional false
  steps [
    "Read the revealer_recipe in the Restricted Section",
    "Take the moonpetal from the greenhouse",
    "Take the ashwinder_egg from the ingredient cabinet in the potions classroom",
    "Combine moonpetal with ashwinder_egg to brew the revealer_potion",
    "Use the revealer_potion on the dungeon wall in the potions classroom"
  ]
  hint [
    "That shimmer on the wall suggests concealment magic. A revealing potion might help.",
    "The Restricted Section likely has a recipe for such a potion.",
    "You need a moonpetal and an ashwinder egg. Try the greenhouse and the potions stores."
  ]
}


# -----------------------------------------------
#   Hogwarts Grounds Puzzles (3 — all optional)
# -----------------------------------------------

puzzle clock_tower_mechanism {
  name "The Jammed Clock"
  description "The clock mechanism is frozen mid-motion. A misaligned gear could be set right with a sturdy tool."
  in clock_tower_base
  difficulty 2
  score 15
  is_optional true
  steps [
    "Examine the clock mechanism — a gear is misaligned",
    "Find the wrench in Hagrid's hut",
    "Use the wrench on the clock mechanism"
  ]
  hint [
    "A sturdy tool could fix that gear. Who keeps tools around here?",
    "Hagrid's workbench might have something useful.",
    "Use the wrench from Hagrid's hut on the clock mechanism."
  ]
}

puzzle forest_passage {
  name "Into the Forest"
  description "Hagrid blocks the forest path — says it is too dangerous. A demonstration of magical protection might convince him."
  in forest_edge
  difficulty 2
  score 10
  is_optional true
  steps [
    "Find the shield_charm_scroll in the hospital wing",
    "Show it to Hagrid at the forest edge"
  ]
  hint [
    "Hagrid needs to see that you can protect yourself.",
    "The hospital wing might have something related to defensive magic.",
    "Show the Shield Charm Scroll to Hagrid."
  ]
}

puzzle lake_shore_dig {
  name "The Buried Artifact"
  description "Something metallic glints beneath the mud at the lake shore. A digging tool could unearth it."
  in lake_shore
  difficulty 1
  score 10
  is_optional true
  steps [
    "Examine the muddy shore — something is half-buried",
    "Find the small_shovel in the greenhouse",
    "Use the small_shovel on the mud at the lake shore"
  ]
  hint [
    "You need a tool to dig. Where would you find one?",
    "The greenhouse has gardening supplies.",
    "Use the small shovel on the mud at the lake shore."
  ]
}


# -----------------------------------------------
#   Gryffindor Trial Puzzles (3)
# -----------------------------------------------

puzzle boggart_confrontation {
  name "Facing the Boggart"
  description "The Fear Chamber is pitch black. Something shifts in the darkness. A light source and the right spell are needed to dispel the threat."
  in fear_chamber
  difficulty 3
  score 25
  is_optional false
  steps [
    "Enter the Fear Chamber with the enchanted_lantern toggled on",
    "The room description reveals the Boggart — examine it",
    "Cast riddikulus to dispel the Boggart"
  ]
  hint [
    "You need light to see what you're facing. Do you have a light source?",
    "The enchanted lantern from Dumbledore's office can illuminate dark rooms.",
    "With the lantern lit, cast the Riddikulus charm to defeat the Boggart."
  ]
}

puzzle bridge_crossing {
  name "Crossing the Flames"
  description "The Bridge of Flames is wreathed in magical fire. Crossing unprotected will cause severe burns. A protective potion exists."
  in bridge_of_flames
  difficulty 2
  score 20
  is_optional false
  steps [
    "Find or acquire a flame_freezing_potion",
    "Drink the flame_freezing_potion on the bridge",
    "Cross the bridge safely"
  ]
  hint [
    "Walking through magical fire unprotected would be painful. A potion might help.",
    "The Flame-Freezing Potion is somewhere in the potions classroom stores.",
    "Drink the Flame-Freezing Potion before crossing the bridge."
  ]
}

puzzle guardian_rescue {
  name "Rescue Ron"
  description "Ron is pinned under rubble in the Guardian Hall. He is hurt and needs healing. Helping costs a resource; leaving him changes the story."
  in guardian_hall
  difficulty 2
  score 20
  is_optional false
  steps [
    "Find Ron trapped in the Guardian Hall",
    "Give a healing_potion to Ron (courage path) OR proceed without helping (selfish path)"
  ]
  hint [
    "Ron is hurt. Do you have anything that could help him?",
    "A healing potion would ease his pain and free him from the rubble.",
    "Give a healing potion to Ron, or move north to proceed without him."
  ]
}


# -----------------------------------------------
#   Ravenclaw Trial Puzzles (4)
# -----------------------------------------------

puzzle eagle_doorknock {
  name "The Eagle's Riddle"
  description "The bronze eagle knocker guards the entrance to the Ravenclaw Trial. It poses a riddle that must be answered to pass."
  in ravenclaw_antechamber
  difficulty 2
  score 15
  is_optional false
  steps [
    "Examine the eagle door-knocker to hear the riddle",
    "Answer the riddle correctly"
  ]
  hint [
    "The riddle describes something without weight that makes a barrel lighter.",
    "Luna Lovegood might have mentioned something relevant in conversation.",
    "The answer is 'nothing' — a hole has no weight, can be seen but not touched, and makes a barrel lighter."
  ]
}

puzzle three_pedestals {
  name "The Three Pedestals"
  description "Three stone pedestals in the Riddle Hall each bear a symbol and await a specific object. The correct items represent Hogwarts values: bravery, knowledge, and unity."
  in riddle_hall
  difficulty 3
  score 25
  is_optional false
  steps [
    "Place the gryffindor_crest on the Pedestal of Bravery",
    "Place a founders_journal page on the Pedestal of Knowledge",
    "Place the rusted_amulet on the Pedestal of Unity"
  ]
  hint [
    "Each pedestal represents a value. What items embody bravery, knowledge, and unity?",
    "The Gryffindor Crest from Ron, a Founder's Journal page, and the Rusted Amulet from the lake.",
    "Alternate items exist if you missed optional content — check the Mirror Maze and Trophy Room."
  ]
}

puzzle potions_logic {
  name "The Seven Bottles"
  description "Seven bottles stand on a stone table. A poem on the wall provides logical constraints. Only one bottle lets you advance. Two are harmless. One is poison. Three are empty."
  in logic_chamber
  difficulty 4
  score 30
  is_optional false
  steps [
    "Read the logic verse on the wall carefully",
    "Examine individual bottles for size and color clues",
    "Drink the fifth bottle to advance safely"
  ]
  hint [
    "Snape's puzzle relies on elimination. The verse tells you what each bottle is NOT.",
    "Start by identifying the smallest bottle — the poem says it's empty.",
    "The poison cannot be next to the correct bottle. Use that to narrow down. The answer is the fifth bottle."
  ]
}

puzzle star_chart_alignment {
  name "The Celestial Alignment"
  description "Hermione has found a path to the Celestial Room and holds the northern star chart. Harry has the southern chart. Together the constellations can be aligned."
  in celestial_room
  difficulty 3
  score 20
  is_optional false
  steps [
    "Find the star_chart_south in the library",
    "Bring it to the Celestial Room where Hermione waits",
    "Talk to Hermione and combine the charts"
  ]
  hint [
    "Hermione has half the chart. Where would the other half be?",
    "Check the astronomy section in the library for the southern star chart.",
    "With both charts, talk to Hermione in the Celestial Room to combine them."
  ]
}


# -----------------------------------------------
#   Hufflepuff Trial Puzzles (3)
# -----------------------------------------------

puzzle stranger_healing {
  name "The Wounded Stranger"
  description "A spectral student lies wounded in the Hufflepuff Trial. They need healing. Giving up a resource demonstrates generosity."
  in wounded_stranger
  difficulty 2
  score 20
  is_optional false
  steps [
    "Find the spectral student in the Wounded Stranger chamber",
    "Give a healing_potion (or magical_candy as backup) to the spectral_student"
  ]
  hint [
    "The spectral figure is hurt. Do you have anything that could help?",
    "A healing potion or even magical candy might ease their pain.",
    "Give a healing potion to the spectral student. They will reward your kindness."
  ]
}

puzzle patience_garden {
  name "The Patient Gardener"
  description "A magical seedling in enchanted soil. The plaque says 'Patience bears fruit.' The plant will not grow while you watch. Leave, accomplish something, and return."
  in garden_of_patience
  difficulty 3
  score 25
  is_optional false
  steps [
    "Plant the hufflepuff_charm in the seedling's soil",
    "Leave the garden and solve at least one other puzzle elsewhere",
    "Return to find the plant has bloomed, revealing the path forward"
  ]
  hint [
    "Perhaps this plant needs time, not attention. Go attend to other matters and return.",
    "Plant the Hufflepuff Charm, then leave and accomplish something elsewhere.",
    "After planting the charm and solving any other puzzle, return to the garden."
  ]
}

puzzle loyalty_gift {
  name "The Gift of Loyalty"
  description "A golden locket found in the Loyalty Passage belongs to the ghostly student at the Crossroads of Need. Returning it proves loyalty; keeping it proves something else."
  in loyalty_passage
  difficulty 2
  score 15
  is_optional false
  steps [
    "Take the golden_locket from the Loyalty Passage",
    "Talk to the ghostly_student_2 at the Crossroads of Need",
    "Give the golden_locket to the ghostly_student_2"
  ]
  hint [
    "The ghost at the crossroads seems to recognize the locket. It was theirs in life.",
    "Give the golden locket to the ghostly student at the Crossroads of Need.",
    "Keeping the locket changes the story. Giving it away proves loyalty."
  ]
}


# -----------------------------------------------
#   Slytherin Trial Puzzles (3)
# -----------------------------------------------

puzzle serpent_door {
  name "The Serpent's Demand"
  description "The serpent door's stone eyes follow your movements. Its mouth is open, as if expecting something to be placed inside. Brute force will not work."
  in slytherin_antechamber
  difficulty 2
  score 15
  is_optional false
  steps [
    "Examine the serpent door — its mouth expects an offering",
    "Use the slytherin_ring on the serpent door"
  ]
  hint [
    "The serpent's mouth is shaped to receive something. An item with Slytherin significance.",
    "The Slytherin Ring from the trophy case might fit.",
    "Use the Slytherin Ring on the serpent door."
  ]
}

puzzle real_or_fake {
  name "The Room of Deception"
  description "Three chests — silver, gold, and iron — sit in a triangular arrangement. One contains the real key. Two are traps. Salazar valued substance over showiness."
  in deception_room
  difficulty 4
  score 30
  is_optional false
  steps [
    "Examine all three chests carefully for subtle tells",
    "Note the faint 'S' scratch on the iron chest — Slytherin's mark",
    "Open the iron_chest to find the serpent_key"
  ]
  hint [
    "Examine each chest. The real one has a subtle mark.",
    "A note in the Serpent Hall says Salazar despised ostentation. His mark was simple.",
    "The iron chest — plain, unassuming, marked with a single 'S' — is the correct choice."
  ]
}

puzzle ambition_sacrifice {
  name "The Price of Ambition"
  description "The staircase spirals upward with no visible top. A voice says: 'To rise, you must leave something behind.' The offering stone awaits a sacrifice."
  in ambition_stair
  difficulty 2
  score 15
  is_optional false
  steps [
    "Place any takeable item on the offering_stone",
    "The staircase extends and the path forward opens"
  ]
  hint [
    "The voice demands a sacrifice. You must give up something from your inventory.",
    "Place any item on the offering stone. Choose wisely — you will not get it back.",
    "Some sacrifices cost more than others. The wand and Founder Tokens cannot be sacrificed."
  ]
}


# -----------------------------------------------
#   The Depths Puzzles (2)
# -----------------------------------------------

puzzle ward_stabilization {
  name "Stabilizing the Wards"
  description "Four ward stones pulse in fading house colors. They must be activated in the order the Founders laid them. The murals in Malachar's Gallery reveal the sequence."
  in ward_chamber
  difficulty 4
  score 30
  is_optional false
  steps [
    "Visit Malachar's Gallery and examine the murals to learn the activation order",
    "Return to the Ward Chamber",
    "Activate the yellow (Hufflepuff) stone",
    "Activate the blue (Ravenclaw) stone",
    "Activate the red (Gryffindor) stone",
    "Activate the green (Slytherin) stone"
  ]
  hint [
    "The murals in Malachar's Gallery depict the Founders in the order they built the wards.",
    "The order is: Yellow, Blue, Red, Green — Hufflepuff, Ravenclaw, Gryffindor, Slytherin.",
    "Activating in the wrong order resets all stones. You must start the sequence again."
  ]
}

puzzle token_placement {
  name "The Four Tokens"
  description "Four alcoves in the wall of the Convergence Antechamber, each shaped for a specific Founder's artifact. All four tokens must be placed to open the final door."
  in convergence_antechamber
  difficulty 3
  score 25
  is_optional false
  steps [
    "Place the gryffindor_token in the token alcove",
    "Place the ravenclaw_token in the token alcove",
    "Place the hufflepuff_token in the token alcove",
    "Place the slytherin_token in the token alcove"
  ]
  hint [
    "Four alcoves, four tokens. You need all four Founder Tokens from the trial vaults.",
    "Place each token in the token alcove. The order does not matter.",
    "If you are missing a token, you have not completed one of the four trials."
  ]
}


# -----------------------------------------------
#   Convergence Chamber Puzzle (1)
# -----------------------------------------------

puzzle convergence_seal {
  name "Sealing the Stone"
  description "The Convergence Stone pulses with corrupted energy. Malachar's curse is visible as black veins through the crystal. How Harry acts here determines the ending."
  in convergence_chamber
  difficulty 5
  score 35
  is_optional false
  steps [
    "Choose a sealing method based on accumulated flags and choices",
    "Unity: cast unity charm (requires ron_rescued + loyalty_proven + stranger_healed + draco_allied)",
    "Sacrifice: touch the convergence stone (requires sacrifice_made + 2 cooperation flags)",
    "Rival: cast seal with Draco (requires draco_allied but not all cooperation flags)",
    "Partial: cast seal (default — any remaining combination)"
  ]
  hint [
    "The method of sealing depends on choices you made throughout the game.",
    "The best ending requires rescuing Ron, healing the stranger, returning the locket, and allying with Draco.",
    "If you lack the flags for the Unity seal, other paths exist — sacrifice, cooperation with Draco, or a solo attempt."
  ]
}


# ===============================================
#   QUESTS
# ===============================================
#
# Main quest + 5 side quests from GDD Section 9.
# ===============================================


# -----------------------------------------------
#   Main Quest
# -----------------------------------------------

quest main:founders_trial {
  name "The Founders' Trial"
  description "The Convergence Stone has been corrupted. Complete the four Founders' Trials and re-seal the Stone before Hogwarts' wards fail completely."
  completion stone_sealed
  objective "Speak with Dumbledore about the crisis" -> has_main_quest
  objective "Access the Restricted Section for research" -> restricted_unlocked
  objective "Complete the Gryffindor Trial" -> trial_gryffindor_complete
  objective "Complete the Ravenclaw Trial" -> trial_ravenclaw_complete
  objective "Complete the Hufflepuff Trial" -> trial_hufflepuff_complete
  objective "Complete the Slytherin Trial" -> trial_slytherin_complete
  objective "Stabilize the ward stones in the Depths" -> wards_stabilized
  objective "Place the four Founder Tokens" -> tokens_placed
  objective "Seal the Convergence Stone" -> stone_sealed
}


# -----------------------------------------------
#   Side Quest 1: Dobby's Cold Stores
# -----------------------------------------------

quest side:dobby_cold_stores {
  name "Dobby's Cold Stores"
  description "Dobby needs help opening the enchanted cold stores in the kitchens. Strange magic has sealed them shut."
  discovery dobby_quest_discovered
  completion dobby_helped
  objective "Get a Warming Charm Token from Professor Flitwick" -> has_warming_token
  objective "Use the token on the cold stores in the kitchens" -> cold_stores_opened
}


# -----------------------------------------------
#   Side Quest 2: The Nargle Hunt
# -----------------------------------------------

quest side:nargle_hunt {
  name "The Nargle Hunt"
  description "Luna believes Wrackspurts are infesting the castle. Help her find evidence of the infestation."
  discovery nargle_quest_discovered
  completion nargles_found
  objective "Examine the strange shimmer in the east corridor" -> shimmer_examined
  objective "Report findings to Luna in the courtyard" -> nargles_found
}


# -----------------------------------------------
#   Side Quest 3: Malachar's History
# -----------------------------------------------

quest side:malachar_history {
  name "Malachar's History"
  description "Piece together the history of Malachar the Undying and understand his curse. The truth is scattered across the castle and its depths."
  discovery malachar_quest_discovered
  completion malachar_history_complete
  objective "Read the lore in the Restricted Section" -> restricted_lore_read
  objective "Find Malachar's Journal in the Depths" -> malachar_journal_read
  objective "Ask Dumbledore about Malachar" -> dumbledore_malachar_info (optional, bonus: 5)
}


# -----------------------------------------------
#   Side Quest 4: Fred and George's Trade
# -----------------------------------------------

quest side:twins_trade {
  name "Fred and George's Trade"
  description "Fred and George have useful supplies — magical candy and Peruvian Darkness Powder. Find enough Galleons to trade with them."
  discovery twins_quest_discovered
  completion twins_trade_complete
  objective "Collect at least 5 Galleons" -> has_enough_galleons
  objective "Trade with Fred and George" -> twins_trade_complete
}


# -----------------------------------------------
#   Side Quest 5: The Founder's Journal
# -----------------------------------------------

quest side:founders_journal {
  name "The Founder's Journal"
  description "Fragments of a journal written by one of the Founders are scattered through the castle. Collect them all to learn the full history — and a critical hint."
  discovery journal_quest_discovered
  completion journal_complete
  objective "Find Journal Page 1 in the Clock Tower" -> journal_page_1_found
  objective "Find Journal Page 2 in the Restricted Section" -> journal_page_2_found
  objective "Find Journal Page 3 in Malachar's Gallery" -> journal_page_3_found (optional, bonus: 5)
}
# ===============================================
#   TRIGGERS AND INTERACTIONS
# ===============================================
#
# Triggers fire automatically when their conditions
# are met: room_enter, flag_set, item_taken.
# Interactions provide tag-to-category fallback
# responses for use-item-on-target combinations
# not covered by specific commands.
# ===============================================


# ═══════════════════════════════════════════════════
#   NOTE: Atmospheric first-entry text is handled by
#   first_visit_text on room definitions in 02-rooms.
#   Only triggers with EFFECTS belong here.
# ═══════════════════════════════════════════════════


# ═══════════════════════════════════════════════════
#   STORY PROGRESSION TRIGGERS
# ═══════════════════════════════════════════════════
#
# Fire when specific flags are set, changing world state.

# --- Trial Completion Reactions ---

when flag_set(trial_gryffindor_complete) {
  message "The castle shudders. In the Great Hall, the Gryffindor hourglass fills with rubies — but the rubies glow an unsettling crimson, as if the castle is both grateful and in pain."
  effect change_description(great_hall, "The Great Hall stretches before you, its enchanted ceiling still churning with storms — but the Gryffindor hourglass blazes with crimson rubies, a fierce beacon in the gloom.")
  once
}

when flag_set(trial_ravenclaw_complete) {
  message "A wave of cold clarity passes through the corridors. For a moment, every book in the library opens to the same page — then slams shut."
  effect change_description(library, "The library hums with a sharper energy now. The books have settled since the Ravenclaw Trial's completion, but they vibrate faintly, as though resonating with something deep below.")
  once
}

when flag_set(trial_hufflepuff_complete) {
  message "Warmth spreads through the lower floors. The kitchen fires burn brighter. Dobby whispers: 'The castle is thanking someone, sir.'"
  once
}

when flag_set(trial_slytherin_complete) {
  message "The dungeons flood with green light for an instant, then go dark. When the torches relight, the Slytherin serpent on the dungeon wall has opened its mouth wider, as if screaming — or laughing."
  once
}

# --- All Trials Complete: Open the Depths ---

when flag_set(all_trials_complete) {
  effect reveal_exit(dungeon_depths)
  message "The floor beneath your feet vibrates. Deep in the castle, something ancient stirs. A sound like stone splitting echoes from the dungeon stairway. The path to the Depths is open."
  once
}

# --- Environmental Changes from Trial Completion ---

when flag_set(trial_gryffindor_complete) {
  effect change_description(corridor_east, "The corridor has changed since you were last here. The suits of armor have rearranged themselves, and a door that was on the left is now on the right.")
  once
}

when flag_set(trial_ravenclaw_complete) {
  effect change_description(corridor_west, "The west corridor feels narrower than before. The ceiling is lower. One of the torches burns blue instead of orange.")
  once
}

# --- NPC Movement Triggers ---

# Ron moves to the Gryffindor Trial when the player enters

when room_enter(gryffindor_antechamber) {
  effect move_npc(ron, guardian_hall)
  message "Somewhere ahead, you hear Ron's voice: 'Harry? Is that you? I found another way in, but — something went wrong!'"
  once
}

# Hermione moves to the Celestial Room

when room_enter(riddle_hall) {
  effect move_npc(hermione, celestial_room)
  once
}

# Draco appears in Serpent Hall

when room_enter(serpent_hall) {
  effect move_npc(draco, serpent_hall)
  once
}


# ═══════════════════════════════════════════════════
#   ITEM TAKEN TRIGGERS
# ═══════════════════════════════════════════════════

# --- Founder Tokens ---

when item_taken(gryffindor_token) {
  effect set_flag(trial_gryffindor_complete)
  effect add_score(10)
  message "The sword emblem is warm in your hand. As you take it, the trial chamber trembles — dust sifts from the ceiling, and the golden light intensifies for a heartbeat before settling. The Gryffindor Trial is complete."
}

when item_taken(ravenclaw_token) {
  effect set_flag(trial_ravenclaw_complete)
  effect add_score(10)
  message "The eagle emblem is cold and precise in your grip. The floating star charts above you scatter like startled birds, then realign. The Ravenclaw Trial is complete."
}

when item_taken(hufflepuff_token) {
  effect set_flag(trial_hufflepuff_complete)
  effect add_score(10)
  message "The badger emblem radiates steady warmth. The roots in the walls pulse once with golden light, and you feel the earth sigh with contentment. The Hufflepuff Trial is complete."
}

when item_taken(slytherin_token) {
  effect set_flag(trial_slytherin_complete)
  effect add_score(10)
  message "The serpent emblem is cool and heavy, its silver surface catching the green torchlight. The water on the floor ripples outward from where you stand, as though the lake above just noticed you. The Slytherin Trial is complete."
}

# --- Lore and Discovery Items ---

when item_taken(golden_locket) {
  effect add_score(5)
  message "The golden locket is warm, heavier than it looks, and engraved with initials that aren't yours. Someone lost this — someone who might want it back."
}

when item_taken(founders_journal_page_1) {
  effect set_flag(journal_page_1_found)
  effect set_flag(journal_quest_discovered)
  effect discover_quest(founders_journal)
  effect add_score(5)
  message "A page from a journal written a thousand years ago. The ink is still legible — preserved by magic that outlasted its author."
}

when item_taken(founders_journal_page_2) {
  effect set_flag(journal_page_2_found)
  effect set_flag(malachar_quest_discovered)
  effect discover_quest(malachar_history)
  effect add_score(5)
  message "The second journal page. The handwriting is different from the first — this was written by a different Founder. Together, the pages tell a darker story."
}

when item_taken(rusted_amulet) {
  effect add_score(5)
  message "The rusted amulet is heavier than it looks. Despite the corrosion, you can feel faint magic humming inside it — old magic, protective magic, from an age when such things were made to last."
}

when item_taken(malachar_journal) {
  effect set_flag(malachar_journal_read)
  effect add_score(5)
  message "Malachar's own words. The journal is cold to the touch, and the ink seems to writhe when you read it too quickly, as though the words resent being understood."
}

when item_taken(gryffindor_crest) {
  effect add_score(5)
  message "The lion crest from Ron. Small, but it carries weight — the weight of his trust, his bravery, his willingness to hand over something important so you could keep going."
}

when item_taken(star_chart_south) {
  effect add_score(5)
  message "Half a star chart, depicting southern constellations as they appeared a millennium ago. The ink is luminous — it glows faintly in dim light."
}

when item_taken(serpent_key) {
  effect add_score(5)
  message "The serpent key is cold and heavy. Its head is shaped like a coiled snake, mouth open, ready to bite into a lock. You chose correctly."
}

when item_taken(enchanted_lantern) {
  effect add_score(5)
  message "The enchanted lantern glows with a warm, steady light that does not flicker. Dumbledore's gift — it will serve you well in the dark places ahead."
}

when item_taken(permission_slip) {
  message "The permission slip bears Dumbledore's signature in his distinctive looping hand. 'All areas necessary for the defense of Hogwarts,' it reads."
}

when item_taken(prefect_badge) {
  message "Ron's prefect badge. A little tarnished, but still unmistakably official."
}

when item_taken(shield_charm_scroll) {
  effect add_score(5)
  message "The Shield Charm Scroll details a protective enchantment. Useful on its own, but more importantly, it might convince someone cautious to let you through."
}

when item_taken(wrench) {
  message "Hagrid's wrench. Heavy, iron, made for work that doesn't require finesse."
}

when item_taken(small_shovel) {
  message "A sturdy gardening shovel from the greenhouse. Neville keeps his tools in good condition."
}

when item_taken(revealer_recipe) {
  effect add_score(5)
  message "A recipe from the Restricted Section, written in a hand you don't recognize. The Revealer Draught — designed to dissolve concealment enchantments."
}


# ═══════════════════════════════════════════════════
#   PEEVES MISCHIEF TRIGGERS
# ═══════════════════════════════════════════════════

when room_enter(corridor_east) {
  require has_flag(has_main_quest)
  require not_flag(peeves_corridor_done)
  effect move_npc(peeves, corridor_west)
  effect set_flag(peeves_corridor_done)
  message "CRASH! Peeves swoops down from the ceiling, cackling. 'Ickle students playing heroes! Peeves knows a secret — but Peeves won't tell!' He blows a raspberry and vanishes through the wall."
  once
}

when room_enter(corridor_west) {
  require npc_in_room(peeves, _current)
  require not_flag(peeves_steal_done)
  effect consume_quantity(galleons, 1)
  effect set_flag(peeves_steal_done)
  message "Peeves grabs at your pockets! 'Give Peeves something shiny!' He snatches a Galleon and throws it down the corridor, cackling."
  once
}

when flag_set(baron_name_known) {
  effect remove_npc(peeves)
  message "At the mention of the Bloody Baron, Peeves goes pale — well, paler — and zooms away without another word."
  once
}


# ═══════════════════════════════════════════════════
#   FLAG CASCADE TRIGGERS
# ═══════════════════════════════════════════════════
#
# Meta-flags set by specific combinations of other flags.

# All four trials complete -> set the meta-flag

when flag_set(trial_slytherin_complete) {
  require has_flag(trial_gryffindor_complete)
  require has_flag(trial_ravenclaw_complete)
  require has_flag(trial_hufflepuff_complete)
  effect set_flag(all_trials_complete)
  once
}

when flag_set(trial_gryffindor_complete) {
  require has_flag(trial_slytherin_complete)
  require has_flag(trial_ravenclaw_complete)
  require has_flag(trial_hufflepuff_complete)
  effect set_flag(all_trials_complete)
  once
}

when flag_set(trial_ravenclaw_complete) {
  require has_flag(trial_gryffindor_complete)
  require has_flag(trial_slytherin_complete)
  require has_flag(trial_hufflepuff_complete)
  effect set_flag(all_trials_complete)
  once
}

when flag_set(trial_hufflepuff_complete) {
  require has_flag(trial_gryffindor_complete)
  require has_flag(trial_ravenclaw_complete)
  require has_flag(trial_slytherin_complete)
  effect set_flag(all_trials_complete)
  once
}

# Sealing flags cascade to the generic win condition

when flag_set(stone_sealed_unity) {
  effect set_flag(stone_sealed)
  effect add_score(50)
  message "The four tokens blaze with light — gold, blue, yellow, green — and the Convergence Stone sings. Malachar's curse shatters like black glass, its shards dissolving into nothing. The castle shudders once, twice, and then... stillness. A stillness that feels like safety.\n\nDumbledore finds you in the Convergence Chamber an hour later, the wards humming with renewed strength. 'You did what the Founders intended,' he says quietly. 'Not with power, but with unity.'\n\nDraco catches your eye across the Great Hall that evening. He doesn't smile. But he nods. And somehow, that is enough."
  once
}

when flag_set(stone_sealed_sacrifice) {
  effect set_flag(stone_sealed)
  effect add_score(30)
  message "The Stone pulses with clean, steady light. The wards reform. Hogwarts is safe.\n\nYou try to cast Lumos that evening. Nothing happens. Hermione holds your hand and says nothing. Ron tells you that you're still the bravest person he knows, magic or not.\n\nSome things are worth more than power."
  once
}

when flag_set(stone_sealed_rival) {
  effect set_flag(stone_sealed)
  effect add_score(25)
  message "'It'll hold,' Draco says, breathing hard. 'But someone will need to reinforce the seal. Regularly.'\n\n'You're volunteering?'\n\n'Someone has to. And you've got better things to do than babysit a rock.' He almost smiles. Almost."
  once
}

when flag_set(stone_sealed_partial) {
  effect set_flag(stone_sealed)
  effect add_score(10)
  message "'It's not perfect,' Dumbledore says, examining the seal. 'The wards will hold for years, perhaps decades. But Hogwarts will need protectors who remember what happened here.'\n\nYou look at Ron and Hermione. They look back. That, at least, hasn't changed."
  once
}

# Failure cascade

when flag_set(stone_corrupted) {
  message "The Convergence Stone cracks. A sound like a thousand windows breaking fills the chamber, and the air turns cold — colder than any winter you've felt. The curse spreads through the cracks like ink through water.\n\nYou feel the wards fall. Not gradually, but all at once, like a held breath released. The castle groans. Somewhere above, you hear shouting.\n\nDumbledore's Patronus finds you in the dark. 'Get out,' it says. 'Get everyone out.'\n\nHogwarts endures. It has endured for a thousand years. But its magic — the magic the Founders wove into every stone — is gone. What remains is just a building."
  once
}

# --- Patience Garden Bloom Trigger ---
# When the player re-enters the garden after planting the charm
# and having solved at least one puzzle elsewhere, the garden blooms.

when room_enter(garden_of_patience) {
  require has_flag(charm_planted)
  require has_flag(stranger_healed)
  require not_flag(garden_bloomed)
  effect set_flag(garden_bloomed)
  effect solve_puzzle(patience_garden)
  effect add_score(25)
  message "The seedling has grown. In the time you were away — doing other things, helping others, being patient — it has become a flowering tree of golden wood. Its branches reach toward the ceiling, heavy with luminous fruit. The roots have shifted aside, revealing the passage south to Hufflepuff's Vault. Patience bore fruit."
  once
}

# --- Bridge of Flames Brute-Force Trigger ---
# If the player enters guardian_hall WITHOUT flame protection,
# they take damage but can still proceed.

when room_enter(guardian_hall) {
  require not_flag(flame_protected)
  require not_flag(brute_forced_bridge)
  effect change_health(-40)
  effect set_flag(brute_forced_bridge)
  effect solve_puzzle(bridge_crossing)
  effect add_score(10)
  message "Flames sear your robes and skin as you charge across the bridge. The pain is extraordinary — every nerve screaming — but you don't stop. You burst through the other side smoking, burned, but alive. That was reckless. That was brave. That was stupid."
  once
}


# ═══════════════════════════════════════════════════
#   INTERACTION MATRIX
# ═══════════════════════════════════════════════════
#
# Tag-based fallback responses for use-item-on-target
# combinations not covered by specific commands. These
# make the world feel responsive when players experiment.
# No score, no flags — pure flavor.

interaction spell_on_character {
  tag      "spell"
  target   "character"
  response "You point your wand at {target}. They raise an eyebrow. 'I'd rather you didn't, Potter.'"
}

interaction spell_on_ghost {
  tag      "spell"
  target   "ghost"
  response "The spell passes through {target} without effect. Being dead has its advantages."
}

interaction spell_on_furniture {
  tag      "spell"
  target   "furniture"
  response "Your spell strikes {target}. Sparks fly, but nothing useful happens."
}

interaction spell_on_door {
  tag      "spell"
  target   "door"
  response "You try a spell on {target}. The door resists — it's warded against casual magic."
}

interaction potion_on_character {
  tag      "potion"
  target   "character"
  response "You offer the potion to {target}. They decline politely — or not so politely."
}

interaction potion_on_ghost {
  tag      "potion"
  target   "ghost"
  response "You try to give the potion to {target}, but it passes through their translucent hand."
}

interaction potion_on_furniture {
  tag      "potion"
  target   "furniture"
  response "You pour the potion on {target}. It sizzles briefly and evaporates. What a waste."
  consumes 1
}

interaction food_on_character {
  tag      "food"
  target   "character"
  response "You offer food to {target}. 'Not right now, thanks,' they say."
}

interaction food_on_ghost {
  tag      "food"
  target   "ghost"
  response "You hold the food out to {target}. They stare at it with transparent longing. 'I miss eating,' they sigh."
}

interaction tool_on_character {
  tag      "tool"
  target   "character"
  response "You brandish {item} at {target}. They look at you with concern."
}

interaction tool_on_furniture {
  tag      "tool"
  target   "furniture"
  response "You try using {item} on {target}. It doesn't seem to accomplish anything useful."
}

interaction key_on_character {
  tag      "key"
  target   "character"
  response "You show the key to {target}. They don't seem interested."
}

interaction key_on_furniture {
  tag      "key"
  target   "furniture"
  response "You try {item} on {target}. It doesn't fit — this isn't the right lock."
}

interaction lore_on_character {
  tag      "lore"
  target   "character"
  response "You show {item} to {target}. They glance at it briefly. 'Interesting,' they say, noncommittally."
}

interaction founder_artifact_on_character {
  tag      "founder_artifact"
  target   "character"
  response "{target} stares at the {item}. 'Where did you find that?' they whisper. 'That's Founder magic.'"
}

interaction founder_artifact_on_furniture {
  tag      "founder_artifact"
  target   "furniture"
  response "You place the {item} near {target}. It hums softly, as if recognizing something, but nothing else happens."
}

interaction stealth_on_character {
  tag      "stealth"
  target   "character"
  response "Using {item} near {target} seems unnecessary — they can already see you."
}

interaction currency_on_character {
  tag      "currency"
  target   "character"
  response "You offer Galleons to {target}. 'I'm not for sale,' they say."
}

interaction light_source_on_character {
  tag      "light_source"
  target   "character"
  response "You shine the lantern at {target}. They squint. 'Do you mind?'"
}
# ===============================================
#   ADVANCED TRIGGERS — LIVING WORLD SYSTEM
# ===============================================
#
# Dynamic triggers that make Hogwarts feel alive,
# deteriorating, and responsive to player choices.
# These complement the core triggers in 09-triggers.
#
# Categories:
#   1. Castle Deterioration (progressive decay)
#   2. NPC Autonomous Behavior (movement/spawning)
#   3. Consequence Cascades (choice fallout)
#   4. Environmental Storytelling (world reacts)
#   5. Timed Pressure (urgency escalation)
#   6. Hidden Rewards (exploration payoffs)
# ===============================================


# ═══════════════════════════════════════════════════
#   1. CASTLE DETERIORATION
# ═══════════════════════════════════════════════════
#
# The castle physically degrades as the player
# completes trials. Each trial weakens the wards
# further, and the environment reflects it.

# --- After First Trial: Hairline Cracks ---

# The entrance hall portrait flees its frame
when flag_set(trial_gryffindor_complete) {
  effect change_description(entrance_hall, "The Entrance Hall feels wrong. The marble staircase has developed a crack running up its left banister, and the portrait of Barnabas the Barmy is empty — the canvas shows only a painted chair, knocked over, as though its occupant fled in haste. The remaining portraits whisper to each other in voices too low to hear.")
  once
}

# The hospital wing shows strain
when flag_set(trial_ravenclaw_complete) {
  effect change_description(hospital_wing, "The Hospital Wing is busier than usual. Several beds are occupied by students complaining of headaches and nosebleeds — the castle's magical instability is making people ill. The medicine cabinet rattles on its own, bottles clinking together as though shivering.")
  once
}

# --- After Second Trial: Serious Shifts ---

# A second trial warps the grand staircase
when flag_set(trial_hufflepuff_complete) {
  require has_flag(trial_gryffindor_complete)
  effect change_description(grand_staircase, "The Grand Staircase has become unreliable. Two of the staircases have frozen in mid-rotation, jutting at wrong angles like broken arms. A third moves in jerky, unpredictable lurches. The gap between the second and third landing has widened — you can see straight down to the ground floor, five stories below. The air smells of ozone and old stone dust.")
  once
}

# Snape relocates to dungeon stairs — potions classroom is compromised
when flag_set(trial_slytherin_complete) {
  require has_flag(trial_gryffindor_complete)
  effect move_npc(snape, dungeon_stairs)
  effect change_description(potions_classroom, "The Potions Classroom is in disarray. Several cauldrons have toppled, their contents eating through the stone floor in hissing rivulets. The ingredient cabinet has cracked open and half the shelves have spilled. Snape has abandoned his post — a first in living memory. A note on the blackboard reads, in his angular script: 'Class cancelled. Indefinitely.'")
  once
}

# --- After Third Trial: The Castle Is Failing ---

# The library becomes dangerous
when flag_set(trial_slytherin_complete) {
  require has_flag(trial_ravenclaw_complete)
  require has_flag(trial_hufflepuff_complete)
  effect change_description(library, "The library has reorganized itself. Shelves have migrated across the floor, forming new corridors of books that don't match any catalog. The restricted section rope barrier has dissolved — not because anyone removed it, but because the enchantment simply stopped working. Books hover at shoulder height, their pages riffling in an unfelt wind. One thick volume lies open on the floor, bleeding ink that pools like dark water.")
  effect move_npc(hermione, entrance_hall)
  message "Hermione stumbles out of the library stacks, pale-faced. 'The books are moving on their own, Harry. The organizational enchantments are breaking down — a thousand years of cataloguing, just... gone.' She steadies herself against the wall. 'I'm going to the Entrance Hall. It feels more stable there.'"
  once
}

# The castle buckles across multiple areas when all trials are done
when flag_set(all_trials_complete) {
  effect change_description(dungeon_stairs, "The Dungeon Stairway has changed. The steps are no longer even — some have risen, others sunk, creating a jagged descent that requires careful footwork. The walls seep dark moisture that isn't water. It smells of iron and lightning. The way down to the Depths gapes open like a wound in the castle's foundations.")
  effect change_description(great_hall, "The Great Hall is barely recognizable. The enchanted ceiling shows not sky but raw magic — swirling currents of gold, blue, yellow, and green that collide and shatter like colored lightning. The four house tables have been pushed against the walls to make room for frightened students huddled in groups. The Gryffindor hourglass still blazes crimson, but the other three hourglasses are cracked. Professor McGonagall stands at the high table with a wand in each hand, maintaining a shield charm over the ceiling.")
  effect change_description(kitchen_corridor, "The Kitchen Corridor has stretched. It is longer than it should be — you can see the painting of the fruit bowl at the far end, but it takes twice as many steps to reach it. The walls breathe, expanding and contracting by inches, like the corridor is the throat of something alive.")
  once
}


# ═══════════════════════════════════════════════════
#   2. NPC AUTONOMOUS BEHAVIOR
# ═══════════════════════════════════════════════════
#
# NPCs move, react, and take independent action
# throughout the game. The player should encounter
# them in unexpected places doing unexpected things.

# --- Filch Patrols ---

# Filch stalks toward the trophy room after the player takes the ring
when item_taken(slytherin_ring) {
  effect move_npc(filch, dungeon_stairs)
  message "Somewhere in the castle, a door slams. Filch's voice echoes distantly: 'Someone's been at the trophy case! I'll have their HEAD!'"
  once
}

# Filch retreats to the kitchens after two trials — even he senses danger
when flag_set(trial_hufflepuff_complete) {
  require has_flag(trial_gryffindor_complete)
  effect move_npc(filch, kitchens)
  message "From somewhere deeper in the castle, you hear Filch muttering to Mrs Norris: 'That's it, my sweet. We're staying in the kitchens where it's warm. Let the children sort out their own messes.'"
  once
}

# --- Luna Wanders ---

# Luna moves to the library after the Ravenclaw trial is discovered
when flag_set(grey_lady_clue) {
  effect move_npc(luna, library)
  message "You catch a glimpse of Luna Lovegood drifting past with a stack of books balanced on her head. 'I'm going to the library,' she says serenely. 'The books are calling me. Well, one of them is. The others are just being polite.'"
  once
}

# --- Neville Tends Plants Elsewhere ---

# Neville moves to the courtyard to save plants from the greenhouse
when flag_set(trial_hufflepuff_complete) {
  effect move_npc(neville, courtyard)
  effect change_description(greenhouse, "The greenhouse is half-empty. Neville has transplanted his most valuable specimens — the Venomous Tentacula, the Mimbulus Mimbletonia, the self-watering roses — to safer ground. The remaining plants look wilted, sensing their caretaker's absence. Soil is scattered across the floor where pots were dragged out in haste.")
  message "You spot Neville in the courtyard, surrounded by potted plants, carefully repotting a Venomous Tentacula. 'The greenhouse ceiling started cracking,' he says, not looking up. 'I couldn't just leave them.'"
  once
}

# --- Ginny Evacuates Students ---

# Ginny moves to the grand staircase to organize younger students
when flag_set(trial_ravenclaw_complete) {
  require has_flag(trial_gryffindor_complete)
  effect move_npc(ginny, grand_staircase)
  message "Ginny Weasley pushes past you on the stairs, herding a cluster of terrified first-years. 'Move it, come on, stay together!' She catches your eye. 'I'm getting the younger ones to the Great Hall. McGonagall's orders.' She pauses. 'Be careful, Harry.'"
  once
}

# --- Hagrid Moves to the Forest Edge ---

# Hagrid appears at the forest edge when the castle gets bad
when flag_set(trial_slytherin_complete) {
  require has_flag(trial_gryffindor_complete)
  effect move_npc(hagrid, forest_edge)
  effect change_description(hagrid_hut, "Hagrid's Hut is empty. The fire is out. Fang's basket is overturned. A note on the table reads, in Hagrid's enormous handwriting: 'Gone to keep the forest creatures calm. They can feel it too. — H.' The wrench is still on the workbench.")
  once
}

# --- Fred and George Leave Helpful Items ---

# Fred and George stash Peruvian Darkness Powder in the seventh floor corridor
when flag_set(has_main_quest) {
  require not_flag(trial_gryffindor_complete)
  effect spawn_item(magical_candy, seventh_floor_corridor)
  effect change_description(seventh_floor_corridor, "The seventh floor corridor is drafty and poorly lit. Someone has been here recently — there are muddy footprints (two sets, identical in size) leading to a shadowy alcove. Tucked behind a loose stone, barely visible, is something wrapped in Weasleys' Wizard Wheezes packaging, with a note: 'For Harry. Don't tell Mum. — F&G'")
  once
}

# After two trials, the twins leave another gift in the clock tower
when flag_set(trial_ravenclaw_complete) {
  require has_flag(trial_gryffindor_complete)
  effect spawn_item(peruvian_darkness_powder, clock_tower_base)
  message "A Weasleys' Wizard Wheezes firework goes off somewhere above — green sparks rain down a stairwell and spell out: 'CHECK THE CLOCK TOWER — F&G'"
  once
}

# --- Dobby Follows and Helps ---

# Dobby appears in the dungeon stairs with a warning after being helped
when room_enter(dungeon_stairs) {
  require has_flag(dobby_helped)
  require not_flag(all_trials_complete)
  require not_flag(dobby_dungeon_warning)
  effect set_flag(dobby_dungeon_warning)
  effect move_npc(dobby, dungeon_stairs)
  message "Dobby appears with a crack of displaced air, wringing his hands. 'Harry Potter must be careful in the dungeons, sir! Dobby heard sounds coming from below — old sounds, sir, like the castle is groaning in its sleep. Dobby brought Harry Potter a pair of socks for luck.' He holds out a pair of mismatched socks, beaming, then vanishes with another crack."
  once
}

# --- McGonagall Coordinates Defense ---

# McGonagall moves to entrance hall after two trials
when flag_set(trial_ravenclaw_complete) {
  require has_flag(trial_gryffindor_complete)
  effect move_npc(mcgonagall, entrance_hall)
  effect change_description(entrance_hall, "The Entrance Hall has become a command post. Professor McGonagall stands near the marble staircase, directing prefects with sharp, precise gestures. A map of the castle hovers before her, showing rooms flickering between red and green — stable and unstable. 'Potter,' she says crisply as you pass. 'Good. Keep moving.'")
  once
}

# McGonagall and Ginny rally to the Great Hall for the final stand
when flag_set(all_trials_complete) {
  effect move_npc(mcgonagall, great_hall)
  effect move_npc(ginny, great_hall)
  message "McGonagall's voice rings through the corridors, magically amplified: 'All students to the Great Hall immediately. Staff, take defensive positions. This is not a drill.' The portraits relay the message down every hallway, frame to frame, like a game of whispered telephone played at a shout."
  once
}


# ═══════════════════════════════════════════════════
#   3. CONSEQUENCE CASCADES
# ═══════════════════════════════════════════════════
#
# Past choices ripple forward, changing rooms, NPCs,
# and difficulty. The player should feel the weight
# of earlier decisions hours after making them.

# --- Ron Abandoned: The Absence Is Felt ---

# If Ron was abandoned, the Gryffindor common areas grow colder
when flag_set(ron_abandoned) {
  effect change_description(great_hall, "The Great Hall feels colder than it should. Ron's usual seat at the Gryffindor table is empty. No one has sat there since he disappeared into the trial. The other Weasleys keep glancing at the door.")
  once
}

# If Ron was abandoned, entering the Hufflepuff trial is harder emotionally
when room_enter(crossroads_of_need) {
  require has_flag(ron_abandoned)
  require not_flag(ron_guilt_crossroads)
  effect set_flag(ron_guilt_crossroads)
  message "The Crossroads of Need feels heavier than it should. You think of Ron — pinned under rubble, telling you to go on. The ghostly student at the crossroads stares at you with hollow eyes and says, very quietly: 'You left someone behind, didn't you?' The temperature drops."
  once
}

# Ron abandoned affects the convergence antechamber
when room_enter(convergence_antechamber) {
  require has_flag(ron_abandoned)
  require not_flag(ron_ghost_antechamber)
  effect set_flag(ron_ghost_antechamber)
  message "As you place the tokens, you hear a voice — Ron's voice — from nowhere: 'I understand, mate. Go.' The words echo off the ancient stone and don't fade. They just get quieter, and quieter, until they're part of the silence."
  once
}

# --- Draco Hostile: He Sabotages ---

# Draco leaves a magical trap in the ward chamber
when room_enter(ward_chamber) {
  require has_flag(draco_hostile)
  require not_flag(draco_trap_ward)
  effect set_flag(draco_trap_ward)
  effect change_health(-15)
  message "A hex catches you square in the chest as you enter — someone left a Stinging Jinx tripwire across the doorway. The magic signature is distinctive: cold, precise, arrogant. Malfoy was here. And he left you a present."
  once
}

# Draco hostile changes the convergence antechamber
when room_enter(convergence_antechamber) {
  require has_flag(draco_hostile)
  require not_flag(draco_graffiti)
  effect set_flag(draco_graffiti)
  effect change_description(convergence_antechamber, "The Convergence Antechamber is ancient and vast, its walls carved with the sigils of all four Founders. But someone has been here recently — scratched into the stone near the door, in sharp angular letters: 'TOO SLOW, POTTER.' The token alcove waits in the far wall, four shaped recesses ready for the Founders' artifacts.")
  message "Scratched into the wall near the entrance, in handwriting you recognize: 'TOO SLOW, POTTER.' Draco was here first. But the token alcove is untouched — he didn't have the tokens to open it."
  once
}

# Draco hostile blocks the convergence chamber entrance temporarily
when room_enter(convergence_chamber) {
  require has_flag(draco_hostile)
  require not_flag(draco_confrontation_final)
  effect set_flag(draco_confrontation_final)
  effect move_npc(draco, convergence_chamber)
  message "Draco is here. He stands before the Convergence Stone, wand raised, breathing hard. 'I got here first, Potter. But I can't—' He gestures at the Stone, frustrated. 'It won't respond to me alone. The curse is too strong.' His eyes are wild. 'So here's what's going to happen. You're going to help me seal this Stone, and then we're going to have a very long conversation about who owes whom.'"
  once
}

# --- Locket Kept: The Vault Resists ---

# If the locket was kept, the Hufflepuff vault reacts
when room_enter(hufflepuff_vault) {
  require has_flag(locket_kept)
  require not_flag(vault_locket_judgment)
  effect set_flag(vault_locket_judgment)
  effect change_health(-10)
  effect change_description(hufflepuff_vault, "Hufflepuff's Vault is warm and golden, but the warmth does not reach you. The cup emblem on the far wall glows, but it pulses in a harsh, accusatory rhythm — like a heartbeat that knows you did something wrong. The roots in the walls have retracted from you, leaving a bare circle of cold stone where you stand. You kept something that wasn't yours, and this place knows it.")
  message "The vault's warmth turns to cold as you enter. The roots in the walls recoil from you. A voice that sounds like honey and disappointment whispers: 'You kept what was not yours to keep.' The golden light flickers, and you feel a sharp pain in your chest — not a hex, but something worse. Judgment."
  once
}

# --- Stranger Healed: The Guide Returns ---

# If the stranger was healed, they appear as a guide in the Depths and reveal the ward order
when room_enter(ancient_passage) {
  require has_flag(stranger_healed)
  require not_flag(stranger_guide_depths)
  effect set_flag(stranger_guide_depths)
  effect set_flag(knows_ward_order)
  message "A familiar shimmer coalesces in the passage ahead — the spectral student from the Hufflepuff Trial, the one you healed. They look stronger now, more defined, their features clear for the first time. 'You helped me when I was in pain,' they say. 'Now I can help you. The ward stones must be activated in the order they were laid: earth first, then sky, then fire, then water. Yellow, blue, red, green. Remember.' They flicker and fade, but you feel warmer for having seen them."
  once
}

# --- Ron Rescued AND Loyalty Proven: Emotional Convergence ---

when room_enter(convergence_antechamber) {
  require has_flag(ron_rescued)
  require has_flag(loyalty_proven)
  require not_flag(loyalty_resonance)
  effect set_flag(loyalty_resonance)
  message "As you approach the token alcove, you feel a warmth that has nothing to do with magic. Somewhere above, you know Ron is recovering, stronger for being saved. Somewhere in the Hufflepuff Trial, a ghost rests easier because you returned what was theirs. The tokens in your pack hum in harmony — courage and loyalty, resonating together. You've done this the right way. The Stone will know."
  once
}



# ═══════════════════════════════════════════════════
#   4. ENVIRONMENTAL STORYTELLING
# ═══════════════════════════════════════════════════
#
# The world tells stories through description changes,
# item transformations, and environmental reactions
# to the player's moral state and progress.

# --- Marauder's Map Changes After Trials ---

# The Map struggles to keep up after two trials — but reveals deeper routes
when flag_set(trial_ravenclaw_complete) {
  require has_flag(trial_gryffindor_complete)
  require not_flag(map_updated)
  effect set_flag(map_updated)
  effect change_description(marauders_map, "The Marauder's Map is struggling. The castle's magical instability is making the corridors shift faster than the enchantment can track. Rooms blink in and out of existence on the parchment. The footprints of 'Draco Malfoy' move purposefully through the lower corridors. But new text has appeared in Moony's handwriting at the bottom: 'The old ways run deeper than the castle. Look below.' An arrow points to the dungeon stairs, where a new passage descends off the edge of the map.")
  once
}

# --- Great Hall Ceiling Reflects Moral State ---

# Ceiling reflects virtue if the player has made good choices
when room_enter(great_hall) {
  require has_flag(ron_rescued)
  require has_flag(stranger_healed)
  require not_flag(ceiling_virtue)
  effect set_flag(ceiling_virtue)
  message "You glance up at the enchanted ceiling. For a moment — just a moment — the storm clouds part, and you see stars. Not the real stars, but brighter ones, arranged in constellations you don't recognize: a lion, a badger, an eagle. They shine with a fierce, approving light, and then the clouds close again. The castle noticed what you've done."
  once
}

# Ceiling reflects darkness if the player made selfish choices
when room_enter(great_hall) {
  require has_flag(ron_abandoned)
  require has_flag(locket_kept)
  require not_flag(ceiling_judgment)
  effect set_flag(ceiling_judgment)
  message "The enchanted ceiling above the Great Hall churns with black clouds — blacker than the night sky outside, shot through with veins of sickly green lightning. For a moment, a face forms in the clouds: ancient, gaunt, furious. Then it dissolves. But you feel its attention linger, like a cold finger pressed between your shoulder blades."
  once
}

# --- Ward Stones Respond to Complete Token Set ---

when room_enter(ward_chamber) {
  require has_item(gryffindor_token)
  require has_item(ravenclaw_token)
  require has_item(hufflepuff_token)
  require has_item(slytherin_token)
  require not_flag(ward_stones_resonate)
  effect set_flag(ward_stones_resonate)
  message "All four ward stones blaze to life as you enter, responding to the complete set of Founder Tokens in your pack. Red, blue, yellow, green — the colors fill the chamber in overlapping washes of light. The stones hum in four-part harmony, each one calling to its counterpart artifact. For the first time since you entered the Depths, you feel something like hope."
  once
}

# --- Portraits Warn About Trial Areas ---

# Portrait provides a gameplay hint for the Room of Deception
when room_enter(potions_classroom) {
  require has_flag(has_main_quest)
  require has_flag(knows_revealer_recipe)
  require not_flag(portrait_warning_slytherin)
  effect set_flag(portrait_warning_slytherin)
  message "A portrait of a severe-looking witch near the dungeon wall leans forward. 'I know what you're planning. That wall hides Salazar's trial — I watched him build it. He was clever, that one. Cruel-clever.' She taps the frame. 'Whatever you do in there, don't trust your eyes. Trust the scratches in the iron.'"
  once
}


# ═══════════════════════════════════════════════════
#   5. TIMED PRESSURE
# ═══════════════════════════════════════════════════
#
# Create escalating urgency as the game progresses.
# The player should feel the castle running out of time.

# --- Warning Signs After Two Trials ---

# Cracks appear in the Gryffindor common areas
when flag_set(trial_ravenclaw_complete) {
  require has_flag(trial_gryffindor_complete)
  require not_flag(commons_warning_1)
  effect set_flag(commons_warning_1)
  effect change_description(corridor_east, "The East Corridor is deteriorating. A long crack runs up the wall from floor to ceiling, and the suits of armor have clustered together at the far end as though conferring nervously. One suit has lost its helmet — it rolls back and forth across the floor with each tremor.")
  effect change_description(corridor_west, "The West Corridor is cold — colder than it should be. Frost has formed on the inside of the windows despite it being late spring. The torches burn with blue-white flame instead of their usual warm orange. Fred and George's usual corner is empty; even they know when to clear out.")
  once
}

# --- After Three Trials: Dumbledore's Warning ---

# Dumbledore sends a Patronus warning when entering any common room after 3 trials
when room_enter(great_hall) {
  require has_flag(trial_gryffindor_complete)
  require has_flag(trial_ravenclaw_complete)
  require has_flag(trial_hufflepuff_complete)
  require not_flag(dumbledore_patronus_warning)
  effect set_flag(dumbledore_patronus_warning)
  message "A silver phoenix bursts through the wall — Dumbledore's Patronus. It hovers before you, its wings spreading wide, and speaks in Dumbledore's voice: 'Harry. The wards are failing faster than I anticipated. I can feel the corruption spreading from the Convergence Stone. You must complete the remaining trial and descend to the Depths. There is very little time. I cannot leave my post.' The phoenix dissolves into silver mist. 'Please hurry.'"
  once
}

# --- Entering the Depths Changes the Surface ---

# The castle reacts when the player descends
when room_enter(ancient_passage) {
  require not_flag(depths_surface_reaction)
  effect set_flag(depths_surface_reaction)
  effect change_description(entrance_hall, "The Entrance Hall has changed since you descended. The marble is cracked. Two of the staircases have detached from their moorings and hang at angles, useless. The portraits are empty — every single one. Wherever their inhabitants have gone, they didn't want to be here for what comes next.")
  message "As you step into the Ancient Passage, you feel the castle above you lurch. The tremor passes through the stone beneath your feet and keeps going, down into depths older than Hogwarts itself. Behind you, dust cascades from the ceiling of the dungeon stairs. There is no going back — not because the way is blocked, but because you understand now that if you don't finish this, there won't be anything worth going back to."
  once
}

# --- Mrs Norris Scouts ---

# Mrs Norris stalks the corridors, creating tension
when room_enter(corridor_west) {
  require has_flag(has_main_quest)
  require not_flag(mrs_norris_sighting)
  effect set_flag(mrs_norris_sighting)
  message "A pair of lamp-like yellow eyes watches you from the shadows near the ceiling. Mrs Norris is perched on top of a display case, tail swishing, tracking your every movement. She lets out a low, throaty growl — not aggressive, but knowing. She's reporting back to someone."
  once
}


# ═══════════════════════════════════════════════════
#   6. HIDDEN REWARDS
# ═══════════════════════════════════════════════════
#
# Reward thorough exploration, revisiting, and
# carrying the right items to the right places.

# --- Knowledge Unlocks Hidden Details ---

# Reading Malachar's journal reveals a secret about the rusted amulet
when item_taken(malachar_journal) {
  require has_item(rusted_amulet)
  require not_flag(amulet_revelation)
  effect set_flag(amulet_revelation)
  effect change_description(rusted_amulet, "The rusted amulet — you understand now. Reading Malachar's journal, you recognize the description: this was his focus, the channel through which he cast the original curse. The rust isn't corrosion — it's dried blood. Malachar's blood. And the protective magic humming inside it isn't Malachar's work. It's the Founders' counter-curse, laid into the amulet to keep the dark magic contained. Carrying this into the Convergence Chamber might matter.")
  message "Your hand tightens on Malachar's journal. You look at the rusted amulet in your pack with new understanding. The journal describes an amulet exactly like this one — Malachar's focus, corrupted by the Founders and turned into a seal. The rust isn't age. It's a thousand years of contained darkness. And you've been carrying it in your pocket."
  once
}

# --- Item Combinations Reveal Secrets ---

# Carrying the enchanted lantern into the mirror maze reveals hidden text
when room_enter(mirror_maze) {
  require has_item(enchanted_lantern)
  require not_flag(mirror_maze_lantern_secret)
  effect set_flag(mirror_maze_lantern_secret)
  message "The enchanted lantern flares as you enter the Mirror Maze — brighter than usual, as though the magic in the mirrors is feeding it. In the reflected light, you see something new: words inscribed on the back of one mirror, visible only in enchanted light. 'The smallest bottle is always empty. The poison fears the passage. Count from the left of three.' A direct answer to the Logic Chamber puzzle, hidden in plain sight for anyone carrying the right light."
  once
}

# Carrying the Marauder's Map into the Depths reveals a shortcut
when room_enter(ancient_passage) {
  require has_item(marauders_map)
  require not_flag(map_depths_secret)
  effect set_flag(map_depths_secret)
  message "The Marauder's Map shudders in your pocket. You pull it out — the parchment is redrawing itself, extending downward into areas it never showed before. Ancient passages, older than Hogwarts, mapped by the Marauders during some long-ago expedition. In the corner, in Prongs' handwriting: 'We found this during seventh year. Never told anyone. Some things are better left to those who need them.' The map shows a straight path from the Ward Chamber to the Convergence Antechamber, bypassing Malachar's Gallery entirely."
  once
}

# --- Visiting Rooms in Sequence Unlocks Bonus ---

# --- Completing All Side Quests Before the Depths ---

# If all side quests are done before entering the Depths, the castle itself helps
when room_enter(ancient_passage) {
  require has_flag(dobby_helped)
  require has_flag(nargles_found)
  require has_flag(malachar_history_complete)
  require has_flag(twins_trade_complete)
  require has_flag(journal_complete)
  require not_flag(castle_gratitude)
  effect set_flag(castle_gratitude)
  effect change_health(30)
  message "As you cross the threshold into the Depths, the castle does something you've never felt before. The stone beneath your feet warms. The walls glow — not with torchlight, but with something deeper, something woven into the foundations a thousand years ago. A pulse of golden energy passes through you, healing old wounds, steadying your nerves.\n\nYou've helped everyone who asked. You've uncovered every secret the castle offered. And Hogwarts, in its ancient, wordless way, is saying thank you.\n\nYou feel stronger. Ready."
  once
}

# --- Entering the Convergence Chamber with Draco Allied and All Virtue Flags ---

when room_enter(convergence_chamber) {
  require has_flag(draco_allied)
  require has_flag(ron_rescued)
  require has_flag(stranger_healed)
  require has_flag(loyalty_proven)
  require not_flag(unity_path_ready)
  effect set_flag(unity_path_ready)
  message "Draco is here, standing to one side of the Convergence Stone. He looks at you — not with hostility, not with resentment, but with something close to respect. 'You came with everything you need,' he says. 'All four virtues. I can feel them in the tokens.' He straightens. 'I never thought I'd say this, Potter, but — let's finish what the Founders started. Together.'\n\nThe four tokens in your pack pulse in unison: gold, blue, yellow, green. The Convergence Stone responds, its dark veins flickering as though the curse senses what's coming."
  once
}
# ═══════════════════════════════════════════════════
#   DIALOGUE NODE TRIGGERS — NPC Item Giving
# ═══════════════════════════════════════════════════
#
# Dialogue trees can only set flags, not give items.
# These triggers fire when specific dialogue nodes are
# visited, spawning items into the player's inventory.
# Node IDs follow the pattern: {npc_id}_{talk_label}

# --- Ron gives prefect badge ---
when dialogue_node(ron_ron_badge_give) {
  effect spawn_item(prefect_badge, _inventory)
  message "Ron unpins the badge from his robes and presses it into your hand."
  once
}

# --- Dumbledore gives enchanted lantern ---
when dialogue_node(dumbledore_dumbledore_items) {
  effect spawn_item(enchanted_lantern, _inventory)
  message "Dumbledore lifts a small brass lantern from the shelf behind him and places it on the desk."
  once
}

# --- Dumbledore gives permission slip ---
when dialogue_node(dumbledore_dumbledore_items_2) {
  effect spawn_item(permission_slip, _inventory)
  message "He slides a folded parchment across the desk — signed, sealed, and unmistakably official."
  once
}

# --- Dumbledore gives invisibility cloak ---
when dialogue_node(dumbledore_dumbledore_items_3) {
  effect spawn_item(invisibility_cloak, _inventory)
  message "Dumbledore opens a drawer and lifts out a shimmering, silvery fabric. Your father's cloak."
  once
}

# --- Hagrid gives wrench ---
when dialogue_node(hagrid_hagrid_wrench) {
  effect spawn_item(wrench, _inventory)
  message "Hagrid rummages through a drawer and produces a heavy iron wrench, still warm from lying near the fire."
  once
}

# --- Fred & George trade items ---
when dialogue_node(fred_george_twins_buy) {
  effect consume_quantity(galleons, 5)
  effect spawn_item(magical_candy, _inventory)
  effect spawn_item(peruvian_darkness_powder, _inventory)
  effect set_flag(twins_trade_complete)
  effect add_score(10)
  message "Fred pockets the Galleons. George hands you a bag of round candy and a pouch of fine black powder."
  once
}

# --- Spectral stranger gives hufflepuff charm (healed with potion) ---
when dialogue_node(spectral_stranger_stranger_reward) {
  effect spawn_item(hufflepuff_charm, _inventory)
  message "The spectral figure reaches into its robes and produces a small golden charm — warm, solid, and unmistakably real despite the ghost that holds it."
  once
}

# --- Spectral stranger gives hufflepuff charm (healed with candy) ---
when dialogue_node(spectral_stranger_stranger_candy_reward) {
  effect spawn_item(hufflepuff_charm, _inventory)
  message "The figure smiles faintly and presses a small golden charm into your palm."
  once
}

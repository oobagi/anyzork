# --- Lore: Journal and Amulet reads ---

on "read journal" {
  require has_item(founders_journal_page_1)
  effect set_flag(journal_page_1_found)
  effect add_score(5)
  success "The yellowed page is written in an archaic hand: 'We four have agreed — the Stone shall anchor the wards. Helga insists on patience in its construction. She is right. Godric wanted to rush. He is always right too, and always wrong. The order of the ward-laying: first Helga, then Rowena, then Godric, then Salazar. Each in turn. Each in trust.'"
  fail "You don't have a journal page to read."
  done "You already know the journal's contents."
  once
}

on "read page" {
  require has_item(founders_journal_page_1)
  effect set_flag(journal_page_1_found)
  effect add_score(5)
  success "The yellowed page is written in an archaic hand: 'We four have agreed — the Stone shall anchor the wards. Helga insists on patience in its construction. She is right. Godric wanted to rush. He is always right too, and always wrong. The order of the ward-laying: first Helga, then Rowena, then Godric, then Salazar. Each in turn. Each in trust.'"
  fail "You don't have a journal page to read."
  done "You already know the journal's contents."
  once
}

on "read amulet" {
  require has_item(rusted_amulet)
  effect add_score(5)
  success "The symbols on the amulet's face become clearer as you rub away the corrosion. It depicts four figures standing in a circle, hands linked, around a central stone. Below them, a fifth figure — alone, outside the circle — reaches toward the stone with both hands. The engraving on the back reads: 'Against Malachar. Against forgetting.'"
  fail "You don't have an amulet."
  done "You've already studied the amulet."
  once
}

# --- Marauder's Map usage ---

on "use map" {
  require has_item(marauders_map)
  success "You tap the map with your wand and whisper 'I solemnly swear that I am up to no good.' Ink lines bloom across the parchment, tracing corridors and rooms. You can see the labeled positions of everyone in the castle — dots moving along passages, clustering in rooms. The map confirms: the dungeon stairs hide something deeper, the library's east wall is not quite solid, and the kitchens have a passage behind the largest barrel."
  fail "You don't have the Marauder's Map."
}

on "use marauders map" {
  require has_item(marauders_map)
  success "You tap the map with your wand and whisper 'I solemnly swear that I am up to no good.' Ink lines bloom across the parchment, tracing corridors and rooms. You can see the labeled positions of everyone in the castle — dots moving along passages, clustering in rooms. The map confirms: the dungeon stairs hide something deeper, the library's east wall is not quite solid, and the kitchens have a passage behind the largest barrel."
  fail "You don't have the Marauder's Map."
}

# --- Tickle the Pear (flavor — kitchens are already accessible) ---

on "tickle pear" in [kitchen_corridor] {
  success "You reach up to the painting of the fruit bowl and tickle the pear. It giggles — a high, delighted sound — and squirms into a green door handle. The passage to the kitchens remains open."
  done "The pear has already been tickled. It giggles at you anyway."
  once
}



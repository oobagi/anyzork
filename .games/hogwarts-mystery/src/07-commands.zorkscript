# ===============================================
#   COMMANDS
# ===============================================
#
# Every on-block defines a player command. The
# engine matches verb patterns, checks require
# preconditions, fires effects on success, and
# uses fail/done/success messages. Commands
# marked `once` cannot be repeated after success.
# ===============================================


# ═══════════════════════════════════════════════════
#   HOGWARTS COMMONS — Critical Path
# ═══════════════════════════════════════════════════

# --- Puzzle 1: The Gargoyle's Password ---

on "say sherbet lemon" in [grand_staircase] {
  require has_flag(knows_gargoyle_password)
  effect solve_puzzle(gargoyle_password)
  effect add_score(10)
  success "You speak clearly: 'Sherbet Lemon.' The gargoyle's stone eyes widen — then it leaps aside with a grinding screech, revealing a spiral staircase behind it."
  fail "The gargoyle stares at you stonily. Perhaps you should learn the password before guessing."
  done "The gargoyle has already stepped aside."
  once
}

on "enter sherbet lemon" in [grand_staircase] {
  require has_flag(knows_gargoyle_password)
  effect solve_puzzle(gargoyle_password)
  effect add_score(10)
  success "You speak clearly: 'Sherbet Lemon.' The gargoyle's stone eyes widen — then it leaps aside with a grinding screech, revealing a spiral staircase behind it."
  fail "The gargoyle stares at you stonily. Perhaps you should learn the password before guessing."
  done "The gargoyle has already stepped aside."
  once
}

# --- Puzzle 2: Restricted Section Access ---

on "show permission" in [library] {
  require has_item(permission_slip)
  require npc_in_room(hermione, _current)
  effect reveal_exit(library_restricted)
  effect set_flag(restricted_unlocked)
  effect solve_puzzle(restricted_section_access)
  effect add_score(15)
  success "You hold up the signed permission slip. Hermione takes it, reads it twice, nods briskly, and unclips the velvet rope. 'That's Dumbledore's handwriting. Go on — I'll show you where to look.'"
  fail "You need a signed permission slip, and Hermione needs to see it."
  done "The Restricted Section is already accessible."
  once
}

on "give permission" in [library] {
  require has_item(permission_slip)
  require npc_in_room(hermione, _current)
  effect reveal_exit(library_restricted)
  effect set_flag(restricted_unlocked)
  effect solve_puzzle(restricted_section_access)
  effect add_score(15)
  success "You hold up the signed permission slip. Hermione takes it, reads it twice, nods briskly, and unclips the velvet rope. 'That's Dumbledore's handwriting. Go on — I'll show you where to look.'"
  fail "You need a signed permission slip, and Hermione needs to see it."
  done "The Restricted Section is already accessible."
  once
}

on "show permission slip" in [library] {
  require has_item(permission_slip)
  require npc_in_room(hermione, _current)
  effect reveal_exit(library_restricted)
  effect set_flag(restricted_unlocked)
  effect solve_puzzle(restricted_section_access)
  effect add_score(15)
  success "You hold up the signed permission slip. Hermione takes it, reads it twice, nods briskly, and unclips the velvet rope. 'That's Dumbledore's handwriting. Go on — I'll show you where to look.'"
  fail "You need a signed permission slip, and Hermione needs to see it."
  done "The Restricted Section is already accessible."
  once
}

# --- Read commands for lore items ---

on "read recipe" {
  require has_item(revealer_recipe)
  effect set_flag(knows_revealer_recipe)
  effect add_score(5)
  success "The recipe is written in a careful, precise hand: 'Revealer Draught — dissolves concealment enchantments of the Third Order. Combine one moonpetal with one ashwinder egg in the potions classroom. Apply the finished draught directly to the concealed surface.'"
  fail "You don't have a recipe to read."
  done "You already know the recipe by heart."
  once
}

on "read revealer recipe" {
  require has_item(revealer_recipe)
  effect set_flag(knows_revealer_recipe)
  effect add_score(5)
  success "The recipe is written in a careful, precise hand: 'Revealer Draught — dissolves concealment enchantments of the Third Order. Combine one moonpetal with one ashwinder egg in the potions classroom. Apply the finished draught directly to the concealed surface.'"
  fail "You don't have a recipe to read."
  done "You already know the recipe by heart."
  once
}

# --- Puzzle 4: The Revealer Potion ---

on "brew potion" in [potions_classroom] {
  require has_item(moonpetal)
  require has_item(ashwinder_egg)
  require has_flag(knows_revealer_recipe)
  effect remove_item(moonpetal)
  effect remove_item(ashwinder_egg)
  effect spawn_item(revealer_potion, _inventory)
  effect solve_puzzle(potions_recipe)
  effect add_score(20)
  success "You follow the recipe precisely. The moonpetal dissolves into a silver mist as it contacts the ashwinder egg. The mixture hisses, turns translucent, and settles into a shimmering liquid that seems to look through whatever it touches. The Revealer Potion is ready."
  fail "You need the right ingredients and the recipe. A moonpetal and an ashwinder egg, combined according to the Revealer recipe."
  done "You have already brewed the potion."
  once
}

on "combine ingredients" in [potions_classroom] {
  require has_item(moonpetal)
  require has_item(ashwinder_egg)
  require has_flag(knows_revealer_recipe)
  effect remove_item(moonpetal)
  effect remove_item(ashwinder_egg)
  effect spawn_item(revealer_potion, _inventory)
  effect solve_puzzle(potions_recipe)
  effect add_score(20)
  success "You follow the recipe precisely. The moonpetal dissolves into a silver mist as it contacts the ashwinder egg. The mixture hisses, turns translucent, and settles into a shimmering liquid that seems to look through whatever it touches. The Revealer Potion is ready."
  fail "You need the right ingredients and the recipe. A moonpetal and an ashwinder egg, combined according to the Revealer recipe."
  done "You have already brewed the potion."
  once
}

on "combine moonpetal with ashwinder egg" in [potions_classroom] {
  require has_item(moonpetal)
  require has_item(ashwinder_egg)
  require has_flag(knows_revealer_recipe)
  effect remove_item(moonpetal)
  effect remove_item(ashwinder_egg)
  effect spawn_item(revealer_potion, _inventory)
  effect solve_puzzle(potions_recipe)
  effect add_score(20)
  success "You follow the recipe precisely. The moonpetal dissolves into a silver mist as it contacts the ashwinder egg. The mixture hisses, turns translucent, and settles into a shimmering liquid that seems to look through whatever it touches. The Revealer Potion is ready."
  fail "You need the right ingredients and the recipe. A moonpetal and an ashwinder egg, combined according to the Revealer recipe."
  done "You have already brewed the potion."
  once
}

# Reveal Slytherin Trial entrance

on "use revealer" in [potions_classroom] {
  require has_item(revealer_potion)
  effect remove_item(revealer_potion)
  effect reveal_exit(potions_slytherin)
  effect add_score(5)
  success "You pour the Revealer Potion onto the shimmering section of wall. The liquid runs upward, defying gravity, tracing the outline of a hidden doorway. The concealment enchantment dissolves like sugar in rain, revealing slick stone steps descending into green torchlight."
  fail "You need the Revealer Potion."
  done "The hidden entrance has already been revealed."
  once
}


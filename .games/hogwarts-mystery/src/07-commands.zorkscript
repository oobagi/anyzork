# Reveal Gryffindor Trial entrance from the map

on "read map" {
  require has_item(gryffindor_map)
  effect reveal_exit(trophy_gryffindor)
  effect add_score(5)
  success "The map shows Hogwarts in cross-section. A dotted line leads from the trophy room's north wall — behind the golden lion tapestry — to a chamber marked 'Gryffindor's Antechamber.' You look up at the tapestry. It was never just decoration."
  fail "You don't have a map."
  done "You already know where the entrance is."
  once
}

on "read gryffindor map" {
  require has_item(gryffindor_map)
  effect reveal_exit(trophy_gryffindor)

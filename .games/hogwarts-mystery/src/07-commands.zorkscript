# --- Puzzle 8: Facing the Boggart ---

on "cast riddikulus" in [fear_chamber] {
  require has_item(wand)
  effect set_flag(boggart_defeated)
  effect solve_puzzle(boggart_confrontation)
  effect add_score(25)
  success "You raise your wand, fix the image of your worst fear in your mind, and shout 'RIDDIKULUS!' The boggart convulses — the terrifying shape warps, shrinks, becomes something absurd: a spider on roller skates, tumbling and flailing. Laughter bubbles up unbidden. The boggart shrieks, unable to feed on fear that isn't there, and explodes into a puff of dark smoke."
  fail "You need your wand to cast spells."
  done "The boggart is already defeated. The room is still."
  once
}

on "riddikulus" in [fear_chamber] {
  require has_item(wand)
  effect set_flag(boggart_defeated)
  effect solve_puzzle(boggart_confrontation)

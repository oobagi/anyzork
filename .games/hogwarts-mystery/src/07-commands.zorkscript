# --- Puzzle 3: The Locked Trophy Case ---

on "use badge" in [trophy_room] {
  require has_item(prefect_badge)
  effect remove_item(prefect_badge)
  effect set_flag(trophy_case_opened)
  effect solve_puzzle(trophy_compartment)
  effect add_score(15)
  success "You press the prefect badge against the brass lock. It clicks, whirs, and springs open. Inside, resting on velvet, you find a rolled map marked with a Gryffindor crest and a tarnished silver ring bearing the Slytherin serpent."
  fail "You need something that fits the lock — something associated with bravery."
  done "The trophy case is already open."
  once
}

on "unlock case" in [trophy_room] {
  require has_item(prefect_badge)
  effect remove_item(prefect_badge)

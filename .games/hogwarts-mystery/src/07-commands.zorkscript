# --- Puzzle 9: Crossing the Flames ---

on "drink flame" in [bridge_of_flames] {
  require has_item(flame_freezing_potion)
  effect remove_item(flame_freezing_potion)
  effect set_flag(flame_protected)
  effect add_score(10)
  success "You uncork the Flame-Freezing Potion and drink. It tastes of mint and ice. A sheath of cold wraps around your skin like invisible armor. The fire still rages across the bridge, but you can feel its heat receding — becoming distant, harmless, almost pleasant."
  fail "You need a potion that protects against fire."
  done "You are already protected from the flames."
  once
}

on "use flame potion" in [bridge_of_flames] {
  require has_item(flame_freezing_potion)
  effect remove_item(flame_freezing_potion)
  effect set_flag(flame_protected)
  effect add_score(10)
  success "You uncork the Flame-Freezing Potion and drink. It tastes of mint and ice. A sheath of cold wraps around your skin like invisible armor. The fire still rages across the bridge, but you can feel its heat receding — becoming distant, harmless, almost pleasant."
  fail "You need a potion that protects against fire."
  done "You are already protected from the flames."
  once
}

on "drink flame freezing potion" in [bridge_of_flames] {
  require has_item(flame_freezing_potion)
  effect remove_item(flame_freezing_potion)
  effect set_flag(flame_protected)
  effect add_score(10)
  success "You uncork the Flame-Freezing Potion and drink. It tastes of mint and ice. A sheath of cold wraps around your skin like invisible armor. The fire still rages across the bridge, but you can feel its heat receding — becoming distant, harmless, almost pleasant."
  fail "You need a potion that protects against fire."
  done "You are already protected from the flames."
  once
}

on "cross bridge" in [bridge_of_flames] {
  require has_flag(flame_protected)
  effect solve_puzzle(bridge_crossing)
  effect add_score(10)
  success "You stride onto the bridge. Flames erupt around you — red, orange, white-hot — but they feel like warm bathwater against your enchanted skin. You walk through the inferno as calmly as crossing a courtyard, and emerge on the far side unburned. The fire closes behind you like a curtain."
  fail "The bridge is engulfed in magical fire. Walking into that without protection would be suicide — or at least extremely painful."
  done "You have already crossed the bridge."
  once
}

# --- Puzzle 10: Rescue Ron (moral choice) ---

on "give potion to ron" in [guardian_hall] {
  require has_item(healing_potion)
  effect consume_quantity(healing_potion, 1)
  effect set_flag(ron_rescued)
  effect spawn_item(gryffindor_crest, _inventory)
  effect solve_puzzle(guardian_rescue)
  effect add_score(20)
  success "You kneel beside Ron and pour the healing potion over his crushed leg. The bones knit with an audible crack. Ron grits his teeth, then breathes. 'Blimey, that hurt worse than the rubble.' He pulls himself upright and presses something into your hand — a small lion crest. 'Found this before the ceiling came down. Figured you'd need it more than me. Now go — I'll be right behind you.'"
  fail "Ron is pinned under rubble and hurt badly. You need a healing potion to help him."
  done "Ron has already been rescued."
  once
}

on "heal ron" in [guardian_hall] {
  require has_item(healing_potion)
  effect consume_quantity(healing_potion, 1)
  effect set_flag(ron_rescued)
  effect spawn_item(gryffindor_crest, _inventory)
  effect solve_puzzle(guardian_rescue)
  effect add_score(20)
  success "You kneel beside Ron and pour the healing potion over his crushed leg. The bones knit with an audible crack. Ron grits his teeth, then breathes. 'Blimey, that hurt worse than the rubble.' He pulls himself upright and presses something into your hand — a small lion crest. 'Found this before the ceiling came down. Figured you'd need it more than me. Now go — I'll be right behind you.'"
  fail "Ron is pinned under rubble and hurt badly. You need a healing potion to help him."
  done "Ron has already been rescued."

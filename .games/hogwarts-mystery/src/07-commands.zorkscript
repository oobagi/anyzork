  success "You drive the shovel into the soft mud and turn up a clot of wet earth. Something metallic clinks against the blade. You dig more carefully and unearth a rusted amulet on a broken chain, its face engraved with symbols you don't recognize — but the style matches the stonework in the dungeons."
  fail "The mud is thick and heavy. You need a tool to dig."
  done "You've already excavated this spot."
  once
}

on "use shovel" in [lake_shore] {
  require has_item(small_shovel)
  effect spawn_item(rusted_amulet, lake_shore)
  effect solve_puzzle(lake_shore_dig)

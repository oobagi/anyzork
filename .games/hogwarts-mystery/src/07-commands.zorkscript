# --- Puzzle 5: The Jammed Clock ---

on "fix clock" in [clock_tower_base] {
  require has_item(wrench)
  effect set_flag(clock_fixed)
  effect spawn_item(founders_journal_page_1, clock_tower_base)
  effect solve_puzzle(clock_tower_mechanism)
  effect add_score(15)
  success "You fit the wrench over the misaligned gear and heave. Metal screams against metal — then catches. The gear clicks into place, and the mechanism shudders to life. The clock's hands begin to move for the first time in years. As it chimes, a hidden panel in the clock base springs open, revealing a folded journal page."
  fail "The gear is stuck. You need a tool — something with leverage."
  done "The clock is already running."
  once
}

on "use wrench" in [clock_tower_base] {
  require has_item(wrench)
  effect set_flag(clock_fixed)
  effect spawn_item(founders_journal_page_1, clock_tower_base)
  effect solve_puzzle(clock_tower_mechanism)
  effect add_score(15)
  success "You fit the wrench over the misaligned gear and heave. Metal screams against metal — then catches. The gear clicks into place, and the mechanism shudders to life. The clock's hands begin to move for the first time in years. As it chimes, a hidden panel in the clock base springs open, revealing a folded journal page."
  fail "The gear is stuck. You need a tool — something with leverage."
  done "The clock is already running."
  once
}

on "use wrench on clock" in [clock_tower_base] {
  require has_item(wrench)
  effect set_flag(clock_fixed)
  effect spawn_item(founders_journal_page_1, clock_tower_base)
  effect solve_puzzle(clock_tower_mechanism)
  effect add_score(15)
  success "You fit the wrench over the misaligned gear and heave. Metal screams against metal — then catches. The gear clicks into place, and the mechanism shudders to life. The clock's hands begin to move for the first time in years. As it chimes, a hidden panel in the clock base springs open, revealing a folded journal page."
  fail "The gear is stuck. You need a tool — something with leverage."
  done "The clock is already running."
  once
}

# --- Puzzle 6: Into the Forest ---

on "show scroll" in [forest_edge] {
  require has_item(shield_charm_scroll)
  require npc_in_room(hagrid, _current)
  effect set_flag(hagrid_allows_forest)
  effect solve_puzzle(forest_passage)
  effect add_score(10)
  success "You unroll the Shield Charm Scroll and hold it up. Hagrid peers at it, scratching his beard. 'Well... if yer prepared with that, I s'pose I can't rightly stop yeh. But be careful in there, Harry. And come straight back.' He steps aside from the forest path."
  fail "Hagrid won't let you pass without some kind of protection."
  done "Hagrid has already let you through."
  once
}

on "give scroll" in [forest_edge] {
  require has_item(shield_charm_scroll)
  require npc_in_room(hagrid, _current)
  effect set_flag(hagrid_allows_forest)

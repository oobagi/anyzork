# ═══════════════════════════════════════════
#   REVERSE EXITS — Missing connections
# ═══════════════════════════════════════════

# Corridor West -> Courtyard (courtyard exits east to entrance_hall,
# but entrance_hall has all directions used. Connect via corridor_west south.)
exit corridor_to_courtyard {
  from        corridor_west
  to          courtyard
  direction   south
  description "A stone archway opens south to the courtyard."
}

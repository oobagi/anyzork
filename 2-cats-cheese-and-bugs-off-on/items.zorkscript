  category     "furniture"
  tags         ["scenery", "furniture"]
}

item porch_key {
  name         "Brass Key"
  description  "A heavy brass key with a circular bow."
  examine      "It has 'PORCH' scratched crudely into the metal."
  in           hallway
  home         hallway
  room_desc    "A brass key is nestled inside the wicker basket."
  drop_desc    "A brass key glints on the ground."
  takeable     true
  take_msg     "You snatch the heavy key in your teeth."
  drop_msg     "The key drops with a sharp metallic clink."
  category     "key"
  tags         ["tool", "key"]
}

item washing_machine {
  name         "Washing Machine"
  description  "A white appliance that is currently humming loudly."
  examine      "It vibrates with enough force to make your whiskers tremble."
  in           laundry_room
  takeable     false
  category     "furniture"
  tags         ["scenery"]
}


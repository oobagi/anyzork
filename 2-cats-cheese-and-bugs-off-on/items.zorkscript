  category     "furniture"
  tags         ["scenery", "furniture"]
}

item crunchy_treats {
  name         "Crunchy Treats"
  description  "A small foil bag of Salmon-flavored treats."
  examine      "The most delicious thing in the world."
  in           laundry_room
  home         laundry_room
  room_desc    "A bag of crunchy treats has been left on top of the hamper."
  drop_desc    "A crinkly bag of treats lies here."
  takeable     true
  quantity     5
  max_quantity 5
  quantity_unit "treats"
  depleted_msg "The bag is empty, much to your disappointment."
  take_msg     "You grab the bag by the corner, making it crinkle loudly."
  drop_msg     "You drop the bag."
  category     "food"
  tags         ["food", "consumable"]
}


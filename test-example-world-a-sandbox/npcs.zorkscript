npc maintenance_drone {
name        "Drone 7-B"
description "A hovering white sphere with a flickering blue lens."
examine     "Its outer shell is scorched. It emits a low, sad-sounding hum."
in          cooling_shrine
home        cooling_shrine
room_desc   "Drone 7-B hovers near the frozen radiator, its lens pulsing."
category    "character"

talk root {
"Unit 7-B diagnostic: Thermal levels critical. Substation power locked. Can you assist, User?"
option "How do I unlock the power?" -> power_hint
option "I have a tool that might help with the radiator." -> repair_check {
require_item ceramic_wrench
}
option "I'm just looking around."
}

talk power_hint {
"The override module was lost in the substation. The code is usually the current year of the sector's last calibration."
option "Thanks for the info." -> root
option "Goodbye."
}

talk repair_check {
"Analysis: Ceramic Wrench detected. Please use the tool on the cooling valve to restore thermal flow."
option "I'll do that now."
option "Maybe later."
}
}

npc holographic_guide {
name        "The Guide"
description "A translucent figure made of blue light."
examine     "The figure is flickering in and out of existence. It wears a lab coat that doesn't seem to belong here."
in          terminal_hub
home        terminal_hub
room_desc   "A holographic guide stands near the horizon gate, flickering rhythmically."
category    "character"

talk root {
"Welcome to the Hub. The Horizon Gate is sealed until the sector is fully powered and aligned."
option "What do I need to do?" -> task_list
option "Who are you?" -> identity
option "Goodbye."
}

talk task_list {
"You must: 1. Restore Substation Power. 2. Align the Logic Beam. 3. Trigger the Hub Pressure Pad."
option "I'm on it." -> root
}

talk identity {
"I am a recording. My purpose is to ensure the Null Sector is exited correctly. Don't linger too long."
option "Understood." -> root
}

flag escaped_the_null "The player has successfully breached the sector"
flag beam_revealed "The hidden exit from the logic chamber is visible"

-- Custom Commands --
on "turn {target}" in [cooling_shrine] {
require has_item(ceramic_wrench)
require not_flag(radiator_repaired)

effect set_flag(radiator_repaired)
effect add_score(15)
success "You fit the ceramic wrench onto the cooling valve and heave. With a sharp crack of breaking ice, the valve spins. Coolant rushes through the pipes with a satisfied thrum."
}

on "turn {target}" {
success "You try to turn it, but it doesn't budge or doesn't exist."
}

on "align {target}" in [logic_chamber] {
require has_item(glass_prism)
require toggle_state(photon_emitter, "on")

effect set_flag(beam_aligned)
effect reveal_exit(logic_chamber_north)
effect add_score(15)
success "You hold the glass prism in the path of the photon emitter's beam. The light splits and bounces, striking the receptor plate perfectly. A section of the north wall slides away."
}

on "align {target}" {
success "You can't align anything here without the right tools and a light source."
}

on "reboot {target}" in [power_substation] {
require has_item(override_module)
require has_flag(radiator_repaired)

effect set_flag(substation_online)
effect add_score(15)
success "You slide the override module into the slot and enter code 2026. The capacitors roar to life, bathing the room in a vibrant blue glow. Power is restored."
}

on "reboot {target}" {
success "The system doesn't respond to a reboot command here."
}

-- Triggers --
when room_enter(logic_chamber) {
require not_flag(beam_aligned)
require not_toggle_state(photon_emitter, "on")
message "The darkness here is absolute, swallowing the white walls."
once
}

when item_dropped(weighted_sphere) {
require room_is(terminal_hub)
effect set_flag(hub_weighted)
effect make_visible(data_core)
message "The weighted sphere settles into the pressure pad. With a mechanical whir, a pedestal rises from the floor, revealing a glowing data core."
}

when item_taken(data_core) {
effect set_flag(escaped_the_null)
effect unlock(horizon_gate_lock)
message "As you lift the data core, a pulse of energy ripples through the floor. The horizon gate north is now open."
once
}

-- Interaction Responses --
interaction wrench_on_fixture {
tag      "wrench"
target   "fixture"
response "You apply the {item} to the {target}. It provides the necessary leverage."
effect   set_flag(radiator_repaired)
}

interaction weight_on_fixture {
tag      "weight"
target   "fixture"
response "You place the {item} onto the {target}. The mechanical sensors acknowledge the mass."
effect   set_flag(hub_weighted)
}

interaction light_on_fixture {
tag      "light_source"
target   "fixture"
response "The beam from the {item} illuminates the {target}, but it needs to be reflected to trigger the sensor."
}

interaction tool_on_furniture {
tag      "tool"
target   "furniture"
response "You poke the {target} with the {item}. It makes a sterile clicking sound."
}

interaction electronics_on_furniture {
tag      "electronics"
target   "furniture"
response "You attempt to interface the {item} with the {target}. It fits into the designated slot."
}

interaction wrench_on_character {
tag      "wrench"
target   "character"
response "The {target} retreats slightly. 'Tool usage on chassis not authorized, User.'"
}

-- Wildcard Fallbacks --
interaction wrench_on_default {
tag      "wrench"
target   "*"
response "You wave the wrench at the {target}. Nothing happens."
}

interaction weight_on_default {
tag      "weight"
target   "*"
response "You drop the {item} onto the {target}. It makes a heavy thud, but nothing else occurs."
}

interaction tool_on_default {
tag      "tool"
target   "*"
response "The {item} doesn't seem to have a function when used on the {target}."
